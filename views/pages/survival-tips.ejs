<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>
<!-- ========================================================================= -->

<body class="app">
  <%- include('../partials/page-start'); %>

    <header class="app-header fixed-top">
      <%- include('../partials/user-navbar'); %>
        <%- include('../partials/user-sidebar'); %>
    </header>

    <div class="app-wrapper">
      <div class="app-content pt-3 p-md-3 p-lg-4">
        <div class="container-xl">
          <h1 class="app-page-title">Disaster Survival Tips</h1>

          <div class="row g-4 mb-4">
            <div class="col-12 col-lg-8">
              <div class="app-card app-card-settings shadow-sm p-4 h-100">
                <div class="app-card-body">
                  <p class="text-muted mb-4">
                    Here are some essential survival tips to help you stay safe during different types of disasters.
                  </p>

                  <div class="accordion accordion-flush" id="survivalTipsAccordion">
                    <div class="accordion-item border-bottom">
                      <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold px-0 bg-transparent text-danger" type="button"
                          data-bs-toggle="collapse" data-bs-target="#tip1">
                          <i class="fa fa-fire me-2"></i> Fire Survival Tips
                        </button>
                      </h2>
                      <div id="tip1" class="accordion-collapse collapse" data-bs-parent="#survivalTipsAccordion">
                        <div class="accordion-body px-0 text-muted">
                          <ul class="list-unstyled mb-0">
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> Stay low to the ground to
                              avoid smoke inhalation.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> If trapped inside, close all
                              doors and use a cloth to block smoke from entering.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> Don't use elevators during a
                              fire.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> If possible, use a fire
                              extinguisher for small fires, but don’t risk your safety.</li>
                            <li><i class="fa fa-check text-success me-2"></i> Always have an emergency exit plan and
                              stay calm.</li>
                          </ul>
                        </div>
                      </div>
                    </div>

                    <div class="accordion-item border-bottom">
                      <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold px-0 bg-transparent text-info" type="button"
                          data-bs-toggle="collapse" data-bs-target="#tip2">
                          <i class="fa fa-tint me-2"></i> Flood Survival Tips
                        </button>
                      </h2>
                      <div id="tip2" class="accordion-collapse collapse" data-bs-parent="#survivalTipsAccordion">
                        <div class="accordion-body px-0 text-muted">
                          <ul class="list-unstyled mb-0">
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> Move to higher ground
                              immediately.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> If trapped, climb to a
                              rooftop or stay in a safe location until help arrives.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> Do not walk or drive through
                              floodwaters as they can be dangerous.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> Listen to weather alerts and
                              evacuation orders.</li>
                            <li><i class="fa fa-check text-success me-2"></i> Keep emergency supplies such as water,
                              food, and first aid kits on hand.</li>
                          </ul>
                        </div>
                      </div>
                    </div>

                    <div class="accordion-item border-bottom">
                      <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold px-0 bg-transparent text-warning"
                          type="button" data-bs-toggle="collapse" data-bs-target="#tip3">
                          <i class="fa fa-exclamation-triangle me-2"></i> Earthquake Survival Tips
                        </button>
                      </h2>
                      <div id="tip3" class="accordion-collapse collapse" data-bs-parent="#survivalTipsAccordion">
                        <div class="accordion-body px-0 text-muted">
                          <ul class="list-unstyled mb-0">
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> If inside, take cover under a
                              table or desk. Protect your head and neck.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> If outside, move to an open
                              area away from buildings, trees, and power lines.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> Stay away from windows and
                              anything that could fall during aftershocks.</li>
                            <li><i class="fa fa-check text-success me-2"></i> Check for hazards such as gas leaks or
                              fires after the shaking stops.</li>
                          </ul>
                        </div>
                      </div>
                    </div>

                    <div class="accordion-item border-0">
                      <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold px-0 bg-transparent text-secondary"
                          type="button" data-bs-toggle="collapse" data-bs-target="#tip4">
                          <i class="fa fa-mountain me-2"></i> Landslide Survival Tips
                        </button>
                      </h2>
                      <div id="tip4" class="accordion-collapse collapse" data-bs-parent="#survivalTipsAccordion">
                        <div class="accordion-body px-0 text-muted">
                          <ul class="list-unstyled mb-0">
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> If you are near a hill or
                              mountain, move to an open space immediately.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> If trapped, create a barrier
                              to protect yourself from debris.</li>
                            <li class="mb-2"><i class="fa fa-check text-success me-2"></i> Listen for warnings and
                              evacuate immediately if instructed.</li>
                            <li><i class="fa fa-check text-success me-2"></i> Stay away from riverbeds and low-lying
                              areas that might be affected.</li>
                          </ul>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-4">
              <div class="app-card app-card-notification shadow-sm p-4">
                <h4 class="app-card-title mb-3">Emergency Hotlines</h4>
                <div class="app-card-body">
                  <p class="text-muted small">If you need immediate assistance, refer to these hotlines:</p>
                  <div class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                    <div class="d-flex flex-column">
                      <span class="fw-bold">National Hotline</span>
                    </div>
                    <span class="badge bg-danger fs-6">911</span>
                  </div>
                  <div class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                    <div class="d-flex flex-column">
                      <span class="fw-bold">PNP (Police)</span>
                      <small class="text-muted">(02) 8722-0650</small>
                    </div>
                    <span class="badge bg-primary fs-6">117</span>
                  </div>
                  <div class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                    <div class="d-flex flex-column">
                      <span class="fw-bold">BFP (Fire)</span>
                    </div>
                    <span class="badge bg-warning text-dark fs-6">(02) 8426</span>
                  </div>
                  <div class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                    <div class="d-flex flex-column">
                      <span class="fw-bold">Red Cross</span>
                      <small class="text-muted">(02) 8790-2300</small>
                    </div>
                    <span class="badge bg-info text-white fs-6">143</span>
                  </div>
                  <div class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                    <div class="d-flex flex-column">
                      <span class="fw-bold">MMDA</span>
                    </div>
                    <span class="badge bg-success fs-6">136</span>
                  </div>
                  <div class="d-flex justify-content-between align-items-center py-2">
                    <div class="d-flex flex-column">
                      <span class="fw-bold">NDRRMC Opcen</span>
                    </div>
                    <span class="badge bg-secondary fs-6 text-dark">(02) 8911</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%- include('../partials/footer'); %>
    </div>

    <%- include('../partials/page-end'); %>
      <script src="/js/script.js"></script>
</body>

</html>