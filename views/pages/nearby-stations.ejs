<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <!-- Leaflet & Routing Machine -->
        
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        
        <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.min.js"></script>
        
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/user-navbar', { currentPage: 'nearby-stations' }); %>
        </header>

        <div>
            <aside>
                <%- include('../partials/user-sidebar', { currentPage: 'nearby-stations' }); %>
            </aside>

            <main>
                <div>

                    <h1>
                        <div>
                            <i></i>
                        </div>
                        Safe Zones Mapping
                    </h1>

                    <div>

                        <!-- Map Section -->
                        <div>
                            <div>
                                <div>
                                    <h4>
                                        <i></i> Tactical Overlay
                                    </h4>
                                    <div>
                                        <div></div> Live Scan
                                        Active
                                    </div>
                                </div>
                                <div>
                                    <div id="map"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Sidebar Info Section -->
                        <div>

                            <!-- Location Info -->
                            <div>
                                <div>
                                    <h4>
                                        <i></i> Current Coordinates
                                    </h4>
                                </div>
                                <div>
                                    <div>
                                        <div>
                                            <div>
                                                Detected Location</div>
                                            <div id="address">
                                                <i></i> Acquiring
                                                satellite fix...
                                            </div>
                                        </div>
                                        <div>
                                            <div id="coords">
                                                Awaiting GPS signal
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Nearest Station Result -->
                            <div>
                                <!-- Glow -->
                                <div>
                                </div>

                                <div>
                                    <h4>
                                        <i></i> Optimal Safe Zone
                                    </h4>
                                </div>
                                <div>
                                    <div>
                                        <div>
                                            <div>
                                                <i></i>
                                            </div>
                                            <div>
                                                <div>
                                                    Designation</div>
                                                <div id="stationName1">Scanning
                                                    sector...</div>
                                            </div>
                                        </div>

                                        <div>
                                            <div>
                                                <div>
                                                    Distance</div>
                                                <div id="stationDistance1">--</div>
                                            </div>
                                            <div>
                                                <div>
                                                    Status</div>
                                                <div>
                                                    <i></i> Active
                                                </div>
                                            </div>
                                        </div>

                                        <div>
                                            <div>
                                                Address</div>
                                            <div id="stationAddress1">--</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </main>
        </div>

        <script>
            // Use custom marker icons matching the theme
            const safeZoneIcon = new L.Icon({
                iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
                shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.3.4/images/marker-shadow.png',
                iconSize: [25, 41],
                iconAnchor: [12, 41],
                popupAnchor: [1, -34],
                shadowSize: [41, 41]
            });

            // Initialize map
            const map = L.map('map', { zoomControl: false });
            L.control.zoom({ position: 'bottomright' }).addTo(map);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                maxZoom: 18,
                attribution: '© OpenStreetMap | Carto'
            }).addTo(map);

            map.locate({ setView: true, maxZoom: 14 });

            let userLat, userLng;
            let hasScanned = false; // Prevent double scan

            function onLocationFound(e) {
                const { lat, lng } = e.latlng;
                userLat = lat;
                userLng = lng;

                // Custom user icon
                const userIconHtml = `
                <div>
                    <span></span>
                    <span>
                        <i></i>
                    </span>
                </div>
            `;
                const uIcon = L.divIcon({ className: 'bg-transparent', html: userIconHtml, iconSize: [24, 24], iconAnchor: [12, 12] });

                L.marker([lat, lng], { icon: uIcon }).addTo(map)
                    .bindPopup(`<div>Current Position</div>`).openPopup();

                L.circle([lat, lng], { radius: e.accuracy, color: '#10b981', fillColor: '#10b981', fillOpacity: 0.1, weight: 1 }).addTo(map);

                document.getElementById("coords").textContent = `LAT: ${lat.toFixed(5)} | LNG: ${lng.toFixed(5)}`;

                fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`)
                    .then(res => res.json())
                    .then(data => {
                        document.getElementById("address").innerHTML = `<i></i> <span>${data.display_name}</span>`;
                    });

                if (!hasScanned) {
                    hasScanned = true;
                    fetchStations(lat, lng);
                }
            }

            function onLocationError(e) {
                document.getElementById("address").innerHTML = `<span>Failed to acquire satellite fix. Check permissions.</span>`;
                document.getElementById("coords").innerHTML = `--`;
            }

            map.on('locationfound', onLocationFound);
            map.on('locationerror', onLocationError);

            function fetchStations(lat, lng) {
                document.getElementById("stationName1").textContent = "Calculating vectors...";
                fetch('/nearby-stations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lat: lat, lng: lng })
                })
                    .then(res => res.json())
                    .then(data => {
                        if (!data || data.length === 0) {
                            document.getElementById("stationName1").textContent = "No safe zones in range.";
                            return;
                        }

                        const nearest = data[0];
                        document.getElementById("stationName1").textContent = nearest.name;
                        document.getElementById("stationAddress1").textContent = nearest.address;
                        document.getElementById("stationDistance1").textContent = `${nearest.distance.toFixed(2)} km`;

                        data.forEach(station => {
                            let typeBadge = '';
                            if (station.type.toLowerCase().includes('police')) {
                                typeBadge = '<span>PNP</span>';
                            } else if (station.type.toLowerCase().includes('fire')) {
                                typeBadge = '<span>BFP</span>';
                            }

                            const popupContent = `
                        <div>
                            <div>
                                ${station.name}
                                ${typeBadge}
                            </div>
                            <div>
                                <div><i></i> ${station.distance.toFixed(2)} km</div>
                                <div><i></i> ${station.address}</div>
                            </div>
                        </div>
                    `;

                            L.marker([station.latitude, station.longitude], { icon: safeZoneIcon })
                                .addTo(map)
                                .bindPopup(popupContent);
                        });

                        // Routing
                        L.Routing.control({
                            waypoints: [
                                L.latLng(lat, lng),
                                L.latLng(nearest.latitude, nearest.longitude)
                            ],
                            lineOptions: {
                                styles: [{ color: '#6366f1', weight: 5, opacity: 0.8, className: 'animate-route dash-array' }]
                            },
                            routeWhileDragging: false,
                            showAlternatives: false,
                            addWaypoints: false,
                            draggableWaypoints: false,
                            fitSelectedRoutes: true,
                            show: false, // hide the text directions panel for a cleaner UI
                            createMarker: function () { return null; }
                        }).addTo(map);

                        // Add custom styling for the dashed route line
                        const style = document.createElement('style');
                        style.innerHTML = `
                    .animate-route { stroke-dasharray: 10, 10; animation: dash 1s linear infinite; }
                    @keyframes dash { to { stroke-dashoffset: -20; } }
                `;
                        document.head.appendChild(style);

                    })
                    .catch(err => {
                        console.error(err);
                        document.getElementById("stationName1").innerHTML = `<span>Error loading data</span>`;
                    });
            }
        </script>

        <%- include('../partials/footer'); %>
            <%- include('../partials/page-end'); %>
</body>

</html>