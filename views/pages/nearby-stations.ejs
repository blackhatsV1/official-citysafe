<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <!-- Leaflet & Routing Machine -->

        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

        <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.min.js"></script>

</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/user-navbar', { currentPage: 'nearby-stations' }); %>
        </header>

        <div class="cs-layout-container">
            <aside>
                <%- include('../partials/user-sidebar', { currentPage: 'nearby-stations' }); %>
            </aside>

            <main class="cs-main-content">
                <div class="cs-container">

                    <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 3rem;">
                        <div class="cs-badge"
                            style="width: 64px; height: 64px; font-size: 1.5rem; background: var(--primary-glow); color: var(--primary); border: 2px solid var(--primary);">
                            <i class="fa-solid fa-map-location-dot"></i>
                        </div>
                        <h1 class="cs-section-header" style="margin: 0;">
                            SAFE ZONES <span
                                style="background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">MAPPING</span>
                        </h1>
                    </div>

                    <div class="cs-grid cs-grid-2">

                        <!-- Map Section -->
                        <div class="cs-card"
                            style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem;">
                            <div
                                style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem;">
                                <div style="display: flex; align-items: center; gap: 1rem;">
                                    <div class="cs-badge" style="background: var(--info-glow); color: var(--info);"><i
                                            class="fa-solid fa-radar"></i></div>
                                    <h4
                                        style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                        TACTICAL OVERLAY</h4>
                                </div>
                                <div
                                    style="font-size: 0.65rem; font-weight: 900; color: #10b981; border: 1px solid #10b981; padding: 0.3rem 0.6rem; border-radius: 2rem; display: flex; align-items: center; gap: 0.4rem; background: rgba(16, 185, 129, 0.1);">
                                    <div
                                        style="width: 6px; height: 6px; background: #10b981; border-radius: 50%; box-shadow: 0 0 5px #10b981; animation: pulse 2s infinite;">
                                    </div> LIVE SCAN ACTIVE
                                </div>
                            </div>
                            <div class="cs-map-container" id="map" style="height: 480px; border-radius: 1rem;"></div>
                        </div>

                        <!-- Sidebar Info Section -->
                        <div style="display: flex; flex-direction: column; gap: 1.5rem;">

                            <!-- Location Info -->
                            <div class="cs-card" style="padding: 2rem;">
                                <div
                                    style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem;">
                                    <div class="cs-badge"
                                        style="background: var(--primary-glow); color: var(--primary);"><i
                                            class="fa-solid fa-location-crosshairs"></i></div>
                                    <h4
                                        style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                        POSITIONAL TELEMETRY</h4>
                                </div>
                                <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                                    <div
                                        style="background: rgba(0,0,0,0.2); border: 1px solid var(--border-glass); padding: 1.25rem; border-radius: 1rem;">
                                        <div
                                            style="font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase; letter-spacing: 0.05rem; margin-bottom: 0.5rem;">
                                            Detected Location</div>
                                        <div id="address"
                                            style="font-size: 0.95rem; color: var(--text-bright); line-height: 1.5; font-weight: 600;">
                                            <i class="fa-solid fa-spinner fa-spin"></i> Acquiring satellite fix...
                                        </div>
                                    </div>
                                    <div id="coords"
                                        style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: var(--primary); background: var(--primary-glow); align-self: flex-start; padding: 0.4rem 0.8rem; border-radius: 0.5rem; border: 1px solid var(--primary);">
                                        0.00000 | 0.00000
                                    </div>
                                </div>
                            </div>

                            <!-- Nearest Station Result -->
                            <div class="cs-card" style="padding: 2rem; position: relative; overflow: hidden;">
                                <div
                                    style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: radial-gradient(circle, rgba(99, 102, 241, 0.1) 0%, transparent 70%); border-radius: 50%; pointer-events: none;">
                                </div>

                                <div
                                    style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem;">
                                    <div class="cs-badge" style="background: var(--accent-glow); color: var(--accent);">
                                        <i class="fa-solid fa-shield-heart"></i></div>
                                    <h4
                                        style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                        OPTIMAL SAFE ZONE</h4>
                                </div>

                                <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                                    <div style="display: flex; gap: 1.25rem; align-items: flex-start;">
                                        <div class="cs-badge"
                                            style="width: 48px; height: 48px; font-size: 1.25rem; background: rgba(255,255,255,0.05); color: var(--text-bright);">
                                            <i class="fa-solid fa-building-shield"></i></div>
                                        <div>
                                            <div
                                                style="font-size: 0.75rem; font-weight: 800; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.05rem; margin-bottom: 0.25rem;">
                                                Designation</div>
                                            <div id="stationName1"
                                                style="font-size: 1.1rem; font-weight: 800; color: var(--text-bright);">
                                                Scanning sector...</div>
                                        </div>
                                    </div>

                                    <div class="cs-grid cs-grid-2" style="gap: 1rem;">
                                        <div
                                            style="background: rgba(0,0,0,0.2); border: 1px solid var(--border-glass); padding: 1rem; border-radius: 0.75rem;">
                                            <div
                                                style="font-size: 0.65rem; font-weight: 800; color: var(--primary); margin-bottom: 0.25rem;">
                                                DISTANCE</div>
                                            <div id="stationDistance1"
                                                style="font-size: 1rem; font-weight: 800; color: var(--text-bright); font-family: 'JetBrains Mono', monospace;">
                                                --</div>
                                        </div>
                                        <div
                                            style="background: rgba(0,0,0,0.2); border: 1px solid var(--border-glass); padding: 1rem; border-radius: 0.75rem;">
                                            <div
                                                style="font-size: 0.65rem; font-weight: 800; color: #10b981; margin-bottom: 0.25rem;">
                                                STATUS</div>
                                            <div
                                                style="font-size: 0.85rem; font-weight: 800; color: var(--text-bright); display: flex; align-items: center; gap: 0.4rem;">
                                                <i class="fa-solid fa-circle-check" style="color: #10b981;"></i> ACTIVE
                                            </div>
                                        </div>
                                    </div>

                                    <div
                                        style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-glass); padding: 1rem; border-radius: 0.75rem;">
                                        <div
                                            style="font-size: 0.65rem; font-weight: 800; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.5rem;">
                                            Sector Address</div>
                                        <div id="stationAddress1"
                                            style="font-size: 0.85rem; color: var(--text-dim); line-height: 1.4;">--
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </main>
        </div>

        <script>
            // Use custom marker icons matching the theme
            const safeZoneIcon = new L.Icon({
                iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
                shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.3.4/images/marker-shadow.png',
                iconSize: [25, 41],
                iconAnchor: [12, 41],
                popupAnchor: [1, -34],
                shadowSize: [41, 41]
            });

            // Initialize map
            const map = L.map('map', { zoomControl: false });
            L.control.zoom({ position: 'bottomright' }).addTo(map);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                maxZoom: 18,
                attribution: '© OpenStreetMap | Carto'
            }).addTo(map);

            map.locate({ setView: true, maxZoom: 14 });

            let userLat, userLng;
            let hasScanned = false; // Prevent double scan

            function onLocationFound(e) {
                const { lat, lng } = e.latlng;
                userLat = lat;
                userLng = lng;

                // Custom user icon
                const userIconHtml = `
                <div>
                    <span></span>
                    <span>
                        <i></i>
                    </span>
                </div>
            `;
                const uIcon = L.divIcon({ className: 'bg-transparent', html: userIconHtml, iconSize: [24, 24], iconAnchor: [12, 12] });

                L.marker([lat, lng], { icon: uIcon }).addTo(map)
                    .bindPopup(`<div>Current Position</div>`).openPopup();

                L.circle([lat, lng], { radius: e.accuracy, color: '#10b981', fillColor: '#10b981', fillOpacity: 0.1, weight: 1 }).addTo(map);

                document.getElementById("coords").textContent = `LAT: ${lat.toFixed(5)} | LNG: ${lng.toFixed(5)}`;

                fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`)
                    .then(res => res.json())
                    .then(data => {
                        document.getElementById("address").innerHTML = `<i></i> <span>${data.display_name}</span>`;
                    });

                if (!hasScanned) {
                    hasScanned = true;
                    fetchStations(lat, lng);
                }
            }

            function onLocationError(e) {
                document.getElementById("address").innerHTML = `<span>Failed to acquire satellite fix. Check permissions.</span>`;
                document.getElementById("coords").innerHTML = `--`;
            }

            map.on('locationfound', onLocationFound);
            map.on('locationerror', onLocationError);

            function fetchStations(lat, lng) {
                document.getElementById("stationName1").textContent = "Calculating vectors...";
                fetch('/nearby-stations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lat: lat, lng: lng })
                })
                    .then(res => res.json())
                    .then(data => {
                        if (!data || data.length === 0) {
                            document.getElementById("stationName1").textContent = "No safe zones in range.";
                            return;
                        }

                        const nearest = data[0];
                        document.getElementById("stationName1").textContent = nearest.name;
                        document.getElementById("stationAddress1").textContent = nearest.address;
                        document.getElementById("stationDistance1").textContent = `${nearest.distance.toFixed(2)} km`;

                        data.forEach(station => {
                            let typeBadge = '';
                            if (station.type.toLowerCase().includes('police')) {
                                typeBadge = '<span>PNP</span>';
                            } else if (station.type.toLowerCase().includes('fire')) {
                                typeBadge = '<span>BFP</span>';
                            }

                            const popupContent = `
                        <div>
                            <div>
                                ${station.name}
                                ${typeBadge}
                            </div>
                            <div>
                                <div><i></i> ${station.distance.toFixed(2)} km</div>
                                <div><i></i> ${station.address}</div>
                            </div>
                        </div>
                    `;

                            L.marker([station.latitude, station.longitude], { icon: safeZoneIcon })
                                .addTo(map)
                                .bindPopup(popupContent);
                        });

                        // Routing
                        L.Routing.control({
                            waypoints: [
                                L.latLng(lat, lng),
                                L.latLng(nearest.latitude, nearest.longitude)
                            ],
                            lineOptions: {
                                styles: [{ color: '#6366f1', weight: 5, opacity: 0.8, className: 'animate-route dash-array' }]
                            },
                            routeWhileDragging: false,
                            showAlternatives: false,
                            addWaypoints: false,
                            draggableWaypoints: false,
                            fitSelectedRoutes: true,
                            show: false, // hide the text directions panel for a cleaner UI
                            createMarker: function () { return null; }
                        }).addTo(map);

                        // Add custom styling for the dashed route line
                        const style = document.createElement('style');
                        style.innerHTML = `
                    .animate-route { stroke-dasharray: 10, 10; animation: dash 1s linear infinite; }
                    @keyframes dash { to { stroke-dashoffset: -20; } }
                `;
                        document.head.appendChild(style);

                    })
                    .catch(err => {
                        console.error(err);
                        document.getElementById("stationName1").innerHTML = `<span>Error loading data</span>`;
                    });
            }
        </script>

        <%- include('../partials/footer'); %>
            <%- include('../partials/page-end'); %>
</body>

</html>