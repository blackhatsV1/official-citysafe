<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body
  class="bg-gradient-glass-light dark:bg-gradient-glass-dark text-gray-800 dark:text-gray-100 min-h-screen flex flex-col">
  <%- include('../partials/page-start'); %>

    <header class="sticky top-0 z-50">
      <%- include('../partials/admin-navbar', { currentPage: 'users' }); %>
    </header>

    <div class="flex flex-1 overflow-hidden relative">
      <aside class="z-40">
        <%- include('../partials/admin-sidebar', { currentPage: 'users' }); %>
      </aside>

      <main class="flex-1 px-4 py-6 sm:px-6 lg:px-8 overflow-y-auto w-full">
        <div class="max-w-7xl mx-auto space-y-6">

          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <h1 class="text-2xl font-black text-gray-900 dark:text-gray-100 tracking-tight">USER DIRECTORY</h1>
            <a href="/addusers" class="btn-glass-primary whitespace-nowrap"><i class="fa fa-user-plus mr-2"></i>New
              Citizen</a>
            <a href="/addresponder" class="btn-glass whitespace-nowrap text-red-600 dark:text-red-400"><i
                class="fa fa-user-md mr-2"></i>New Responder</a>
          </div>

          <div class="glass-panel overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 bg-white/40 dark:bg-gray-900/40">
              <h2 class="text-sm font-bold uppercase tracking-wider text-gray-700 dark:text-gray-300">Registered
                Accounts</h2>
            </div>

            <div class="overflow-x-auto w-full">
              <table class="w-full text-left border-collapse">
                <thead>
                  <tr
                    class="bg-gray-50/50 dark:bg-gray-800/50 text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 font-bold border-b border-gray-100 dark:border-gray-800">
                    <th class="px-6 py-4">Actions</th>
                    <th class="px-6 py-4">Type</th>
                    <th class="px-6 py-4">ID</th>
                    <th class="px-6 py-4">Name</th>
                    <th class="px-6 py-4">Location (Bgy/City)</th>
                    <th class="px-6 py-4">Email</th>
                    <th class="px-6 py-4">Contact</th>
                    <th class="px-6 py-4">Role</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-800/60 text-sm">
                  <% responders.forEach(res=> { %>
                    <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-800/30 transition-colors">
                      <td class="px-6 py-3 whitespace-nowrap">
                        <div class="flex items-center gap-2">
                          <a href="/edit-responder/<%= res.id %>"
                            class="px-3 py-1 bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 rounded font-bold text-xs transition-colors">Edit</a>
                          <button onclick="deleteResponder(<%= res.id %>)"
                            class="px-3 py-1 bg-red-100 hover:bg-red-200 dark:bg-red-900/30 dark:hover:bg-red-900/50 text-red-700 dark:text-red-400 rounded font-bold text-xs transition-colors">Delete</button>
                        </div>
                      </td>
                      <td class="px-6 py-3 whitespace-nowrap">
                        <span
                          class="px-2 py-1 bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400 rounded text-xs font-bold uppercase tracking-wider">Responder</span>
                      </td>
                      <td class="px-6 py-3 text-gray-500 dark:text-gray-400 font-mono">
                        <%= res.id %>
                      </td>
                      <td class="px-6 py-3 font-semibold text-gray-900 dark:text-gray-100">
                        <%= res.firstname %>
                          <%= res.lastname %>
                      </td>
                      <td class="px-6 py-3 text-gray-600 dark:text-gray-300">
                        <%= res.station_name || 'N/A' %>
                      </td>
                      <td class="px-6 py-3 text-gray-600 dark:text-gray-300">
                        <%= res.email %>
                      </td>
                      <td class="px-6 py-3 text-gray-600 dark:text-gray-300">
                        <%= res.contact_number %>
                      </td>
                      <td class="px-6 py-3 whitespace-nowrap">
                        <span
                          class="px-2 py-1 bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400 rounded text-xs font-bold uppercase tracking-wider">responder</span>
                      </td>
                    </tr>
                    <% }) %>
                      <% users.forEach(user=> { %>
                        <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-800/30 transition-colors">
                          <td class="px-6 py-3 whitespace-nowrap">
                            <div class="flex items-center gap-2">
                              <a href="/edit/<%= user.id %>"
                                class="px-3 py-1 bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 rounded font-bold text-xs transition-colors">Edit</a>
                              <button onclick="deleteUser(<%= user.id %>)"
                                class="px-3 py-1 bg-red-100 hover:bg-red-200 dark:bg-red-900/30 dark:hover:bg-red-900/50 text-red-700 dark:text-red-400 rounded font-bold text-xs transition-colors">Delete</button>
                            </div>
                          </td>
                          <td class="px-6 py-3 whitespace-nowrap">
                            <span
                              class="px-2 py-1 bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300 rounded text-xs font-bold uppercase tracking-wider">Citizen</span>
                          </td>
                          <td class="px-6 py-3 text-gray-500 dark:text-gray-400 font-mono">
                            <%= user.id %>
                          </td>
                          <td class="px-6 py-3 font-semibold text-gray-900 dark:text-gray-100">
                            <%= user.firstname %>
                              <%= user.lastname %>
                          </td>
                          <td class="px-6 py-3 text-gray-600 dark:text-gray-300">
                            <%= user.barangay %>, <%= user.city %>
                          </td>
                          <td class="px-6 py-3 text-gray-600 dark:text-gray-300">
                            <%= user.email %>
                          </td>
                          <td class="px-6 py-3 text-gray-600 dark:text-gray-300">
                            <%= user.contact_number %>
                          </td>
                          <td class="px-6 py-3 whitespace-nowrap">
                            <span
                              class="px-2 py-1 bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400 rounded text-xs font-bold uppercase tracking-wider">
                              <%= user.role %>
                            </span>
                          </td>
                        </tr>
                        <% }) %>
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>

      <script src="/js/script.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
      <script>
        function deleteUser(id) {
          Swal.fire({
            title: 'Are you sure?',
            text: "This will permanently remove the user and their disaster reports!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, delete user',
            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
          }).then((result) => {
            if (result.isConfirmed) {
              window.location.href = '/admin-delete/' + id;
            }
          });
        }

        function deleteResponder(id) {
          Swal.fire({
            title: 'Are you sure?',
            text: "This will permanently remove the responder!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, delete responder',
            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
          }).then((result) => {
            if (result.isConfirmed) {
              window.location.href = '/admin-delete-responder/' + id;
            }
          });
        }
      </script>
</body>

</html>