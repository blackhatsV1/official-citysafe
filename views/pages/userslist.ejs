<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>
<!-- ========================================================================= -->

<body class="app">
  <%- include('../partials/page-start'); %>
    <header class="app-header fixed-top">
      <%- include('../partials/admin-navbar', { currentPage: 'users' }); %>
        <%- include('../partials/admin-sidebar', { currentPage: 'users' }); %>
    </header>

    <div class="app-wrapper">
      <div class="app-content pt-3 p-md-3 p-lg-4">
        <div class="container-xl">
          <div class="row g-3 mb-4 align-items-center justify-content-between">
            <div class="col-auto">
              <h1 class="app-page-title mb-0">User Directory</h1>
            </div>
          </div>

          <div class="app-card app-card-orders-table shadow-sm mb-5">
            <div class="app-card-body">
              <div class="table-responsive">
                <table class="table app-table-hover mb-0 text-left">
                  <thead>
                    <tr>
                      <th class="cell">Actions</th>
                      <th class="cell">Type</th>
                      <th class="cell">ID</th>
                      <th class="cell">Name</th>
                      <th class="cell">Location (Bgy/City)</th>
                      <th class="cell">Email</th>
                      <th class="cell">Contact</th>
                      <th class="cell">Role</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% responders.forEach(res=> { %>
                      <tr>
                        <td class="cell">
                          <a class="btn-sm app-btn-secondary" href="/edit-responder/<%= res.id %>">Edit</a>
                          <button class="btn-sm btn-outline-danger border-0"
                            onclick="deleteResponder(<%= res.id %>)">Delete</button>
                        </td>
                        <td class="cell"><span class="badge bg-info">Responder</span></td>
                        <td class="cell">
                          <%= res.id %>
                        </td>
                        <td class="cell">
                          <%= res.firstname %>
                            <%= res.lastname %>
                        </td>
                        <td class="cell">
                          <%= res.station_name || 'N/A' %>
                        </td>
                        <td class="cell">
                          <%= res.email %>
                        </td>
                        <td class="cell">
                          <%= res.contact_number %>
                        </td>
                        <td class="cell"><span class="badge bg-success">responder</span></td>
                      </tr>
                      <% }) %>
                        <% users.forEach(user=> { %>
                          <tr>
                            <td class="cell">
                              <a class="btn-sm app-btn-secondary" href="/edit/<%= user.id %>">Edit</a>
                              <button class="btn-sm btn-outline-danger border-0"
                                onclick="deleteUser(<%= user.id %>)">Delete</button>
                            </td>
                            <td class="cell"><span class="badge bg-secondary">Citizen</span></td>
                            <td class="cell">
                              <%= user.id %>
                            </td>
                            <td class="cell">
                              <%= user.firstname %>
                                <%= user.lastname %>
                            </td>
                            <td class="cell">
                              <%= user.barangay %>, <%= user.city %>
                            </td>
                            <td class="cell">
                              <%= user.email %>
                            </td>
                            <td class="cell">
                              <%= user.contact_number %>
                            </td>
                            <td class="cell"><span class="badge bg-info">
                                <%= user.role %>
                              </span></td>
                          </tr>
                          <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <footer class="app-footer">
        <%- include('../partials/footer'); %>
      </footer>
    </div>

    <script src="/js/script.js"></script>
    <script>
      function deleteUser(id) {
        Swal.fire({
          title: 'Are you sure?',
          text: "This will permanently remove the user and their disaster reports!",
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#d33',
          cancelButtonColor: '#6c757d',
          confirmButtonText: 'Yes, delete user'
        }).then((result) => {
          if (result.isConfirmed) {
            window.location.href = '/admin-delete/' + id;
          }
        });
      }

      function deleteResponder(id) {
        Swal.fire({
          title: 'Are you sure?',
          text: "This will permanently remove the responder!",
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#d33',
          cancelButtonColor: '#6c757d',
          confirmButtonText: 'Yes, delete responder'
        }).then((result) => {
          if (result.isConfirmed) {
            window.location.href = '/admin-delete-responder/' + id;
          }
        });
      }
    </script>
</body>

</html>