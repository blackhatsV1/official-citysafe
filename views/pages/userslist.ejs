<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body>
  <%- include('../partials/page-start'); %>

    <header>
      <%- include('../partials/admin-navbar', { currentPage: 'users' }); %>
    </header>

    <div>
      <aside>
        <%- include('../partials/admin-sidebar', { currentPage: 'users' }); %>
      </aside>

      <main>
        <div>

          <div>
            <h1>USER DIRECTORY</h1>
            <a href="/addusers"><i></i>New
              Citizen</a>
            <a href="/addresponder"><i></i>New Responder</a>
          </div>

          <div>
            <div>
              <h2>Registered
                Accounts</h2>
            </div>

            <div>
              <table>
                <thead>
                  <tr>
                    <th>Actions</th>
                    <th>Type</th>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Location (Bgy/City)</th>
                    <th>Email</th>
                    <th>Contact</th>
                    <th>Role</th>
                  </tr>
                </thead>
                <tbody>
                  <% responders.forEach(res=> { %>
                    <tr>
                      <td>
                        <div>
                          <a href="/edit-responder/<%= res.id %>">Edit</a>
                          <button onclick="deleteResponder(<%= res.id %>)">Delete</button>
                        </div>
                      </td>
                      <td>
                        <span>Responder</span>
                      </td>
                      <td>
                        <%= res.id %>
                      </td>
                      <td>
                        <%= res.firstname %>
                          <%= res.lastname %>
                      </td>
                      <td>
                        <%= res.station_name || 'N/A' %>
                      </td>
                      <td>
                        <%= res.email %>
                      </td>
                      <td>
                        <%= res.contact_number %>
                      </td>
                      <td>
                        <span>responder</span>
                      </td>
                    </tr>
                    <% }) %>
                      <% users.forEach(user=> { %>
                        <tr>
                          <td>
                            <div>
                              <a href="/edit/<%= user.id %>">Edit</a>
                              <button onclick="deleteUser(<%= user.id %>)">Delete</button>
                            </div>
                          </td>
                          <td>
                            <span>Citizen</span>
                          </td>
                          <td>
                            <%= user.id %>
                          </td>
                          <td>
                            <%= user.firstname %>
                              <%= user.lastname %>
                          </td>
                          <td>
                            <%= user.barangay %>, <%= user.city %>
                          </td>
                          <td>
                            <%= user.email %>
                          </td>
                          <td>
                            <%= user.contact_number %>
                          </td>
                          <td>
                            <span>
                              <%= user.role %>
                            </span>
                          </td>
                        </tr>
                        <% }) %>
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>

      <script src="/js/script.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
      <script>
        function deleteUser(id) {
          Swal.fire({
            title: 'Are you sure?',
            text: "This will permanently remove the user and their disaster reports!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, delete user',
            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
          }).then((result) => {
            if (result.isConfirmed) {
              window.location.href = '/admin-delete/' + id;
            }
          });
        }

        function deleteResponder(id) {
          Swal.fire({
            title: 'Are you sure?',
            text: "This will permanently remove the responder!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, delete responder',
            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
          }).then((result) => {
            if (result.isConfirmed) {
              window.location.href = '/admin-delete-responder/' + id;
            }
          });
        }
      </script>
</body>

</html>