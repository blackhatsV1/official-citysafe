<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="app">
    <%- include('../partials/page-start'); %>
        <header class="app-header fixed-top">
            <%- include('../partials/responder-navbar'); %>
                <%- include('../partials/responder-sidebar'); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <h1 class="app-page-title">Reaction History</h1>

                    <div class="app-card app-card-orders shadow-sm mb-5">
                        <div class="app-card-body">
                            <div class="table-responsive">
                                <table class="table app-table-hover mb-0 text-left">
                                    <thead>
                                        <tr>
                                            <th class="cell">Date/Time</th>
                                            <th class="cell">Resolved Time</th>
                                            <th class="cell">Type</th>
                                            <th class="cell">Location</th>
                                            <th class="cell">Resolved By</th>
                                            <th class="cell">Intelligence/Remarks</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (reports.length> 0) { %>
                                            <% reports.forEach(function(report) { %>
                                                <tr>
                                                    <td class="cell"><span class="note">
                                                            <%= new Date(report.reported_at).toLocaleString() %>
                                                        </span></td>
                                                    <td class="cell"><span class="note">
                                                            <%= report.resolved_at ? new
                                                                Date(report.resolved_at).toLocaleString() : '-' %>
                                                        </span></td>
                                                    <td class="cell"><span class="badge bg-danger">
                                                            <%= report.disaster_type %>
                                                        </span></td>
                                                    <td class="cell small">
                                                        <%= report.location || 'Unknown Coordinates' %>
                                                    </td>
                                                    <td class="cell"><span class="badge bg-success">
                                                            <%= report.resolved_by || 'Unknown' %>
                                                        </span></td>
                                                    <td class="cell">
                                                        <div class="small">
                                                            <div class="mb-1"><strong
                                                                    class="text-primary">Unit:</strong>
                                                                <%= report.responder_message || '-' %>
                                                            </div>
                                                            <div><strong class="text-info">HQ/User:</strong>
                                                                <%= report.user_message || '-' %>
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="6" class="text-center py-4 text-muted">No
                                                                historical deployments found.</td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <footer class="app-footer">
                <%- include('../partials/footer'); %>
            </footer>
        </div>

        <script src="/js/script.js"></script>
</body>

</html>