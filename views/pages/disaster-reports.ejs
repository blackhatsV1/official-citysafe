<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/admin-navbar', { currentPage: 'disaster-reports' }); %>
        </header>

        <div>
            <aside>
                <%- include('../partials/admin-sidebar', { currentPage: 'disaster-reports' }); %>
            </aside>

            <main>

                <div>

                    <div>
                        <h1>
                            Incident Management Ledger</h1>
                        <div>
                            <span>
                                <span></span>
                                REAL-TIME SYNC
                            </span>
                            <div></div>
                            <span
                                id="sync-timer">Last update: just now</span>
                        </div>
                    </div>

                    <div>
                        <div>
                            <h2>Live
                                Operations Feed</h2>
                        </div>

                        <div>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Mission Control</th>
                                        <th>Personnel / Sender</th>
                                        <th>Classification</th>
                                        <th>Sector / Location</th>
                                        <th>Comms Feed</th>
                                        <th>Resolution</th>
                                        <th>Timestamp</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% reports.forEach(report=> { %>
                                        <tr>
                                            <td>
                                                <% if (report.status==='responding' ) { %>
                                                    <div>
                                                        <span>
                                                            IN PROGRESS
                                                        </span>
                                                        <button onclick="cancelReportAdmin('<%= report.id %>')"
                                                            title="Abort Mission">
                                                            <i></i>
                                                        </button>
                                                    </div>
                                                    <% } else if (report.status==='resolved' ) { %>
                                                        <span>
                                                            RESOLVED
                                                        </span>
                                                        <% } else if (report.status.includes('cancelled')) { %>
                                                            <span>
                                                                CANCELLED
                                                            </span>
                                                            <% } else { %>
                                                                <div>
                                                                    <button onclick="initiateDeploy(this)"
                                                                        data-id="<%= report.id %>"
                                                                        data-location="<%= report.location %>"
                                                                        data-lat="<%= report.latitude %>"
                                                                        data-lon="<%= report.longitude %>"
                                                                        data-type="<%= report.disaster_type %>"
                                                                        data-date="<%= new Date(report.reported_at).toLocaleString() %>">
                                                                        DEPLOY
                                                                    </button>
                                                                    <button
                                                                        onclick="cancelReportAdmin('<%= report.id %>')">
                                                                        CANCEL
                                                                    </button>
                                                                </div>
                                                                <% } %>
                                            </td>

                                            <td>
                                                <div>
                                                    <span>
                                                        <%= report.sender %>
                                                    </span>
                                                    <% if (report.responder_name) { %>
                                                        <span>
                                                            <i></i>
                                                            <%= report.responder_name %>
                                                        </span>
                                                        <% } else { %>
                                                            <span>Unassigned</span>
                                                            <% } %>
                                                </div>
                                            </td>

                                            <td>
                                                <% let
                                                    badgeColors='bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300'
                                                    ; let icon='fa-exclamation-circle' ; if
                                                    (report.disaster_type==='Fire' ) {
                                                    badgeColors='bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400'
                                                    ; icon='fa-fire' ; } else if (report.disaster_type==='Flood' ) {
                                                    badgeColors='bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400'
                                                    ; icon='fa-water' ; } else if (report.disaster_type==='Earthquake' )
                                                    {
                                                    badgeColors='bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-400'
                                                    ; icon='fa-house-crack' ; } else if
                                                    (report.disaster_type==='Landslide' ) {
                                                    badgeColors='bg-stone-100 text-stone-700 dark:bg-stone-900/40 dark:text-stone-400'
                                                    ; icon='fa-mountain' ; } %>
                                                    <span>
                                                        <i></i>
                                                        <%= report.disaster_type %>
                                                    </span>
                                            </td>

                                            <td>
                                                <div>
                                                    <span
                                                        id="loc-display-<%= report.id %>">
                                                        <%= (report.latitude && report.longitude) ?
                                                            `${report.latitude.toFixed(4)},
                                                            ${report.longitude.toFixed(4)}` : (report.location || "N/A"
                                                            ) %>
                                                    </span>
                                                    <% if (report.latitude && report.longitude) { %>
                                                        <button
                                                            onclick="fetchFormattedAddress(this, <%= report.latitude %>, <%= report.longitude %>, 'loc-display-<%= report.id %>'); return false;">
                                                            Show Address
                                                        </button>
                                                        <% } %>
                                                </div>
                                            </td>

                                            <td>
                                                <div>
                                                    <div>
                                                        "<%= report.user_message || 'No civilian intel' %>"
                                                    </div>
                                                    <% if(report.responder_name) { %>
                                                        <div>
                                                            "<%= report.responder_message || 'Awaiting update' %>"
                                                        </div>
                                                        <% } %>
                                                </div>
                                            </td>

                                            <td>
                                                <% if (report.status==='resolved' ) { %>
                                                    <div>
                                                        <% if (report.user_confirmed_at) { %>
                                                            <div
                                                                title="User Confirmed">
                                                                <i></i>
                                                            </div>
                                                            <% } %>
                                                                <% if (report.responder_confirmed_at) { %>
                                                                    <div
                                                                        title="Responder Confirmed">
                                                                        <i></i>
                                                                    </div>
                                                                    <% } %>
                                                    </div>
                                                    <span>
                                                        <%= report.resolution_remarks || 'System Resolved' %>
                                                    </span>
                                                    <% } else { %>
                                                        <span>Awaiting
                                                            Resolution</span>
                                                        <% } %>
                                            </td>

                                            <td>
                                                <div>
                                                    <span>
                                                        <%= new Date(report.reported_at).toLocaleTimeString([],
                                                            {hour: '2-digit' , minute:'2-digit'}) %>
                                                    </span>
                                                    <span>
                                                        <%= new Date(report.reported_at).toLocaleDateString() %>
                                                    </span>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>

                            <% if(reports.length===0) { %>
                                <div>
                                    <div>
                                        <i></i>
                                    </div>
                                    <h3>No Active Incidents
                                    </h3>
                                    <p>There are no reports in the
                                        ledger currently.</p>
                                </div>
                                <% } %>
                        </div>
                    </div>
                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>

            <!-- Scripts -->
            <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script src="/js/script.js"></script>

            <script>
                async function initiateDeploy(btn) {
                    const reportId = btn.getAttribute('data-id');
                    const storedLat = btn.getAttribute('data-lat');
                    const storedLon = btn.getAttribute('data-lon');
                    const reportType = btn.getAttribute('data-type') || 'General';
                    const reportDate = btn.getAttribute('data-date') || 'N/A';
                    const locationStr = btn.getAttribute('data-location') || `Lat: ${storedLat}, Lon: ${storedLon}`;

                    let incLat = parseFloat(storedLat);
                    let incLon = parseFloat(storedLon);

                    if (!incLat || !incLon) {
                        Swal.fire({
                            title: 'Geospatial Error',
                            text: 'Incomplete coordinate metadata for deployment.',
                            icon: 'error',
                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                        });
                        return;
                    }

                    if (typeof window.openSharedDeployModal === 'function') {
                        window.openSharedDeployModal({ reportId, lat: incLat, lng: incLon, type: reportType, dateStr: reportDate, locationStr });
                    }
                }

                function cancelReportAdmin(id) {
                    Swal.fire({
                        title: 'ABORT MISSION?',
                        text: "Are you sure you want to cancel this emergency protocol?",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#6b7280',
                        confirmButtonText: 'CONFIRM ABORT',
                        reverseButtons: true,
                        background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                        color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            fetch('/api/admin/cancel_report', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ id: id })
                            })
                                .then(res => res.json())
                                .then(data => {
                                    if (data.success) {
                                        Swal.fire({
                                            title: 'Aborted',
                                            text: 'Operation has been successfully cancelled.',
                                            icon: 'success',
                                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                                        }).then(() => location.reload());
                                    }
                                });
                        }
                    });
                }

                async function fetchFormattedAddress(btnEl, lat, lon, targetId) {
                    const targetEl = document.getElementById(targetId);
                    if (!targetEl) return;
                    const originalText = btnEl.innerText;
                    btnEl.innerText = "QUERYING...";
                    btnEl.disabled = true;
                    try {
                        const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lon}`);
                        const data = await res.json();
                        if (data.display_name) {
                            targetEl.innerText = data.display_name;
                            btnEl.remove();
                        } else {
                            btnEl.innerText = "NOT FOUND";
                            setTimeout(() => { btnEl.innerText = originalText; btnEl.disabled = false; }, 2000);
                        }
                    } catch (e) {
                        btnEl.innerText = "FAILED";
                        setTimeout(() => { btnEl.innerText = originalText; btnEl.disabled = false; }, 2000);
                    }
                }

                // Optimized Polling
                let prevJSON = null;
                let isPolling = true;

                async function pollIncidents() {
                    if (!isPolling) return;
                    try {
                        const res = await fetch('/api/incidents?t=' + Date.now());
                        if (!res.ok) return;
                        const data = await res.json();
                        const currentJSON = JSON.stringify(data);

                        if (prevJSON !== null && currentJSON !== prevJSON) {
                            document.getElementById('sync-timer').innerText = `Last update: ${new Date().toLocaleTimeString()}`;
                            location.reload(); // Simple reload. A more complex approach would update DOM elements directly.
                        }
                        prevJSON = currentJSON;
                    } catch (e) {
                        console.error("Polling error", e);
                    }
                }

                setInterval(pollIncidents, 10000);

                // Initial set to avoid false positive reloads on first poll
                setTimeout(() => {
                    fetch('/api/incidents?t=' + Date.now())
                        .then(r => r.json())
                        .then(d => { prevJSON = JSON.stringify(d); })
                        .catch(e => { });
                }, 1000);

            </script>
</body>

</html>