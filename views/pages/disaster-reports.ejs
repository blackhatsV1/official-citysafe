<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="app">
    <%- include('../partials/page-start'); %>
        <header class="app-header fixed-top">
            <%- include('../partials/admin-navbar', { currentPage: 'disaster-reports' }); %>
                <%- include('../partials/admin-sidebar', { currentPage: 'disaster-reports' }); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <div class="row g-3 mb-4 align-items-center justify-content-between">
                        <div class="col-auto">
                            <h1 class="app-page-title mb-0">Incident Management Ledger</h1>
                        </div>
                        <div class="col-auto">
                            <div class="page-utilities">
                                <div class="row g-2 justify-content-start justify-content-md-end align-items-center">
                                    <div class="col-auto">
                                        <span class="badge bg-success px-2 py-1 rounded-pill small">REAL-TIME
                                            SYNC</span>
                                    </div>
                                    <div class="col-auto">
                                        <small class="text-muted fw-bold" id="sync-timer">Last update: just now</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="app-card app-card-orders-table shadow-sm mb-5">
                        <div class="app-card-body">
                            <div class="table-responsive">
                                <table class="table app-table-hover mb-0 text-left">
                                    <thead>
                                        <tr>
                                            <th class="cell">Mission Control</th>
                                            <th class="cell">Personnel / Sender</th>
                                            <th class="cell">Classification</th>
                                            <th class="cell">Sector / Location</th>
                                            <th class="cell">Comms Feed</th>
                                            <th class="cell">Resolution</th>
                                            <th class="cell">Timestamp</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% reports.forEach(report=> { %>
                                            <tr>
                                                <td class="cell">
                                                    <% if (report.status==='responding' ) { %>
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="badge bg-warning">IN PROGRESS</span>
                                                            <button class="btn btn-sm btn-outline-danger border-0"
                                                                onclick="cancelReportAdmin('<%= report.id %>')">ABORT</button>
                                                        </div>
                                                        <% } else if (report.status==='resolved' ) { %>
                                                            <span class="badge bg-success">RESOLVED</span>
                                                            <% } else if (report.status.includes('cancelled')) { %>
                                                                <span class="badge bg-danger">CANCELLED</span>
                                                                <% } else { %>
                                                                    <div class="d-flex gap-2">
                                                                        <button class="btn-sm app-btn-primary"
                                                                            data-id="<%= report.id %>"
                                                                            data-location="<%= report.location %>"
                                                                            data-lat="<%= report.latitude %>"
                                                                            data-lon="<%= report.longitude %>"
                                                                            data-type="<%= report.disaster_type %>"
                                                                            data-date="<%= new Date(report.reported_at).toLocaleString() %>"
                                                                            onclick="initiateDeploy(this)">DEPLOY</button>
                                                                        <button
                                                                            class="btn-sm btn-outline-danger border-0"
                                                                            onclick="cancelReportAdmin('<%= report.id %>')">CANCEL</button>
                                                                    </div>
                                                                    <% } %>
                                                </td>
                                                <td class="cell">
                                                    <div class="d-flex flex-column">
                                                        <span class="fw-bold">
                                                            <%= report.sender %>
                                                        </span>
                                                        <% if (report.responder_name) { %>
                                                            <small class="text-primary"><i
                                                                    class="fa fa-shield-halved me-1"></i>
                                                                <%= report.responder_name %>
                                                            </small>
                                                            <% } else { %>
                                                                <small class="text-muted"
                                                                    style="font-size: 0.7rem;">Unassigned</small>
                                                                <% } %>
                                                    </div>
                                                </td>
                                                <td class="cell">
                                                    <% let badgeClass='bg-secondary' ; if (report.disaster_type==='Fire'
                                                        ) badgeClass='bg-danger' ; else if
                                                        (report.disaster_type==='Flood' ) badgeClass='bg-info' ; else if
                                                        (report.disaster_type==='Earthquake' )
                                                        badgeClass='bg-warning text-dark' ; else if
                                                        (report.disaster_type==='Landslide' ) badgeClass='bg-dark' ; %>
                                                        <span class="badge <%= badgeClass %>">
                                                            <%= report.disaster_type %>
                                                        </span>
                                                </td>
                                                <td class="cell">
                                                    <div class="d-flex flex-column">
                                                        <span class="small" id="loc-display-<%= report.id %>">
                                                            <%= (report.latitude && report.longitude) ?
                                                                `${report.latitude.toFixed(4)},
                                                                ${report.longitude.toFixed(4)}` : (report.location
                                                                || "N/A" ) %>
                                                        </span>
                                                        <% if (report.latitude && report.longitude) { %>
                                                            <a href="#" class="text-primary fw-bold"
                                                                style="font-size: 0.65rem;"
                                                                onclick="fetchFormattedAddress(this, <%= report.latitude %>, <%= report.longitude %>, 'loc-display-<%= report.id %>'); return false;">SHOW
                                                                ADDRESS</a>
                                                            <% } %>
                                                    </div>
                                                </td>
                                                <td class="cell">
                                                    <div class="d-flex flex-column gap-1" style="max-width: 180px;">
                                                        <small class="text-truncate italic text-muted"
                                                            style="font-size: 0.7rem;">"<%= report.user_message
                                                                || 'No intel' %>"</small>
                                                        <% if(report.responder_name) { %>
                                                            <small class="text-truncate italic text-primary"
                                                                style="font-size: 0.7rem;">"<%= report.responder_message
                                                                    || 'Awaiting update' %>"</small>
                                                            <% } %>
                                                    </div>
                                                </td>
                                                <td class="cell">
                                                    <% if (report.status==='resolved' ) { %>
                                                        <div class="d-flex gap-1 mb-1">
                                                            <% if (report.user_confirmed_at) { %><i
                                                                    class="fa fa-user-check text-success small"
                                                                    title="User Confirmed"></i>
                                                                <% } %>
                                                                    <% if (report.responder_confirmed_at) { %><i
                                                                            class="fa fa-shield-check text-primary small"
                                                                            title="Responder Confirmed"></i>
                                                                        <% } %>
                                                        </div>
                                                        <small class="text-muted">
                                                            <%= report.resolution_remarks || 'System Resolved' %>
                                                        </small>
                                                        <% } else { %>
                                                            <span class="text-muted small italic">Awaiting</span>
                                                            <% } %>
                                                </td>
                                                <td class="cell">
                                                    <span class="fw-bold">
                                                        <%= new Date(report.reported_at).toLocaleTimeString([],
                                                            {hour: '2-digit' , minute:'2-digit'}) %>
                                                    </span><br>
                                                    <small class="text-muted">
                                                        <%= new Date(report.reported_at).toLocaleDateString() %>
                                                    </small>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="app-footer">
                <%- include('../partials/footer'); %>
            </footer>
        </div>
        </div>

        <!-- Scripts -->
        <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
        <script src="/js/script.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            async function initiateDeploy(btn) {
                const reportId = btn.getAttribute('data-id');
                const storedLat = btn.getAttribute('data-lat');
                const storedLon = btn.getAttribute('data-lon');
                const reportType = btn.getAttribute('data-type') || 'General';
                const reportDate = btn.getAttribute('data-date') || 'N/A';
                const locationStr = btn.getAttribute('data-location') || `Lat: ${storedLat}, Lon: ${storedLon}`;

                let incLat = parseFloat(storedLat);
                let incLon = parseFloat(storedLon);

                if (!incLat || !incLon) {
                    Swal.fire('Error', 'Incomplete geospatial metadata.', 'error');
                    return;
                }

                window.openSharedDeployModal({ reportId, lat: incLat, lng: incLon, type: reportType, dateStr: reportDate, locationStr });
            }

            function cancelReportAdmin(id) {
                Swal.fire({
                    title: 'ABORT MISSION?',
                    text: "Are you sure you want to cancel this emergency protocol?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: 'var(--danger-slate)',
                    confirmButtonText: 'CONFIRM ABORT',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch('/api/admin/cancel_report', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: id })
                        })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    Swal.fire('Operation Aborted', '', 'success').then(() => location.reload());
                                }
                            });
                    }
                });
            }

            async function fetchFormattedAddress(linkEl, lat, lon, targetId) {
                const targetEl = document.getElementById(targetId);
                if (!targetEl) return;
                linkEl.innerText = "QUERYING...";
                try {
                    const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lon}`);
                    const data = await res.json();
                    if (data.display_name) {
                        targetEl.innerText = data.display_name;
                        linkEl.remove();
                    }
                } catch (e) { linkEl.innerText = "RETRY"; }
            }

            // Optimized Polling
            let prevJSON = '';
            setInterval(() => {
                fetch('/api/incidents?t=' + Date.now())
                    .then(res => res.json())
                    .then(data => {
                        const currentJSON = JSON.stringify(data);
                        if (currentJSON === prevJSON) return;
                        prevJSON = currentJSON;
                        document.getElementById('sync-timer').innerText = `Last update: ${new Date().toLocaleTimeString()}`;
                        // Note: Full table redraw on update for simplicity, can be optimized with better DOM diffing
                        location.reload();
                    });
            }, 10000);
        </script>
</body>

</html>