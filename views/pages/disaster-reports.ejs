<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body
    class="bg-gradient-glass-light dark:bg-gradient-glass-dark text-gray-800 dark:text-gray-100 min-h-screen flex flex-col">
    <%- include('../partials/page-start'); %>

        <header class="sticky top-0 z-50">
            <%- include('../partials/admin-navbar', { currentPage: 'disaster-reports' }); %>
        </header>

        <div class="flex flex-1 overflow-hidden relative">
            <aside class="z-40">
                <%- include('../partials/admin-sidebar', { currentPage: 'disaster-reports' }); %>
            </aside>

            <main class="flex-1 px-4 py-6 sm:px-6 lg:px-8 overflow-y-auto w-full relative">

                <div class="max-w-7xl mx-auto space-y-6">

                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                        <h1 class="text-2xl font-black text-gray-900 dark:text-gray-100 tracking-tight uppercase">
                            Incident Management Ledger</h1>
                        <div class="glass-panel px-4 py-2 flex items-center gap-3">
                            <span
                                class="px-2 py-0.5 bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400 rounded text-[10px] font-black uppercase tracking-widest flex items-center gap-1">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                                REAL-TIME SYNC
                            </span>
                            <div class="h-4 w-px bg-gray-200 dark:bg-gray-700"></div>
                            <span class="text-xs font-bold text-gray-400 dark:text-gray-500 tracking-wider"
                                id="sync-timer">Last update: just now</span>
                        </div>
                    </div>

                    <div class="glass-panel overflow-hidden">
                        <div
                            class="px-6 py-4 bg-white/40 dark:bg-gray-900/40 border-b border-gray-100 dark:border-gray-800">
                            <h2 class="text-sm font-bold uppercase tracking-wider text-gray-700 dark:text-gray-300">Live
                                Operations Feed</h2>
                        </div>

                        <div class="overflow-x-auto w-full">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr
                                        class="bg-gray-50/50 dark:bg-gray-800/50 text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 font-bold border-b border-gray-100 dark:border-gray-800">
                                        <th class="px-6 py-4">Mission Control</th>
                                        <th class="px-6 py-4">Personnel / Sender</th>
                                        <th class="px-6 py-4">Classification</th>
                                        <th class="px-6 py-4">Sector / Location</th>
                                        <th class="px-6 py-4">Comms Feed</th>
                                        <th class="px-6 py-4">Resolution</th>
                                        <th class="px-6 py-4">Timestamp</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100 dark:divide-gray-800/60 text-sm">
                                    <% reports.forEach(report=> { %>
                                        <tr
                                            class="hover:bg-gray-50/50 dark:hover:bg-gray-800/30 transition-colors group">
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <% if (report.status==='responding' ) { %>
                                                    <div class="flex items-center gap-2">
                                                        <span
                                                            class="px-2.5 py-1 bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-400 rounded text-xs font-bold uppercase tracking-wider animate-pulse">
                                                            IN PROGRESS
                                                        </span>
                                                        <button onclick="cancelReportAdmin('<%= report.id %>')"
                                                            class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 transition-colors p-1"
                                                            title="Abort Mission">
                                                            <i class="fa fa-times-circle"></i>
                                                        </button>
                                                    </div>
                                                    <% } else if (report.status==='resolved' ) { %>
                                                        <span
                                                            class="px-2.5 py-1 bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400 rounded text-xs font-bold uppercase tracking-wider">
                                                            RESOLVED
                                                        </span>
                                                        <% } else if (report.status.includes('cancelled')) { %>
                                                            <span
                                                                class="px-2.5 py-1 bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400 rounded text-xs font-bold uppercase tracking-wider">
                                                                CANCELLED
                                                            </span>
                                                            <% } else { %>
                                                                <div class="flex items-center gap-2">
                                                                    <button onclick="initiateDeploy(this)"
                                                                        data-id="<%= report.id %>"
                                                                        data-location="<%= report.location %>"
                                                                        data-lat="<%= report.latitude %>"
                                                                        data-lon="<%= report.longitude %>"
                                                                        data-type="<%= report.disaster_type %>"
                                                                        data-date="<%= new Date(report.reported_at).toLocaleString() %>"
                                                                        class="px-3 py-1 bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-400 hover:bg-indigo-200 dark:hover:bg-indigo-900/60 rounded text-xs font-black uppercase tracking-widest transition-colors shadow-sm">
                                                                        DEPLOY
                                                                    </button>
                                                                    <button
                                                                        onclick="cancelReportAdmin('<%= report.id %>')"
                                                                        class="text-gray-400 hover:text-red-500 dark:text-gray-500 dark:hover:text-red-400 transition-colors text-xs font-bold uppercase tracking-wider">
                                                                        CANCEL
                                                                    </button>
                                                                </div>
                                                                <% } %>
                                            </td>

                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <div class="flex flex-col">
                                                    <span class="font-bold text-gray-900 dark:text-gray-100">
                                                        <%= report.sender %>
                                                    </span>
                                                    <% if (report.responder_name) { %>
                                                        <span
                                                            class="text-xs text-indigo-600 dark:text-indigo-400 font-medium mt-0.5 flex items-center gap-1">
                                                            <i class="fa fa-shield-alt text-[10px]"></i>
                                                            <%= report.responder_name %>
                                                        </span>
                                                        <% } else { %>
                                                            <span
                                                                class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wider font-bold mt-0.5">Unassigned</span>
                                                            <% } %>
                                                </div>
                                            </td>

                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <% let
                                                    badgeColors='bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300'
                                                    ; let icon='fa-exclamation-circle' ; if
                                                    (report.disaster_type==='Fire' ) {
                                                    badgeColors='bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400'
                                                    ; icon='fa-fire' ; } else if (report.disaster_type==='Flood' ) {
                                                    badgeColors='bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400'
                                                    ; icon='fa-water' ; } else if (report.disaster_type==='Earthquake' )
                                                    {
                                                    badgeColors='bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-400'
                                                    ; icon='fa-house-crack' ; } else if
                                                    (report.disaster_type==='Landslide' ) {
                                                    badgeColors='bg-stone-100 text-stone-700 dark:bg-stone-900/40 dark:text-stone-400'
                                                    ; icon='fa-mountain' ; } %>
                                                    <span
                                                        class="px-2.5 py-1 rounded text-xs font-bold uppercase tracking-wider inline-flex items-center gap-1.5 <%= badgeColors %>">
                                                        <i class="fa <%= icon %> text-[10px]"></i>
                                                        <%= report.disaster_type %>
                                                    </span>
                                            </td>

                                            <td class="px-6 py-4">
                                                <div class="flex flex-col">
                                                    <span
                                                        class="text-xs font-mono text-gray-600 dark:text-gray-400 line-clamp-2"
                                                        id="loc-display-<%= report.id %>">
                                                        <%= (report.latitude && report.longitude) ?
                                                            `${report.latitude.toFixed(4)},
                                                            ${report.longitude.toFixed(4)}` : (report.location || "N/A"
                                                            ) %>
                                                    </span>
                                                    <% if (report.latitude && report.longitude) { %>
                                                        <button
                                                            onclick="fetchFormattedAddress(this, <%= report.latitude %>, <%= report.longitude %>, 'loc-display-<%= report.id %>'); return false;"
                                                            class="text-[10px] text-indigo-500 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300 font-bold uppercase tracking-widest mt-1 text-left inline-block w-max transition-colors">
                                                            Show Address
                                                        </button>
                                                        <% } %>
                                                </div>
                                            </td>

                                            <td class="px-6 py-4">
                                                <div class="flex flex-col gap-1.5 w-48">
                                                    <div
                                                        class="text-xs text-gray-600 dark:text-gray-400 italic bg-gray-50 dark:bg-gray-800/50 p-1.5 rounded line-clamp-2 border-l-2 border-gray-300 dark:border-gray-600">
                                                        "<%= report.user_message || 'No civilian intel' %>"
                                                    </div>
                                                    <% if(report.responder_name) { %>
                                                        <div
                                                            class="text-xs text-indigo-700 dark:text-indigo-300 italic bg-indigo-50/50 dark:bg-indigo-900/20 p-1.5 rounded line-clamp-2 border-l-2 border-indigo-300 dark:border-indigo-600">
                                                            "<%= report.responder_message || 'Awaiting update' %>"
                                                        </div>
                                                        <% } %>
                                                </div>
                                            </td>

                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <% if (report.status==='resolved' ) { %>
                                                    <div class="flex gap-2 mb-1.5">
                                                        <% if (report.user_confirmed_at) { %>
                                                            <div class="w-6 h-6 rounded bg-green-50 dark:bg-green-900/20 flex items-center justify-center border border-green-100 dark:border-green-800/50 tooltip-trigger"
                                                                title="User Confirmed">
                                                                <i class="fa fa-user-check text-green-500 text-xs"></i>
                                                            </div>
                                                            <% } %>
                                                                <% if (report.responder_confirmed_at) { %>
                                                                    <div class="w-6 h-6 rounded bg-indigo-50 dark:bg-indigo-900/20 flex items-center justify-center border border-indigo-100 dark:border-indigo-800/50 tooltip-trigger"
                                                                        title="Responder Confirmed">
                                                                        <i
                                                                            class="fa fa-shield-check text-indigo-500 text-xs"></i>
                                                                    </div>
                                                                    <% } %>
                                                    </div>
                                                    <span
                                                        class="text-[10px] text-gray-500 font-medium uppercase tracking-wider block">
                                                        <%= report.resolution_remarks || 'System Resolved' %>
                                                    </span>
                                                    <% } else { %>
                                                        <span
                                                            class="text-xs text-gray-400 dark:text-gray-500 italic font-medium">Awaiting
                                                            Resolution</span>
                                                        <% } %>
                                            </td>

                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <div class="flex flex-col">
                                                    <span class="font-bold text-gray-900 dark:text-gray-100">
                                                        <%= new Date(report.reported_at).toLocaleTimeString([],
                                                            {hour: '2-digit' , minute:'2-digit'}) %>
                                                    </span>
                                                    <span class="text-xs font-medium text-gray-500 dark:text-gray-400">
                                                        <%= new Date(report.reported_at).toLocaleDateString() %>
                                                    </span>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>

                            <% if(reports.length===0) { %>
                                <div class="flex flex-col items-center justify-center py-16 text-center">
                                    <div
                                        class="w-16 h-16 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center mb-4">
                                        <i class="fa fa-clipboard-list text-3xl text-gray-400"></i>
                                    </div>
                                    <h3 class="text-lg font-bold text-gray-700 dark:text-gray-300">No Active Incidents
                                    </h3>
                                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">There are no reports in the
                                        ledger currently.</p>
                                </div>
                                <% } %>
                        </div>
                    </div>
                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>

            <!-- Scripts -->
            <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script src="/js/script.js"></script>

            <script>
                async function initiateDeploy(btn) {
                    const reportId = btn.getAttribute('data-id');
                    const storedLat = btn.getAttribute('data-lat');
                    const storedLon = btn.getAttribute('data-lon');
                    const reportType = btn.getAttribute('data-type') || 'General';
                    const reportDate = btn.getAttribute('data-date') || 'N/A';
                    const locationStr = btn.getAttribute('data-location') || `Lat: ${storedLat}, Lon: ${storedLon}`;

                    let incLat = parseFloat(storedLat);
                    let incLon = parseFloat(storedLon);

                    if (!incLat || !incLon) {
                        Swal.fire({
                            title: 'Geospatial Error',
                            text: 'Incomplete coordinate metadata for deployment.',
                            icon: 'error',
                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                        });
                        return;
                    }

                    if (typeof window.openSharedDeployModal === 'function') {
                        window.openSharedDeployModal({ reportId, lat: incLat, lng: incLon, type: reportType, dateStr: reportDate, locationStr });
                    }
                }

                function cancelReportAdmin(id) {
                    Swal.fire({
                        title: 'ABORT MISSION?',
                        text: "Are you sure you want to cancel this emergency protocol?",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#6b7280',
                        confirmButtonText: 'CONFIRM ABORT',
                        reverseButtons: true,
                        background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                        color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            fetch('/api/admin/cancel_report', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ id: id })
                            })
                                .then(res => res.json())
                                .then(data => {
                                    if (data.success) {
                                        Swal.fire({
                                            title: 'Aborted',
                                            text: 'Operation has been successfully cancelled.',
                                            icon: 'success',
                                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                                        }).then(() => location.reload());
                                    }
                                });
                        }
                    });
                }

                async function fetchFormattedAddress(btnEl, lat, lon, targetId) {
                    const targetEl = document.getElementById(targetId);
                    if (!targetEl) return;
                    const originalText = btnEl.innerText;
                    btnEl.innerText = "QUERYING...";
                    btnEl.disabled = true;
                    try {
                        const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lon}`);
                        const data = await res.json();
                        if (data.display_name) {
                            targetEl.innerText = data.display_name;
                            btnEl.remove();
                        } else {
                            btnEl.innerText = "NOT FOUND";
                            setTimeout(() => { btnEl.innerText = originalText; btnEl.disabled = false; }, 2000);
                        }
                    } catch (e) {
                        btnEl.innerText = "FAILED";
                        setTimeout(() => { btnEl.innerText = originalText; btnEl.disabled = false; }, 2000);
                    }
                }

                // Optimized Polling
                let prevJSON = null;
                let isPolling = true;

                async function pollIncidents() {
                    if (!isPolling) return;
                    try {
                        const res = await fetch('/api/incidents?t=' + Date.now());
                        if (!res.ok) return;
                        const data = await res.json();
                        const currentJSON = JSON.stringify(data);

                        if (prevJSON !== null && currentJSON !== prevJSON) {
                            document.getElementById('sync-timer').innerText = `Last update: ${new Date().toLocaleTimeString()}`;
                            location.reload(); // Simple reload. A more complex approach would update DOM elements directly.
                        }
                        prevJSON = currentJSON;
                    } catch (e) {
                        console.error("Polling error", e);
                    }
                }

                setInterval(pollIncidents, 10000);

                // Initial set to avoid false positive reloads on first poll
                setTimeout(() => {
                    fetch('/api/incidents?t=' + Date.now())
                        .then(r => r.json())
                        .then(d => { prevJSON = JSON.stringify(d); })
                        .catch(e => { });
                }, 1000);

            </script>
</body>

</html>