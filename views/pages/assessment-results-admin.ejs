<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/admin-navbar', { currentPage: 'assessments' }); %>
        </header>

        <div>
            <aside>
                <%- include('../partials/admin-sidebar', { currentPage: 'assessments' }); %>
            </aside>

            <main>
                <div>

                    <h1>ASSESSMENT RECORDS
                    </h1>

                    <div>
                        <div>
                            <h2>Risk
                                Audit Database</h2>
                        </div>

                        <div>
                            <% if (assessments.length> 0) { %>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Citizen Name</th>
                                            <th>Date Assessed</th>
                                            <th>Risk Score</th>
                                            <th>Risk Level</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% for (let i=0; i < assessments.length; i++) { %>
                                            <tr>
                                                <td>
                                                    <%= assessments[i].firstname %>
                                                        <%= assessments[i].lastname %>
                                                </td>
                                                <td>
                                                    <%= assessments[i].assessed_at %>
                                                </td>
                                                <td>
                                                    <%= assessments[i].risk_score %>
                                                </td>
                                                <td>
                                                    <% if(assessments[i].risk_level==='High' ) { %>
                                                        <span>
                                                            <%= assessments[i].risk_level %>
                                                        </span>
                                                        <% } else if(assessments[i].risk_level==='Medium' ) { %>
                                                            <span>
                                                                <%= assessments[i].risk_level %>
                                                            </span>
                                                            <% } else { %>
                                                                <span>
                                                                    <%= assessments[i].risk_level %>
                                                                </span>
                                                                <% } %>
                                                </td>
                                                <td>
                                                    <form action="/delete-result/<%= assessments[i].id %>" method="POST"
                                                        onsubmit="return confirm('WARNING: Are you sure you want to delete this assessment record?');">
                                                        <button type="submit">
                                                            <i></i> <span>Delete</span>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% } %>
                                    </tbody>
                                </table>
                                <% } else { %>
                                    <div>
                                        <div>
                                            <i></i>
                                        </div>
                                        <h3>No Records Found
                                        </h3>
                                        <p>There are no risk
                                            assessment records in the current operational sector.</p>
                                    </div>
                                    <% } %>
                        </div>
                    </div>

                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>
            <script src="/js/script.js"></script>
</body>

</html>