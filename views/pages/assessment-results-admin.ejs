<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>
<!-- ========================================================================= -->

<body class="app">
    <%- include('../partials/page-start'); %>
        <header class="app-header fixed-top">
            <%- include('../partials/admin-navbar'); %>
                <%- include('../partials/admin-sidebar'); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <h1 class="app-page-title">Assessment Records</h1>

                    <div class="app-card app-card-orders-table shadow-sm mb-5">
                        <div class="app-card-body">
                            <% if (assessments.length> 0) { %>
                                <div class="table-responsive">
                                    <table class="table app-table-hover mb-0 text-left">
                                        <thead>
                                            <tr>
                                                <th class="cell">Name</th>
                                                <th class="cell">Date Assessed</th>
                                                <th class="cell">Risk Score</th>
                                                <th class="cell">Risk Level</th>
                                                <th class="cell">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% for (let i=0; i < assessments.length; i++) { %>
                                                <tr>
                                                    <td class="cell">
                                                        <%= assessments[i].firstname %>
                                                            <%= assessments[i].lastname %>
                                                    </td>
                                                    <td class="cell">
                                                        <%= assessments[i].assessed_at %>
                                                    </td>
                                                    <td class="cell">
                                                        <%= assessments[i].risk_score %>
                                                    </td>
                                                    <td class="cell">
                                                        <% if(assessments[i].risk_level==='High' ) { %>
                                                            <span class="badge bg-danger">
                                                                <%= assessments[i].risk_level %>
                                                            </span>
                                                            <% } else if(assessments[i].risk_level==='Medium' ) { %>
                                                                <span class="badge bg-warning text-dark">
                                                                    <%= assessments[i].risk_level %>
                                                                </span>
                                                                <% } else { %>
                                                                    <span class="badge bg-success">
                                                                        <%= assessments[i].risk_level %>
                                                                    </span>
                                                                    <% } %>
                                                    </td>
                                                    <td class="cell">
                                                        <form action="/delete-result/<%= assessments[i].id %>"
                                                            method="POST" class="d-inline">
                                                            <button type="submit"
                                                                onclick="return confirm('Delete this Assessment?')"
                                                                class="btn-sm btn-outline-danger border-0">Delete</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% } %>
                                        </tbody>
                                    </table>
                                </div>
                                <% } else { %>
                                    <div class="text-center p-5">
                                        <p class="text-muted mb-0">No risk assessment records found in the sector.</p>
                                    </div>
                                    <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="app-footer">
                <%- include('../partials/footer'); %>
            </footer>
        </div>

        <script src="/js/script.js"></script>
</body>