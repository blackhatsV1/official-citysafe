<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <div>
        <!-- Auth Form Column -->
        <div>
            <div>
                <!-- Branding -->
                <div>
                    <a href="/visitor">
                        <div>
                            <i></i>
                        </div>
                        <span>CitySafe</span>
                    </a>
                </div>

                <!-- Intro -->
                <div>
                    <h2>Welcome Back</h2>
                    <p>Enter your secure credentials to access the
                        command center operations.</p>
                </div>

                <!-- Form -->
                <form method="POST" action="/login">
                    <div>
                        <label for="signin-email">Identifier</label>
                        <div>
                            <i></i>
                            <input id="signin-email" name="identifier" type="text"
                                placeholder="Email or Username" required>
                        </div>
                    </div>

                    <div>
                        <label for="signin-password">Passcode</label>
                        <div>
                            <i></i>
                            <input id="signin-password" name="password" type="password"
                                placeholder="••••••••" required>
                            <button type="button" id="toggleLoginPass">
                                <i></i>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label>
                            <input type="checkbox">
                            <span>Remember me</span>
                        </label>
                        <a href="#">Forgot
                            passcode?</a>
                    </div>

                    <button type="submit">
                        SIGN IN TO TERMINAL <i></i>
                    </button>
                </form>

                <!-- Footer text -->
                <div>
                    <p>
                        Awaiting access credentials? <a href="/register">Request
                            Authorization</a>
                    </p>
                </div>

                <div>
                    <p>
                        Designed with <i></i> by tracking project CitySafe
                    </p>
                </div>
            </div>
        </div>

        <!-- Visual Hero Column -->
        <div>
            <!-- Huge abstract graphic background -->
            <div>
                <div></div>
                <div></div>

                <!-- Grid pattern overlay -->
                <div>
                </div>
            </div>

            <!-- Content -->
            <div>
                <div>
                    <h2>
                        Redefining<br><span>Urban Safety</span></h2>
                    <p>
                        CitySafe provides real-time atmospheric command, operational deployment mapping, and emergency
                        response coordination for modern urban environments.
                    </p>
                    <div>
                        <span>Reliable</span>
                        <span>Resilient</span>
                        <span>Responsive</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script>
        const toggleBtn = document.getElementById("toggleLoginPass");
        const passInput = document.getElementById("signin-password");
        const icon = toggleBtn?.querySelector("i");

        if (toggleBtn && passInput && icon) {
            toggleBtn.addEventListener("click", function () {
                if (passInput.type === "password") {
                    passInput.type = "text";
                    icon.classList.remove("fa-eye-slash");
                    icon.classList.add("fa-eye");
                    icon.classList.add("text-indigo-500", "dark:text-indigo-400");
                } else {
                    passInput.type = "password";
                    icon.classList.add("fa-eye-slash");
                    icon.classList.remove("fa-eye");
                    icon.classList.remove("text-indigo-500", "dark:text-indigo-400");
                }
            });
        }
    </script>
</body>

</html>