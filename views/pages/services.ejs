<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="app">
    <%- include('../partials/page-start'); %>
        <header class="app-header fixed-top">
            <%- include('../partials/visitor-navbar'); %>
                <%- include('../partials/visitor-sidebar'); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <h1 class="app-page-title">Our Services</h1>

                    <div class="row g-4 mb-4">
                        <div class="col-12 col-lg-8">
                            <div class="app-card app-card-settings shadow-sm p-4">
                                <div class="app-card-body">
                                    <div class="list-group list-group-flush">
                                        <div class="list-group-item bg-transparent px-0 py-3 border-light">
                                            <h5 class="text-primary mb-1">Real-time Information</h5>
                                            <p class="text-muted mb-0">Disaster-related updates through specific weather
                                                tracking and real-time status.</p>
                                        </div>
                                        <div class="list-group-item bg-transparent px-0 py-3 border-light">
                                            <h5 class="text-primary mb-1">Localized Notifications</h5>
                                            <p class="text-muted mb-0">Relevant alerts and updates based on the user's
                                                active report location.</p>
                                        </div>
                                        <div class="list-group-item bg-transparent px-0 py-3 border-light">
                                            <h5 class="text-primary mb-1">Emergency Alert</h5>
                                            <p class="text-muted mb-0">Quickly send SOS requests with location to nearby
                                                responders.</p>
                                        </div>
                                        <div class="list-group-item bg-transparent px-0 py-3 border-light">
                                            <h5 class="text-primary mb-1">Relief Coordination</h5>
                                            <p class="text-muted mb-0">Connects responders with active incidents to
                                                efficiently manage relief.</p>
                                        </div>
                                        <div class="list-group-item bg-transparent px-0 py-3 border-light">
                                            <h5 class="text-primary mb-1">Mapping Service</h5>
                                            <p class="text-muted mb-0">Visualizes incidents, nearby stations, and
                                                responders for situational awareness.</p>
                                        </div>
                                        <div class="list-group-item bg-transparent px-0 py-3 border-0">
                                            <h5 class="text-primary mb-1">Survival Guidelines</h5>
                                            <p class="text-muted mb-0">Essential survival information and guides for
                                                various disaster scenarios.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="app-card app-card-settings shadow-sm p-4">
                                <div class="app-card-header p-0 border-0 mb-3">
                                    <h4 class="app-card-title">The Development Team</h4>
                                </div>
                                <div class="app-card-body">
                                    <div class="mb-4 text-center">
                                        <div class="p-3 bg-light rounded border mb-3">
                                            <h6 class="mb-1">Jayrold Tabalina</h6>
                                            <small class="text-primary">Programmer</small>
                                        </div>
                                        <div class="p-3 bg-light rounded border mb-3">
                                            <h6 class="mb-1">Yasmine M. Talaman</h6>
                                            <small class="text-primary">Documenter</small>
                                        </div>
                                        <div class="p-3 bg-light rounded border">
                                            <h6 class="mb-1">Mark Vincent Jabao</h6>
                                            <small class="text-primary">UI/UX Designer</small>
                                        </div>
                                    </div>
                                    <div class="text-center">
                                        <small class="text-muted">PHINMA University of Iloilo</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="app-footer">
                <%- include('../partials/footer'); %>
            </footer>
        </div>

        <script src="/js/script.js"></script>
</body>

</html>