<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>

        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

        <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.min.js"></script>

</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/user-navbar', { currentPage: 'sos-otw' }); %>
        </header>

        <div class="cs-layout-container">
            <aside>
                <%- include('../partials/user-sidebar', { currentPage: 'sos-otw' }); %>
            </aside>

            <main class="cs-main-content">
                <div class="cs-container">

                    <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 3rem;">
                        <div class="cs-badge"
                            style="width: 64px; height: 64px; font-size: 1.5rem; background: var(--warning-glow); color: var(--warning); border: 2px solid var(--warning);">
                            <i class="fa-solid fa-truck-fast"></i>
                        </div>
                        <h1 class="cs-section-header" style="margin: 0;">
                            EMERGENCY <span
                                style="background: linear-gradient(135deg, var(--warning) 0%, var(--primary) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">RESOURCES</span>
                        </h1>
                    </div>

                    <div class="cs-grid cs-grid-2">
                        <!-- Left Column (Map) -->
                        <div class="cs-card"
                            style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem;">
                            <div
                                style="display: flex; align-items: center; gap: 1rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem;">
                                <div class="cs-badge" style="background: var(--primary-glow); color: var(--primary);"><i
                                        class="fa-solid fa-shield-halved"></i></div>
                                <h4 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                    SAFE ZONES & EXTRACTION</h4>
                            </div>

                            <div
                                style="background: rgba(0,0,0,0.2); border: 1px solid var(--border-glass); border-radius: 1rem; padding: 1.25rem; display: flex; align-items: flex-start; gap: 1rem;">
                                <div class="cs-badge" style="width: 32px; height: 32px; font-size: 0.9rem;"><i
                                        class="fa-solid fa-location-dot"></i></div>
                                <div>
                                    <p id="address"
                                        style="font-size: 0.9rem; color: var(--text-bright); margin-bottom: 0.25rem; font-weight: 600;">
                                        Acquiring satellite lock...</p>
                                    <p id="coords"
                                        style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--primary); margin: 0;">
                                    </p>
                                </div>
                            </div>

                            <div class="cs-map-container" id="map" style="height: 400px; border-radius: 1rem;"></div>
                        </div>

                        <!-- Right Column (Hotlines) -->
                        <div class="cs-card" style="padding: 2.5rem;">
                            <div
                                style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.5rem;">
                                <div class="cs-badge" style="background: var(--danger-glow); color: var(--danger);"><i
                                        class="fa-solid fa-phone-volume"></i></div>
                                <h4 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                    CRITICAL HOTLINES</h4>
                            </div>

                            <p
                                style="font-size: 0.95rem; color: var(--text-dim); line-height: 1.6; margin-bottom: 2rem;">
                                If you require immediate tactical assistance or extraction, utilize these direct action
                                lines for priority response.
                            </p>

                            <div style="display: flex; flex-direction: column; gap: 1rem;">
                                <% [ { label: 'National Emergency' , num: '911' , sub: 'Unified Command' }, {
                                    label: 'PNP (Police)' , num: '117' , sub: '(02) 8722-0650' }, { label: 'BFP (Fire)'
                                    , num: '160' , sub: '(02) 8426-0219' }, { label: 'Red Cross Medivac' , num: '143' ,
                                    sub: '(02) 8790-2300' }, { label: 'MMDA Dispatch' , num: '136' ,
                                    sub: 'Metro Operations' }, { label: 'NDRRMC Hub' , num: '911-5061' ,
                                    sub: 'Disaster Risk Council' } ].forEach(hotline=> { %>
                                    <div style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass); border-radius: 1rem; padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; transition: all 0.3s ease;"
                                        onmouseover="this.style.background='rgba(255,255,255,0.06)'; this.style.borderColor='var(--primary-glow)'"
                                        onmouseout="this.style.background='rgba(255,255,255,0.03)'; this.style.borderColor='var(--border-glass)'">
                                        <div>
                                            <div
                                                style="font-size: 0.9rem; font-weight: 700; color: var(--text-bright); margin-bottom: 0.25rem;">
                                                <%= hotline.label %>
                                            </div>
                                            <div style="font-size: 0.75rem; color: var(--text-dim);">
                                                <%= hotline.sub %>
                                            </div>
                                        </div>
                                        <div
                                            style="font-family: 'JetBrains Mono', monospace; font-size: 1.25rem; font-weight: 800; color: var(--primary); text-shadow: 0 0 10px var(--primary-glow);">
                                            <%= hotline.num %>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>
                        </div>
                    </div>

                </div>
            </main>
        </div>

        <script>
            const redIcon = new L.Icon({
                iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-red.png',
                shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.3.4/images/marker-shadow.png',
                iconSize: [25, 41],
                iconAnchor: [12, 41],
                popupAnchor: [1, -34],
                shadowSize: [41, 41]
            });

            // Initialize map with a default view before location is found
            const map = L.map('map').setView([14.5995, 120.9842], 13); // Manila coordinates

            // Determine if dark mode is active to use appropriate tile layer
            const isDarkMode = document.documentElement.classList.contains('dark');

            let tileUrl = 'https://tile.openstreetmap.org/{z}/{x}/{y}.png';
            if (isDarkMode) {
                // Dark theme tiles for OpenStreetMap via CartoDB
                tileUrl = 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
                L.tileLayer(tileUrl, {
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
                    subdomains: 'abcd',
                    maxZoom: 20
                }).addTo(map);
            } else {
                L.tileLayer(tileUrl, {
                    maxZoom: 18,
                    attribution: '© OpenStreetMap'
                }).addTo(map);
            }

            map.locate({ setView: true, maxZoom: 16 });

            function onLocationFound(e) {
                const { lat, lng } = e.latlng;
                const radius = e.accuracy;

                const userMarker = L.marker([lat, lng]).addTo(map)
                    .bindPopup(`<div>Current Position</div>`).openPopup();

                L.circle([lat, lng], {
                    radius: radius,
                    color: '#4f46e5',
                    fillColor: '#4f46e5',
                    fillOpacity: 0.15,
                    weight: 2
                }).addTo(map);

                document.getElementById("coords").textContent = `LAT ${lat.toFixed(5)} :: LON ${lng.toFixed(5)}`;

                fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`)
                    .then(res => res.json())
                    .then(data => {
                        document.getElementById("address").innerHTML = `${data.display_name}`;
                    })
                    .catch(() => {
                        document.getElementById("address").innerHTML = "Coordinates Acquired (Address mapping failed)";
                    });

                // Fetch nearby stations
                fetch('/nearby-stations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lat, lng })
                })
                    .then(res => res.json())
                    .then(data => {
                        let nearest = null;

                        if (data && data.length > 0) {
                            data.forEach(station => {
                                const marker = L.marker([station.latitude, station.longitude], { icon: redIcon }).addTo(map);

                                let iconStr = '<i class="fa-solid fa-building-shield"></i>';
                                if (station.type.toLowerCase().includes('police')) iconStr = '<i class="fa-solid fa-building-shield"></i>';
                                if (station.type.toLowerCase().includes('fire')) iconStr = '<i class="fa-solid fa-fire-extinguisher"></i>';
                                if (station.type.toLowerCase().includes('hospital')) iconStr = '<i class="fa-solid fa-hospital"></i>';

                                marker.bindPopup(`
                            <div style="font-family: 'Inter', sans-serif;">
                                <div style="font-weight: 700; color: var(--primary); margin-bottom: 0.25rem;">${iconStr} ${station.name}</div>
                                <div style="font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase;">${station.type}</div>
                                <div style="font-size: 0.8rem; font-weight: 600; color: var(--text-bright); margin-top: 0.5rem;">DIST: ${station.distance.toFixed(2)} KM</div>
                            </div>
                        `);
                            });

                            nearest = data[0];

                            if (nearest) {
                                try {
                                    const routingControl = L.Routing.control({
                                        waypoints: [
                                            L.latLng(lat, lng),
                                            L.latLng(nearest.latitude, nearest.longitude)
                                        ],
                                        lineOptions: {
                                            styles: [{ color: '#4f46e5', weight: 4, opacity: 0.8, dashArray: '10, 10' }]
                                        },
                                        routeWhileDragging: false,
                                        showAlternatives: false,
                                        addWaypoints: false,
                                        draggableWaypoints: false,
                                        fitSelectedRoutes: true,
                                        createMarker: function () { return null; },
                                        show: false // Hide text instructions by default
                                    }).addTo(map);

                                    // Adjust map bounds slightly to ensure both points fit well
                                    const group = new L.featureGroup([
                                        L.marker([lat, lng]),
                                        L.marker([nearest.latitude, nearest.longitude])
                                    ]);
                                    setTimeout(() => { map.fitBounds(group.getBounds().pad(0.1)); }, 1000);

                                } catch (err) {
                                    console.error("Routing error:", err);
                                }
                            }
                        }
                    })
                    .catch(error => {
                        console.error('Network logic anomaly:', error);
                    });
            }

            map.on('locationfound', onLocationFound);
            map.on('locationerror', function (e) {
                console.warn("Location services inaccessible.");
                document.getElementById("address").innerHTML = "Location Services Offline/Denied";
                document.getElementById("coords").innerHTML = "Awaiting manual override...";
            });

            // Handle window resize for map
            window.addEventListener('resize', function () {
                setTimeout(() => { map.invalidateSize(); }, 200);
            });
        </script>

        <%- include('../partials/footer'); %>
            <%- include('../partials/page-end'); %>
</body>

</html>