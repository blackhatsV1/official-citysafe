<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body>
  <%- include('../partials/page-start'); %>

    <header>
      <%- include('../partials/user-navbar', { currentPage: 'riskassessment' }); %>
    </header>

    <div class="cs-layout-container">
      <aside>
        <%- include('../partials/user-sidebar', { currentPage: 'riskassessment' }); %>
      </aside>

      <main class="cs-main-content">
        <div class="cs-container" style="max-width: 800px;">

          <div
            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem; flex-wrap: wrap; gap: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 1.5rem;">
              <div class="cs-badge"
                style="width: 64px; height: 64px; font-size: 1.5rem; background: var(--primary-glow); color: var(--primary); border: 2px solid var(--primary);">
                <i class="fa-solid fa-clipboard-question"></i>
              </div>
              <h1 class="cs-section-header" style="margin: 0;">
                RISK <span
                  style="background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">ASSESSMENT</span>
              </h1>
            </div>
            <a href="/risk-results"
              style="text-decoration: none; font-size: 0.75rem; font-weight: 900; color: var(--text-dim); background: rgba(255,255,255,0.05); padding: 0.75rem 1.25rem; border-radius: 0.75rem; border: 1px solid var(--border-glass); display: flex; align-items: center; gap: 0.5rem; transition: all 0.2s ease;"
              onmouseover="this.style.borderColor='var(--primary)'; this.style.color='var(--primary)'"
              onmouseout="this.style.borderColor='var(--border-glass)'; this.style.color='var(--text-dim)'">
              <i class="fa-solid fa-clock-rotate-left"></i> ASSESSMENT HISTORY
            </a>
          </div>

          <div class="cs-card" style="padding: 3rem; position: relative; overflow: hidden;">
            <div
              style="position: absolute; top: -100px; left: -100px; width: 300px; height: 300px; background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%); pointer-events: none;">
            </div>

            <div style="margin-bottom: 3rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.5rem;">
              <h4
                style="margin: 0; font-size: 1.25rem; font-weight: 800; color: var(--text-bright); letter-spacing: 0.05rem;">
                VULNERABILITY QUESTIONNAIRE</h4>
              <p style="color: var(--text-dim); margin-top: 0.5rem; font-size: 0.95rem;">Answer the following parameters
                to calculate your hyper-local risk profile.</p>
            </div>

            <form action="/assess-risk" method="POST" style="display: flex; flex-direction: column; gap: 2.5rem;">

              <!-- Question 1 -->
              <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                <label
                  style="display: flex; align-items: center; gap: 1rem; font-size: 1rem; font-weight: 700; color: var(--text-bright);">
                  <div class="cs-badge"
                    style="width: 32px; height: 32px; font-size: 0.8rem; background: var(--primary-glow); color: var(--primary);">
                    <i class="fa-solid fa-droplet"></i></div>
                  Are you situated near a river or major waterway?
                </label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <label class="cs-selectable-tile">
                    <input type="radio" name="nearRiver" value="true" required style="display: none;">
                    <div class="tile-content">
                      <i class="fa-solid fa-check"></i>
                      <span>YES, AFFIRMATIVE</span>
                    </div>
                  </label>
                  <label class="cs-selectable-tile">
                    <input type="radio" name="nearRiver" value="false" style="display: none;">
                    <div class="tile-content">
                      <i class="fa-solid fa-xmark"></i>
                      <span>NO, NEGATIVE</span>
                    </div>
                  </label>
                </div>
              </div>

              <!-- Question 2 -->
              <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                <label
                  style="display: flex; align-items: center; gap: 1rem; font-size: 1rem; font-weight: 700; color: var(--text-bright);">
                  <div class="cs-badge"
                    style="width: 32px; height: 32px; font-size: 0.8rem; background: var(--warning-glow); color: var(--warning);">
                    <i class="fa-solid fa-angles-down"></i></div>
                  Are you located near a known geological fault line?
                </label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <label class="cs-selectable-tile">
                    <input type="radio" name="nearFault" value="true" required style="display: none;">
                    <div class="tile-content">
                      <i class="fa-solid fa-check"></i>
                      <span>YES, AFFIRMATIVE</span>
                    </div>
                  </label>
                  <label class="cs-selectable-tile">
                    <input type="radio" name="nearFault" value="false" style="display: none;">
                    <div class="tile-content">
                      <i class="fa-solid fa-xmark"></i>
                      <span>NO, NEGATIVE</span>
                    </div>
                  </label>
                </div>
              </div>

              <!-- Question 3 -->
              <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                <label
                  style="display: flex; align-items: center; gap: 1rem; font-size: 1rem; font-weight: 700; color: var(--text-bright);">
                  <div class="cs-badge"
                    style="width: 32px; height: 32px; font-size: 0.8rem; background: var(--info-glow); color: var(--info);">
                    <i class="fa-solid fa-kit-medical"></i></div>
                  Do you possess a fully stocked emergency survival kit?
                </label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <label class="cs-selectable-tile">
                    <input type="radio" name="hasKit" value="true" required style="display: none;">
                    <div class="tile-content">
                      <i class="fa-solid fa-check"></i>
                      <span>YES, AFFIRMATIVE</span>
                    </div>
                  </label>
                  <label class="cs-selectable-tile">
                    <input type="radio" name="hasKit" value="false" style="display: none;">
                    <div class="tile-content">
                      <i class="fa-solid fa-xmark"></i>
                      <span>NO, NEGATIVE</span>
                    </div>
                  </label>
                </div>
              </div>

              <!-- Question 4 -->
              <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                <label
                  style="display: flex; align-items: center; gap: 1rem; font-size: 1rem; font-weight: 700; color: var(--text-bright);">
                  <div class="cs-badge"
                    style="width: 32px; height: 32px; font-size: 0.8rem; background: var(--accent-glow); color: var(--accent);">
                    <i class="fa-solid fa-route"></i></div>
                  Have you established a clear evacuation route and plan?
                </label>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <label class="cs-selectable-tile">
                    <input type="radio" name="hasPlan" value="true" required style="display: none;">
                    <div class="tile-content">
                      <i class="fa-solid fa-check"></i>
                      <span>YES, AFFIRMATIVE</span>
                    </div>
                  </label>
                  <label class="cs-selectable-tile">
                    <input type="radio" name="hasPlan" value="false" style="display: none;">
                    <div class="tile-content">
                      <i class="fa-solid fa-xmark"></i>
                      <span>NO, NEGATIVE</span>
                    </div>
                  </label>
                </div>
              </div>

              <div style="margin-top: 1rem; display: flex; flex-direction: column; align-items: center; gap: 1rem;">
                <button type="submit" class="cs-btn-primary"
                  style="width: 100%; padding: 1.25rem; font-size: 1rem; display: flex; align-items: center; justify-content: center; gap: 1rem;">
                  <i class="fa-solid fa-microchip"></i> COMPUTE RISK PROFILE
                </button>
                <p
                  style="font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1rem; font-weight: 800;">
                  DATA WILL BE ENCRYPTED AND STORED IN SECURE ARCHIVE</p>
              </div>
            </form>
          </div>

        </div>
      </main>
    </div>

    <style>
      .cs-selectable-tile {
        cursor: pointer;
      }

      .cs-selectable-tile .tile-content {
        padding: 1.25rem;
        border: 1px solid var(--border-glass);
        background: rgba(255, 255, 255, 0.03);
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        color: var(--text-dim);
        font-size: 0.8rem;
        font-weight: 900;
        transition: all 0.2s ease;
      }

      .cs-selectable-tile input:checked+.tile-content {
        background: var(--primary-glow);
        border-color: var(--primary);
        color: var(--primary);
        box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);
      }

      .cs-selectable-tile .tile-content:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.2);
      }

      .cs-selectable-tile input:checked+.tile-content i {
        color: var(--primary);
      }
    </style>
    </main>
    </div>

    <%- include('../partials/footer'); %>
      <%- include('../partials/page-end'); %>
</body>

</html>