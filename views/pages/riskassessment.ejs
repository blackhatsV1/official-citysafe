<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body>
  <%- include('../partials/page-start'); %>

    <header>
      <%- include('../partials/user-navbar', { currentPage: 'riskassessment' }); %>
    </header>

    <div>
      <aside>
        <%- include('../partials/user-sidebar', { currentPage: 'riskassessment' }); %>
      </aside>

      <main>
        <div>

          <div>
            <div>
              <div>
                <i></i>
              </div>
              <h1>Risk Assessment
              </h1>
            </div>
            <a href="/risk-results">
              <i></i> Assessment History
            </a>
          </div>

          <div>
            <!-- Glow effect -->
            <div>
            </div>

            <div>
              <h4>
                Vulnerability Questionnaire
              </h4>
            </div>

            <div>
              <form action="/assess-risk" method="POST">

                <!-- Question 1 -->
                <div>
                  <label>
                    <div>
                      <i></i>
                    </div>
                    Are you situated near a river or major waterway?
                  </label>
                  <div>
                    <label>
                      <input type="radio" name="nearRiver" value="true" required>
                      <div>
                        YES
                      </div>
                    </label>
                    <label>
                      <input type="radio" name="nearRiver" value="false">
                      <div>
                        NO
                      </div>
                    </label>
                  </div>
                </div>

                <!-- Question 2 -->
                <div>
                  <label>
                    <div>
                      <i></i>
                    </div>
                    Are you located near a known geological fault line?
                  </label>
                  <div>
                    <label>
                      <input type="radio" name="nearFault" value="true" required>
                      <div>
                        YES
                      </div>
                    </label>
                    <label>
                      <input type="radio" name="nearFault" value="false">
                      <div>
                        NO
                      </div>
                    </label>
                  </div>
                </div>

                <!-- Question 3 -->
                <div>
                  <label>
                    <div>
                      <i></i>
                    </div>
                    Do you possess a fully stocked emergency survival kit?
                  </label>
                  <div>
                    <label>
                      <input type="radio" name="hasKit" value="true" required>
                      <div>
                        YES
                      </div>
                    </label>
                    <label>
                      <input type="radio" name="hasKit" value="false">
                      <div>
                        NO
                      </div>
                    </label>
                  </div>
                </div>

                <!-- Question 4 -->
                <div>
                  <label>
                    <div>
                      <i></i>
                    </div>
                    Have you established a clear evacuation route and plan?
                  </label>
                  <div>
                    <label>
                      <input type="radio" name="hasPlan" value="true" required>
                      <div>
                        YES
                      </div>
                    </label>
                    <label>
                      <input type="radio" name="hasPlan" value="false">
                      <div>
                        NO
                      </div>
                    </label>
                  </div>
                </div>

                <div>
                  <button type="submit">
                    <i></i> COMPUTE RISK PROFILE
                  </button>
                </div>
              </form>
            </div>
          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>
      <%- include('../partials/page-end'); %>
</body>

</html>