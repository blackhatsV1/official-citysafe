<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <!-- Routing Machine -->

        <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.min.js"></script>

</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/user-navbar', { currentPage: 'my-reports' }); %>
        </header>

        <div class="cs-layout-container">
            <aside>
                <%- include('../partials/user-sidebar', { currentPage: 'my-reports' }); %>
            </aside>

            <main class="cs-main-content">
                <div class="cs-container">

                    <div
                        style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; flex-wrap: wrap; gap: 2rem;">
                        <div>
                            <h1 class="cs-section-header" style="margin: 0;">
                                OPERATIONS <span
                                    style="background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">LOG</span>
                            </h1>
                            <p style="color: var(--text-dim); margin-top: 0.5rem; font-size: 1.1rem;">Personal history
                                of emergency dispatches and active mission status.</p>
                        </div>
                    </div>

                    <!-- Active Report Section -->
                    <% let activeReport=reports.find(r=> r.status === 'responding' || r.status === 'pending'); %>
                        <div id="activeReportContainer">
                            <% if (activeReport) { %>
                                <% let accentColor=activeReport.status==='responding' ? 'var(--warning)'
                                    : 'var(--danger)' ; let accentGlow=activeReport.status==='responding'
                                    ? 'var(--warning-glow)' : 'var(--danger-glow)' ; let
                                    statusIcon=activeReport.status==='responding' ? 'fa-truck-medical'
                                    : 'fa-triangle-exclamation' ; %>
                                    <div class="cs-card"
                                        style="margin-bottom: 3rem; border: 1px solid <%= accentColor %>50; position: relative; overflow: hidden; padding: 0;">
                                        <!-- Background glow -->
                                        <div
                                            style="position: absolute; top: -100px; right: -100px; width: 300px; height: 300px; background: radial-gradient(circle, <%= accentGlow %> 0%, transparent 70%); pointer-events: none;">
                                        </div>

                                        <div
                                            style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--border-glass); background: rgba(0,0,0,0.3); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                                            <div style="display: flex; align-items: center; gap: 1rem;">
                                                <div class="cs-badge"
                                                    style="background: <%= accentGlow %>; color: <%= accentColor %>; border: 1px solid <%= accentColor %>;">
                                                    <i
                                                        class="fa-solid <%= statusIcon %> <%= activeReport.status === 'pending' ? 'fa-beat' : '' %>"></i>
                                                </div>
                                                <h4
                                                    style="margin: 0; font-size: 1rem; font-weight: 800; color: var(--text-bright); letter-spacing: 0.05rem;">
                                                    MISSION STATUS: <span style="color: <%= accentColor %>;">
                                                        <%= activeReport.status.toUpperCase() %>
                                                    </span>
                                                </h4>
                                            </div>
                                            <div id="actionButtonContainer">
                                                <% if (activeReport.status==='responding' &&
                                                    activeReport.user_confirmed_at) { %>
                                                    <span
                                                        style="font-size: 0.75rem; font-weight: 800; color: var(--text-dim); display: flex; align-items: center; gap: 0.5rem;">
                                                        <i class="fa-solid fa-hourglass-start fa-spin"></i> AWAITING
                                                        RESPONDER CHECK-IN
                                                    </span>
                                                    <% } else if (activeReport.status==='responding' ) { %>
                                                        <button onclick="markResolved(<%= activeReport.id %>)"
                                                            style="background: #10b981; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 0.75rem; font-size: 0.75rem; font-weight: 900; cursor: pointer; display: flex; align-items: center; gap: 0.75rem; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);">
                                                            <i class="fa-solid fa-check-double"></i> CONFIRM SAFETY /
                                                            RESOLVE
                                                        </button>
                                                        <% } else if (activeReport.status==='pending' ) { %>
                                                            <span
                                                                style="font-size: 0.75rem; font-weight: 800; color: var(--danger); display: flex; align-items: center; gap: 0.5rem; background: var(--danger-glow); padding: 0.5rem 1rem; border-radius: 0.5rem; border: 1px solid var(--danger);">
                                                                <i class="fa-solid fa-satellite-dish fa-spin-pulse"></i>
                                                                SCANNING FOR AVAILABLE UNITS...
                                                            </span>
                                                            <% } %>
                                            </div>
                                        </div>

                                        <div style="padding: 2rem;">
                                            <% if (activeReport.status==='responding' ) { %>
                                                <div class="cs-grid cs-grid-2">
                                                    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                                                        <div class="cs-card"
                                                            style="background: rgba(0,0,0,0.2); border-color: var(--border-glass); padding: 2rem;">
                                                            <div
                                                                style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
                                                                <div class="cs-badge"
                                                                    style="background: var(--primary-glow); color: var(--primary);">
                                                                    <i class="fa-solid fa-id-badge"></i></div>
                                                                <h3
                                                                    style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                                                    ASSIGNED OPERATIVE</h3>
                                                            </div>

                                                            <div
                                                                style="display: flex; flex-direction: column; gap: 1.5rem;">
                                                                <div>
                                                                    <div
                                                                        style="font-size: 0.7rem; font-weight: 800; color: var(--primary); text-transform: uppercase; letter-spacing: 0.1rem; margin-bottom: 0.5rem;">
                                                                        Designation</div>
                                                                    <div
                                                                        style="font-size: 1.5rem; font-weight: 800; color: var(--text-bright);">
                                                                        <%= activeReport.responder_name %>
                                                                            <%= activeReport.responder_last %>
                                                                    </div>
                                                                </div>

                                                                <div
                                                                    style="display: flex; flex-direction: column; gap: 0.75rem;">
                                                                    <div
                                                                        style="display: flex; align-items: center; gap: 1rem; color: var(--text-dim); font-size: 0.9rem;">
                                                                        <i class="fa-solid fa-envelope"
                                                                            style="width: 20px; color: var(--primary);"></i>
                                                                        <span>
                                                                            <%= activeReport.responder_email
                                                                                || 'CLASSIFIED' %>
                                                                        </span>
                                                                    </div>
                                                                    <div
                                                                        style="display: flex; align-items: center; gap: 1rem; color: var(--text-dim); font-size: 0.9rem;">
                                                                        <i class="fa-solid fa-phone-volume"
                                                                            style="width: 20px; color: var(--primary);"></i>
                                                                        <span>
                                                                            <%= activeReport.responder_contact
                                                                                || 'UNLISTED' %>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="cs-card"
                                                            style="background: rgba(0,0,0,0.2); padding: 1.5rem;">
                                                            <div
                                                                style="display: flex; align-items: flex-start; gap: 1rem;">
                                                                <i class="fa-solid fa-quote-left"
                                                                    style="color: var(--primary); font-size: 1.5rem; opacity: 0.5;"></i>
                                                                <div>
                                                                    <div
                                                                        style="font-size: 0.65rem; font-weight: 800; color: var(--text-dim); margin-bottom: 0.5rem;">
                                                                        FIELD NOTES</div>
                                                                    <div
                                                                        style="font-size: 0.9rem; color: var(--text-bright); line-height: 1.6; font-style: italic;">
                                                                        "<%= activeReport.responder_message
                                                                            || 'The responder is currently in transit. Awaiting further tactical updates from the field.'
                                                                            %>"</div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="cs-card"
                                                        style="padding: 1rem; border-color: var(--border-glass);">
                                                        <div class="cs-map-container" id="trackMap"
                                                            style="height: 100%; min-height: 400px; border-radius: 0.75rem;">
                                                        </div>
                                                        <div
                                                            style="position: absolute; bottom: 2rem; right: 2rem; z-index: 1000;">
                                                            <div class="cs-card"
                                                                style="padding: 0.5rem 1rem; background: rgba(0,0,0,0.8); border: 1px solid #10b981; display: flex; align-items: center; gap: 0.75rem;">
                                                                <div
                                                                    style="width: 8px; height: 8px; background: #10b981; border-radius: 50%; box-shadow: 0 0 10px #10b981; animation: pulse 2s infinite;">
                                                                </div>
                                                                <span
                                                                    style="font-size: 0.7rem; font-weight: 900; color: white;">LIVE
                                                                    TRACKING</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <input type="hidden" id="activeReportId" value="<%= activeReport.id %>">
                                                <input type="hidden" id="userLat" value="<%= activeReport.latitude %>">
                                                <input type="hidden" id="userLng" value="<%= activeReport.longitude %>">
                                                <input type="hidden" id="responderId"
                                                    value="<%= activeReport.responder_id %>">
                                                <% } else { %>
                                                    <div
                                                        style="padding: 4rem 2rem; text-align: center; position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                                                        <!-- Radar Sweep Animation -->
                                                        <div
                                                            style="position: absolute; width: 300px; height: 300px; border: 2px solid var(--danger); border-radius: 50%; opacity: 0.1; animation: radar-ping 3s infinite;">
                                                        </div>
                                                        <div
                                                            style="position: absolute; width: 200px; height: 200px; border: 2px solid var(--danger); border-radius: 50%; opacity: 0.2; animation: radar-ping 3s infinite 1s;">
                                                        </div>

                                                        <div class="cs-badge"
                                                            style="width: 80px; height: 80px; font-size: 2.5rem; background: var(--danger-glow); color: var(--danger); border: 2px solid var(--danger); margin-bottom: 2rem; box-shadow: 0 0 40px var(--danger-glow);">
                                                            <i class="fa-solid fa-satellite-dish"></i>
                                                        </div>
                                                        <h3
                                                            style="margin: 0; font-size: 1.5rem; font-weight: 800; color: var(--text-bright); letter-spacing: 0.1rem;">
                                                            BROADCASTING EMERGENCY SIGNAL</h3>
                                                        <p
                                                            style="margin: 1rem 0 2rem; max-width: 500px; color: var(--text-dim); line-height: 1.6;">
                                                            Please remain in a secure location. We are actively
                                                            cross-referencing your coordinates with the nearest
                                                            available emergency response units.</p>

                                                        <div style="display: flex; gap: 1rem;">
                                                            <div class="cs-card"
                                                                style="padding: 0.75rem 1.5rem; font-size: 0.7rem; font-weight: 900; color: var(--danger); background: rgba(0,0,0,0.5); border-color: var(--danger);">
                                                                LAT: <%= activeReport.latitude.toFixed(5) %>
                                                            </div>
                                                            <div class="cs-card"
                                                                style="padding: 0.75rem 1.5rem; font-size: 0.7rem; font-weight: 900; color: var(--danger); background: rgba(0,0,0,0.5); border-color: var(--danger);">
                                                                LNG: <%= activeReport.longitude.toFixed(5) %>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <input type="hidden" id="activeReportId"
                                                        value="<%= activeReport.id %>">
                                                    <% } %>
                                        </div>
                                    </div>
                                    <% } %>
                        </div>

                        <!-- History Table Container -->
                        <div class="cs-card"
                            style="padding: 0; overflow: hidden; border: 1px solid var(--border-glass);">
                            <div
                                style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--border-glass); background: rgba(255,255,255,0.02); display: flex; align-items: center; gap: 1rem;">
                                <div class="cs-badge" style="background: var(--accent-glow); color: var(--accent);"><i
                                        class="fa-solid fa-box-archive"></i></div>
                                <h2 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                    OPERATIONS ARCHIVE</h2>
                            </div>

                            <div style="overflow-x: auto;">
                                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                                    <thead>
                                        <tr style="background: rgba(0,0,0,0.3);">
                                            <th
                                                style="padding: 1.25rem 2rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                DATE / TIME</th>
                                            <th
                                                style="padding: 1.25rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                TYPE</th>
                                            <th
                                                style="padding: 1.25rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                LOCATION</th>
                                            <th
                                                style="padding: 1.25rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                OPERATIVE</th>
                                            <th
                                                style="padding: 1.25rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                STATUS</th>
                                            <th
                                                style="padding: 1.25rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                COMMS LOG</th>
                                            <th
                                                style="padding: 1.25rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                ACTIONS</th>
                                        </tr>
                                    </thead>
                                    <tbody id="historyTableBody">
                                        <% if (reports.length> 0) { %>
                                            <% reports.forEach(function(report) { %>
                                                <tr style="border-bottom: 1px solid var(--border-glass); transition: background 0.2s ease;"
                                                    onmouseover="this.style.background='rgba(255,255,255,0.02)'"
                                                    onmouseout="this.style.background='transparent'">
                                                    <td style="padding: 1.25rem 2rem;">
                                                        <div
                                                            style="display: flex; flex-direction: column; gap: 0.2rem; font-family: 'JetBrains Mono', monospace;">
                                                            <span
                                                                style="font-size: 0.85rem; font-weight: 700; color: var(--text-bright);">
                                                                <%= new Date(report.reported_at).toLocaleTimeString([],
                                                                    {hour: '2-digit' , minute:'2-digit'}) %>
                                                            </span>
                                                            <span style="font-size: 0.7rem; color: var(--text-dim);">
                                                                <%= new Date(report.reported_at).toLocaleDateString() %>
                                                            </span>
                                                        </div>
                                                    </td>
                                                    <td style="padding: 1.25rem;">
                                                        <span
                                                            style="font-size: 0.75rem; font-weight: 800; color: var(--text-bright); background: rgba(255,255,255,0.05); padding: 0.35rem 0.75rem; border-radius: 0.5rem; border: 1px solid var(--border-glass);">
                                                            <%= report.disaster_type.toUpperCase() %>
                                                        </span>
                                                    </td>
                                                    <td style="padding: 1.25rem;">
                                                        <div style="max-width: 150px; font-size: 0.8rem; color: var(--text-dim); line-height: 1.4; word-break: break-word;"
                                                            title="<%= report.location %>">
                                                            <%= report.location || 'LAT/LNG ONLY' %>
                                                        </div>
                                                    </td>
                                                    <td style="padding: 1.25rem;">
                                                        <% if (report.responder_name) { %>
                                                            <div
                                                                style="display: flex; align-items: center; gap: 0.75rem;">
                                                                <div class="cs-badge"
                                                                    style="width: 28px; height: 28px; font-size: 0.7rem; background: var(--primary-glow); color: var(--primary);">
                                                                    <i class="fa-solid fa-user-shield"></i></div>
                                                                <div style="display: flex; flex-direction: column;">
                                                                    <span
                                                                        style="font-size: 0.85rem; font-weight: 700; color: var(--text-bright);">
                                                                        <%= report.responder_name %>
                                                                    </span>
                                                                    <span
                                                                        style="font-size: 0.65rem; color: var(--primary); font-weight: 800;">
                                                                        <%= report.station_name || 'DEFENSE UNIT' %>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                            <% } else { %>
                                                                <span
                                                                    style="font-size: 0.75rem; color: var(--text-dim); font-style: italic;">Awaiting
                                                                    Assignment</span>
                                                                <% } %>
                                                    </td>
                                                    <td style="padding: 1.25rem;">
                                                        <% let statusColor='var(--text-dim)' ; let
                                                            statusBg='rgba(255,255,255,0.05)' ; if
                                                            (report.status==='resolved' ) { statusColor='#10b981' ;
                                                            statusBg='rgba(16, 185, 129, 0.1)' ; } else if
                                                            (report.status==='responding' ) {
                                                            statusColor='var(--warning)' ;
                                                            statusBg='var(--warning-glow)' ; } else if
                                                            (report.status==='pending' ) { statusColor='var(--danger)' ;
                                                            statusBg='var(--danger-glow)' ; } %>
                                                            <span
                                                                style="font-size: 0.65rem; font-weight: 900; color: <%= statusColor %>; background: <%= statusBg %>; padding: 0.35rem 0.75rem; border-radius: 2rem; border: 1px solid <%= statusColor %>40;">
                                                                <%= report.status.toUpperCase() %>
                                                            </span>
                                                    </td>
                                                    <td style="padding: 1.25rem;">
                                                        <div
                                                            style="display: flex; flex-direction: column; gap: 0.4rem; max-width: 250px;">
                                                            <div
                                                                style="font-size: 0.75rem; color: var(--text-dim); display: flex; gap: 0.5rem; line-height: 1.4;">
                                                                <span
                                                                    style="font-weight: 800; color: var(--primary); min-width: 25px;">OP:</span>
                                                                <span style="font-style: italic;">"<%=
                                                                        report.responder_message || '-' %>"</span>
                                                            </div>
                                                            <div
                                                                style="font-size: 0.75rem; color: var(--text-dim); display: flex; gap: 0.5rem; line-height: 1.4;">
                                                                <span
                                                                    style="font-weight: 800; color: var(--accent); min-width: 25px;">US:</span>
                                                                <span style="font-style: italic;">"<%=
                                                                        report.user_message || '-' %>"</span>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td style="padding: 1.25rem 2rem;">
                                                        <div style="display: flex; gap: 0.5rem;">
                                                            <% if (report.status==='pending' ) { %>
                                                                <button onclick="markResolved(<%= report.id %>)"
                                                                    class="cs-btn-primary"
                                                                    style="padding: 0.4rem 0.8rem; font-size: 0.65rem;">RESOLVE</button>
                                                                <button onclick="cancelReport(<%= report.id %>)"
                                                                    style="background: rgba(239, 68, 68, 0.1); border: 1px solid var(--danger); color: var(--danger); padding: 0.4rem 0.8rem; font-size: 0.65rem; font-weight: 800; border-radius: 0.5rem; cursor: pointer;">CANCEL</button>
                                                                <% } else if (report.status==='responding' ) { %>
                                                                    <% if (!report.user_confirmed_at) { %>
                                                                        <button onclick="markResolved(<%= report.id %>)"
                                                                            class="cs-btn-primary"
                                                                            style="padding: 0.4rem 0.8rem; font-size: 0.65rem;">RESOLVE</button>
                                                                        <% } else { %>
                                                                            <span
                                                                                style="font-size: 0.7rem; color: var(--text-dim); font-weight: 800; display: flex; align-items: center; gap: 0.4rem;"><i
                                                                                    class="fa-solid fa-spinner fa-spin"></i>
                                                                                STANDBY</span>
                                                                            <% } %>
                                                                                <% } else { %>
                                                                                    <span
                                                                                        style="color: var(--text-dim); font-size: 0.7rem; font-weight: 800; opacity: 0.4;">ARCHIVED</span>
                                                                                    <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="7"
                                                                style="padding: 5rem 2rem; text-align: center; color: var(--text-dim);">
                                                                <div class="cs-badge"
                                                                    style="width: 64px; height: 64px; font-size: 2rem; margin: 0 auto 1.5rem; background: rgba(255,255,255,0.02); color: var(--text-dim); border-style: dashed;">
                                                                    <i class="fa-solid fa-folder-open"></i>
                                                                </div>
                                                                <h3
                                                                    style="margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-bright);">
                                                                    ARCHIVE EMPTY</h3>
                                                                <p style="margin-top: 0.5rem;">No historical operations
                                                                    recorded for this terminal.</p>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                </div>
            </main>
        </div>

        <style>
            @keyframes radar-ping {
                0% {
                    transform: scale(1);
                    opacity: 0.3;
                }

                100% {
                    transform: scale(2.5);
                    opacity: 0;
                }
            }

            .animate-route {
                stroke-dasharray: 10, 10;
                animation: dash 1s linear infinite;
            }

            @keyframes dash {
                to {
                    stroke-dashoffset: -20;
                }
            }
        </style>

        </div>
        </main>
        </div>

        <%- include('../partials/footer'); %>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                // Use glassmorphism theme for SweetAlert globally in this view
                const GlassSwal = Swal.mixin({
                    customClass: {
                        popup: 'glass-swal',
                        confirmButton: 'rounded-lg px-4 py-2 font-bold uppercase tracking-widest text-xs',
                        cancelButton: 'rounded-lg px-4 py-2 font-bold uppercase tracking-widest text-xs'
                    },
                    background: document.documentElement.classList.contains('dark') ? 'rgba(17, 24, 39, 0.9)' : 'rgba(255, 255, 255, 0.9)',
                    color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                });

                // Real-time Poll for Reports
                let previousReportsJSON = '';

        // Initialize status
        <%
                    let initialStatus = 'none';
                let jsActive = reports.find(r => r.status === 'responding' || r.status === 'pending');
                if (jsActive) { initialStatus = jsActive.status; }
        %>
                    let currentPageStatus = "<%= initialStatus %>";

                // Logic relies on UI reload on status change for cleanly re-hydrating Alpine/Tailwind state.
                function pollReports() {
                    fetch('/api/my-reports-list')
                        .then(res => res.json())
                        .then(reports => {
                            const currentJSON = JSON.stringify(reports);
                            if (currentJSON === previousReportsJSON) return; // No change
                            previousReportsJSON = currentJSON;

                            // CHECK FOR STATUS CHANGE (Active Report Section)
                            const latestActive = reports.find(r => r.status === 'responding' || r.status === 'pending');
                            const newStatus = latestActive ? latestActive.status : 'none';

                            if (newStatus !== currentPageStatus) {
                                console.log("Status changed. Reloading...");
                                location.reload();
                                return;
                            }

                            // We only update the table dynamically here, active section is handled by reload/checkStatus
                        })
                        .catch(err => console.error(err));
                }

                setInterval(pollReports, 3000);

                function cancelReport(id) {
                    GlassSwal.fire({
                        title: '<span>Abort Operation?</span>',
                        html: '<span>Are you certain you wish to cancel this dispatch request?</span>',
                        icon: 'warning',
                        iconColor: '#ef4444',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#6b7280',
                        confirmButtonText: 'CONFIRM ABORT',
                        cancelButtonText: 'KEEP ACTIVE'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            fetch('/api/cancel_report', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ id: id })
                            }).then(res => res.json()).then(data => {
                                if (data.success) {
                                    GlassSwal.fire({
                                        icon: 'success',
                                        title: '<span>ABORTED</span>',
                                        showConfirmButton: false,
                                        timer: 1500
                                    }).then(() => location.reload());
                                } else {
                                    GlassSwal.fire('Error', 'Failed to cancel.', 'error');
                                }
                            });
                        }
                    })
                }

                function markResolved(id) {
                    GlassSwal.fire({
                        title: '<span>Confirm Resolution</span>',
                        html: '<span>Provide final debriefing remarks for the operational log:</span>',
                        input: 'textarea',
                        inputPlaceholder: 'Type your feedback here...',
                        inputAttributes: { 'aria-label': 'Type your feedback here' },
                        icon: 'question',
                        iconColor: '#10b981',
                        showCancelButton: true,
                        confirmButtonText: 'SUBMIT DEBRIEF',
                        cancelButtonText: 'CANCEL',
                        confirmButtonColor: '#10b981',
                        cancelButtonColor: '#6b7280',
                        showLoaderOnConfirm: true,
                        customClass: Object.assign({}, GlassSwal.params.customClass, {
                            input: 'bg-white/50 dark:bg-gray-800/50 border border-gray-300 dark:border-gray-600 rounded-xl text-sm font-medium focus:ring-emerald-500 focus:border-emerald-500'
                        }),
                        preConfirm: (feedback) => {
                            if (!feedback) {
                                Swal.showValidationMessage('Feedback cannot be empty');
                                return false;
                            }
                            return fetch('/api/resolve', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ incidentId: id, remarks: feedback })
                            })
                                .then(response => {
                                    if (!response.ok) throw new Error(response.statusText)
                                    return response.json()
                                })
                                .catch(error => {
                                    Swal.showValidationMessage(`Request failed: ${error}`)
                                })
                        },
                        allowOutsideClick: () => !Swal.isLoading()
                    }).then((result) => {
                        if (result.isConfirmed && result.value.success) {
                            let msg = result.value.status === 'resolved'
                                ? 'Operation fully resolved and archived.'
                                : 'Awaiting responder counterpart confirmation.';
                            GlassSwal.fire({
                                icon: 'success',
                                title: '<span>LOGGED</span>',
                                html: `<span>${msg}</span>`,
                                confirmButtonColor: '#10b981'
                            }).then(() => location.reload());
                        }
                    })
                }

                // MAP TRACKING LOGIC
                let trackMapEl = document.getElementById('trackMap');
                let mapInstance = null;
                let responderMarker = null;
                let routingControl = null;

                function initTrackMap(userLat, userLng, responderId) {
                    if (mapInstance) { mapInstance.off(); mapInstance.remove(); }

                    trackMapEl = document.getElementById('trackMap');
                    if (!trackMapEl) return;

                    mapInstance = L.map('trackMap', { zoomControl: false }).setView([userLat, userLng], 14);
                    L.control.zoom({ position: 'bottomright' }).addTo(mapInstance);

                    // Subtle darkish map tiles matching the theme better
                    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                        attribution: '&copy; OpenStreetMap | Carto'
                    }).addTo(mapInstance);

                    // User Marker - Pulse effect
                    const userIconHtml = `
                <div>
                    <span></span>
                    <span>
                        <i></i>
                    </span>
                </div>
            `;
                    const uIcon = L.divIcon({ className: 'bg-transparent', html: userIconHtml, iconSize: [24, 24], iconAnchor: [12, 12] });
                    L.marker([userLat, userLng], { icon: uIcon }).addTo(mapInstance).bindPopup("<b>Your Signal</b>", { className: 'glass-popup' });

                    trackResponderOnMap(mapInstance, responderId, userLat, userLng);
                }

                function trackResponderOnMap(map, rId, uLat, uLng) {
                    function pollLoc() {
                        fetch(`/api/responder-track/${rId}`)
                            .then(res => res.json())
                            .then(d => {
                                if (d.latitude && d.longitude) {
                                    if (!responderMarker) {
                                        const respIconHtml = `
                                    <div>
                                        <span></span>
                                        <span>
                                            <i></i>
                                        </span>
                                    </div>
                                `;
                                        const icon = L.divIcon({ className: 'bg-transparent', html: respIconHtml, iconSize: [32, 32], iconAnchor: [16, 16] });
                                        responderMarker = L.marker([d.latitude, d.longitude], { icon: icon, zIndexOffset: 1000 }).addTo(map).bindPopup("<b>Operative inbound</b>", { className: 'glass-popup' });
                                    } else {
                                        responderMarker.setLatLng([d.latitude, d.longitude]);
                                    }

                                    if (routingControl) {
                                        routingControl.setWaypoints([L.latLng(d.latitude, d.longitude), L.latLng(uLat, uLng)]);
                                    } else {
                                        routingControl = L.Routing.control({
                                            waypoints: [L.latLng(d.latitude, d.longitude), L.latLng(uLat, uLng)],
                                            lineOptions: { styles: [{ color: '#f59e0b', opacity: 0.8, weight: 5, dashArray: '10, 10', className: 'animate-route' }] },
                                            show: false, addWaypoints: false, draggableWaypoints: false, fitSelectedRoutes: false,
                                            createMarker: function () { return null; }
                                        }).addTo(map);
                                    }
                                }
                            }).catch(e => console.warn("Tracking:", e));
                    }
                    pollLoc();
                    setInterval(pollLoc, 3000);
                }

                // Initialize map on load if container exists
                if (document.getElementById('trackMap')) {
                    const uLt = parseFloat(document.getElementById('userLat').value);
                    const uLn = parseFloat(document.getElementById('userLng').value);
                    const rId = document.getElementById('responderId').value;
                    initTrackMap(uLt, uLn, rId);
                }
            </script>
</body>

</html>