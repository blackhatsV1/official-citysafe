<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <!-- Routing Machine -->
        <link rel="stylesheet"
            href="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.css" />
        <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.min.js"></script>
        <style>
            #trackMap {
                height: 350px;
                width: 100%;
            }

            /* Glassmorphic SweetAlert matching original theme */
            .swal2-popup.glass-swal {
                background: rgba(255, 255, 255, 0.9);
                backdrop-filter: blur(16px);
                border: 1px solid rgba(255, 255, 255, 0.4);
                border-radius: 1.5rem;
                color: #1f2937;
            }

            .dark .swal2-popup.glass-swal {
                background: rgba(17, 24, 39, 0.85);
                border: 1px solid rgba(255, 255, 255, 0.05);
                color: #f3f4f6;
            }
        </style>
</head>

<body
    class="bg-gradient-glass-light dark:bg-gradient-glass-dark text-gray-800 dark:text-gray-100 min-h-screen flex flex-col">
    <%- include('../partials/page-start'); %>

        <header class="sticky top-0 z-50">
            <%- include('../partials/user-navbar', { currentPage: 'my-reports' }); %>
        </header>

        <div class="flex flex-1 overflow-hidden relative">
            <aside class="z-40">
                <%- include('../partials/user-sidebar', { currentPage: 'my-reports' }); %>
            </aside>

            <main class="flex-1 px-4 py-8 sm:px-6 lg:px-8 overflow-y-auto w-full relative">
                <div class="max-w-7xl mx-auto space-y-6">

                    <h1 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight uppercase px-2 mb-2">My
                        Operations Log</h1>

                    <!-- Active Report Section -->
                    <% let activeReport=reports.find(r=> r.status === 'responding' || r.status === 'pending'); %>
                        <div id="activeReportContainer">
                            <% if (activeReport) { %>
                                <% let borderColor=activeReport.status==='responding'
                                    ? 'border-yellow-500 shadow-yellow-500/20' : 'border-red-500 shadow-red-500/20' ;
                                    let bgColor=activeReport.status==='responding'
                                    ? 'bg-yellow-50/50 dark:bg-yellow-900/10' : 'bg-red-50/50 dark:bg-red-900/10' ; let
                                    headerBorder=activeReport.status==='responding'
                                    ? 'border-yellow-100 dark:border-yellow-900/30'
                                    : 'border-red-100 dark:border-red-900/30' ; let
                                    headerIcon=activeReport.status==='responding' ? 'fa-ambulance text-yellow-500'
                                    : 'fa-exclamation-circle text-red-500 animate-pulse' ; let
                                    textColor=activeReport.status==='responding'
                                    ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400' ; %>
                                    <div class="glass-panel overflow-hidden border-t-4 <%= borderColor %> mb-6 shadow-lg relative"
                                        id="statusBoxBorder">
                                        <!-- Background glow -->
                                        <div
                                            class="absolute top-0 right-0 w-64 h-64 bg-current opacity-5 rounded-full blur-[80px] pointer-events-none <%= textColor %>">
                                        </div>

                                        <div
                                            class="px-6 py-4 border-b <%= headerBorder %> <%= bgColor %> flex flex-col sm:flex-row sm:items-center justify-between gap-4 relative z-10">
                                            <h4
                                                class="text-sm font-bold uppercase tracking-widest flex items-center gap-2">
                                                <i class="fa <%= headerIcon %> text-lg" id="statusIcon"></i>
                                                <span class="text-gray-800 dark:text-gray-200">Current Status:</span>
                                                <span class="<%= textColor %> ml-1" id="statusText">
                                                    <%= activeReport.status.toUpperCase() %>
                                                </span>
                                            </h4>
                                            <div id="actionButtonContainer">
                                                <% if (activeReport.status==='responding' &&
                                                    activeReport.user_confirmed_at) { %>
                                                    <span
                                                        class="px-3 py-1.5 bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 rounded-lg text-xs font-bold uppercase tracking-widest border border-blue-200 dark:border-blue-800/50 flex items-center gap-2">
                                                        <i class="fa fa-circle-notch fa-spin"></i> Awaiting Responder
                                                        Check-in
                                                    </span>
                                                    <% } else if (activeReport.status==='responding' ) { %>
                                                        <button
                                                            class="px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white rounded-lg text-xs font-black uppercase tracking-widest transition-colors shadow-lg shadow-emerald-500/30 flex items-center gap-2 border border-emerald-400 dark:border-emerald-600 animate-pulse"
                                                            onclick="markResolved(<%= activeReport.id %>)">
                                                            <i class="fa fa-check-circle"></i> Confirm Safety / Resolve
                                                        </button>
                                                        <% } else if (activeReport.status==='pending' ) { %>
                                                            <span
                                                                class="px-3 py-1.5 bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 rounded-lg text-xs font-bold uppercase tracking-widest border border-gray-200 dark:border-gray-700 flex items-center gap-2 cursor-not-allowed">
                                                                <i class="fa fa-radar fa-beat-fade relative"><span
                                                                        class="absolute inset-0 invisible">rad</span></i>
                                                                Scanning for Units...
                                                            </span>
                                                            <% } %>
                                            </div>
                                        </div>

                                        <div class="p-6 relative z-10" id="dynamicContent">
                                            <% if (activeReport.status==='responding' ) { %>
                                                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                                    <div class="md:col-span-1">
                                                        <div
                                                            class="h-full bg-white/50 dark:bg-gray-800/50 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 flex flex-col items-center justify-center text-center shadow-inner relative overflow-hidden group hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors">
                                                            <div
                                                                class="mb-4 w-16 h-16 rounded-full bg-indigo-100 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-400 flex items-center justify-center border border-indigo-200 dark:border-indigo-800/50 shadow-md group-hover:scale-110 transition-transform">
                                                                <i class="fa fa-user-shield text-2xl"></i>
                                                            </div>
                                                            <h6
                                                                class="text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-2">
                                                                Assigned Operative</h6>
                                                            <h5 class="text-xl font-bold text-gray-900 dark:text-white capitalize mb-4"
                                                                id="respName">
                                                                <%= activeReport.responder_name %>
                                                                    <%= activeReport.responder_last %>
                                                            </h5>
                                                            <div class="w-full space-y-2 text-sm text-left">
                                                                <div
                                                                    class="flex items-center gap-3 px-3 py-2 bg-gray-50 dark:bg-gray-900/50 rounded-lg border border-gray-100 dark:border-gray-800">
                                                                    <i
                                                                        class="fa fa-envelope text-gray-400 w-4 text-center"></i>
                                                                    <span id="respEmail"
                                                                        class="text-gray-600 dark:text-gray-300 font-medium truncate">
                                                                        <%= activeReport.responder_email || 'Classified'
                                                                            %>
                                                                    </span>
                                                                </div>
                                                                <div
                                                                    class="flex items-center gap-3 px-3 py-2 bg-indigo-50 dark:bg-indigo-900/30 rounded-lg border border-indigo-100 dark:border-indigo-800/50">
                                                                    <i class="fa fa-phone text-indigo-500 w-4 text-center fa-shake"
                                                                        style="--fa-animation-duration: 3s;"></i>
                                                                    <span id="respContact"
                                                                        class="text-indigo-700 dark:text-indigo-300 font-bold">
                                                                        <%= activeReport.responder_contact || 'Unlisted'
                                                                            %>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="md:col-span-2">
                                                        <div
                                                            class="bg-gray-100 dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-inner h-full min-h-[350px] relative">
                                                            <div id="trackMap" class="absolute inset-0"></div>
                                                            <div
                                                                class="absolute top-4 left-4 z-[400] bg-white/80 dark:bg-gray-900/80 backdrop-blur-md px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm text-[10px] font-bold uppercase tracking-widest text-gray-700 dark:text-gray-300 flex items-center gap-2">
                                                                <div
                                                                    class="w-2 h-2 rounded-full bg-green-500 animate-pulse">
                                                                </div> Live Tracking
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <input type="hidden" id="activeReportId" value="<%= activeReport.id %>">
                                                <input type="hidden" id="userLat" value="<%= activeReport.latitude %>">
                                                <input type="hidden" id="userLng" value="<%= activeReport.longitude %>">
                                                <input type="hidden" id="responderId"
                                                    value="<%= activeReport.responder_id %>">
                                                <% } else { %>
                                                    <div
                                                        class="flex flex-col items-center justify-center py-12 text-center relative">
                                                        <!-- Radar Sweep Animation Context -->
                                                        <div
                                                            class="absolute inset-0 flex items-center justify-center opacity-10 pointer-events-none">
                                                            <div
                                                                class="w-48 h-48 rounded-full border border-red-500 absolute animate-ping">
                                                            </div>
                                                            <div class="w-64 h-64 rounded-full border border-red-500 absolute"
                                                                style="animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite; animation-delay: 0.5s;">
                                                            </div>
                                                        </div>

                                                        <div
                                                            class="w-16 h-16 bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400 rounded-full flex items-center justify-center mb-4 border border-red-200 dark:border-red-800/50 shadow-lg relative z-10">
                                                            <i class="fa fa-radar fa-spin text-3xl"></i>
                                                        </div>
                                                        <h5
                                                            class="text-xl font-bold text-gray-900 dark:text-white mb-2 relative z-10 tracking-tight">
                                                            Broadcasting Emergency Signal</h5>
                                                        <p
                                                            class="text-sm font-medium text-gray-500 dark:text-gray-400 max-w-md relative z-10">
                                                            Please lock down in a secure location. We are actively
                                                            cross-referencing nearest available emergency response
                                                            units.
                                                        </p>
                                                    </div>
                                                    <input type="hidden" id="activeReportId"
                                                        value="<%= activeReport.id %>">
                                                    <% } %>
                                        </div>
                                    </div>
                                    <% } %>
                        </div>

                        <!-- History Table Container -->
                        <div class="glass-panel overflow-hidden">
                            <div
                                class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 bg-white/40 dark:bg-gray-900/40 flex items-center gap-3">
                                <i class="fa fa-history text-gray-400"></i>
                                <h2 class="text-sm font-bold uppercase tracking-wider text-gray-700 dark:text-gray-300">
                                    Operations Archive</h2>
                            </div>

                            <div class="p-0 overflow-x-auto">
                                <table class="w-full text-left border-collapse">
                                    <thead>
                                        <tr
                                            class="bg-gray-50/50 dark:bg-gray-800/50 border-b border-gray-100 dark:border-gray-800">
                                            <th
                                                class="px-6 py-3 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">
                                                Date/Time</th>
                                            <th
                                                class="px-6 py-3 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">
                                                Type</th>
                                            <th
                                                class="px-6 py-3 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">
                                                Location</th>
                                            <th
                                                class="px-6 py-3 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">
                                                Operative</th>
                                            <th
                                                class="px-6 py-3 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">
                                                Status</th>
                                            <th
                                                class="px-6 py-3 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">
                                                Resolved By</th>
                                            <th
                                                class="px-6 py-3 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">
                                                Comms Log</th>
                                            <th
                                                class="px-6 py-3 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">
                                                Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="historyTableBody" class="divide-y divide-gray-100 dark:divide-gray-800">
                                        <% if (reports.length> 0) { %>
                                            <% reports.forEach(function(report) { %>
                                                <tr
                                                    class="hover:bg-gray-50/50 dark:hover:bg-gray-800/30 transition-colors group">
                                                    <td
                                                        class="px-6 py-4 text-xs font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap">
                                                        <%= new Date(report.reported_at).toLocaleString() %>
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <span
                                                            class="px-2 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded text-[10px] font-bold uppercase tracking-widest border border-gray-200 dark:border-gray-700">
                                                            <%= report.disaster_type %>
                                                        </span>
                                                    </td>
                                                    <td class="px-6 py-4 text-xs text-gray-600 dark:text-gray-400 max-w-[150px] truncate"
                                                        title="<%= report.location || 'Unknown' %>">
                                                        <%= report.location || 'Unknown' %>
                                                    </td>
                                                    <td class="px-6 py-4 text-xs">
                                                        <% if (report.responder_name) { %>
                                                            <div class="font-bold text-gray-900 dark:text-gray-100">
                                                                <%= report.responder_name %>
                                                                    <%= report.responder_last %>
                                                            </div>
                                                            <div class="text-[10px] font-medium text-gray-500 mt-0.5">
                                                                <%= report.station_name || 'Station' %>
                                                            </div>
                                                            <% } else { %>
                                                                <span
                                                                    class="text-[10px] font-medium uppercase tracking-widest text-gray-400 italic">Pending
                                                                    Assignment</span>
                                                                <% } %>
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <% if (report.status==='pending' ) { %>
                                                            <span
                                                                class="px-2 py-1 bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-400 rounded text-[10px] font-bold uppercase tracking-widest border border-yellow-200 dark:border-yellow-800">Pending</span>
                                                            <% } else if (report.status==='responding' ) { %>
                                                                <span
                                                                    class="px-2 py-1 bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 rounded text-[10px] font-bold uppercase tracking-widest border border-blue-200 dark:border-blue-800">Responding</span>
                                                                <% } else if (report.status==='resolved' ) { %>
                                                                    <span
                                                                        class="px-2 py-1 bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 rounded text-[10px] font-bold uppercase tracking-widest border border-emerald-200 dark:border-emerald-800">Resolved</span>
                                                                    <% } else if (report.status==='cancelled by user' )
                                                                        { %>
                                                                        <span
                                                                            class="px-2 py-1 bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400 rounded text-[10px] font-bold uppercase tracking-widest border border-red-200 dark:border-red-800">Usr
                                                                            Cancel</span>
                                                                        <% } else if
                                                                            (report.status==='cancelled by admin' ) { %>
                                                                            <span
                                                                                class="px-2 py-1 bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400 rounded text-[10px] font-bold uppercase tracking-widest border border-red-200 dark:border-red-800">Op
                                                                                Cancel</span>
                                                                            <% } else if (report.status==='cancelled' )
                                                                                { %>
                                                                                <span
                                                                                    class="px-2 py-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded text-[10px] font-bold uppercase tracking-widest border border-gray-200 dark:border-gray-700">Cancelled</span>
                                                                                <% } %>
                                                    </td>
                                                    <td
                                                        class="px-6 py-4 text-xs font-bold text-indigo-600 dark:text-indigo-400">
                                                        <%= report.resolved_by || '-' %>
                                                    </td>
                                                    <td
                                                        class="px-6 py-4 text-[10px] text-gray-500 dark:text-gray-400 max-w-[150px]">
                                                        <div class="truncate"
                                                            title="Op: <%= report.responder_message || '-' %> | Usr: <%= report.user_message || '-' %>">
                                                            <div class="truncate mb-0.5"><span
                                                                    class="font-bold text-gray-700 dark:text-gray-300">OP:</span>
                                                                <%= report.responder_message || '-' %>
                                                            </div>
                                                            <div class="truncate"><span
                                                                    class="font-bold text-indigo-500 dark:text-indigo-400">US:</span>
                                                                <%= report.user_message || '-' %>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <div class="flex flex-col gap-1.5">
                                                            <% if (report.status==='pending' ) { %>
                                                                <button onclick="markResolved(<%= report.id %>)"
                                                                    class="px-2 py-1 bg-emerald-500 hover:bg-emerald-600 text-white rounded text-[10px] font-bold uppercase tracking-widest transition-colors w-full text-center">Resolve</button>
                                                                <button onclick="cancelReport(<%= report.id %>)"
                                                                    class="px-2 py-1 bg-white dark:bg-gray-800 hover:bg-red-50 dark:hover:bg-red-900/30 text-red-600 dark:text-red-400 rounded text-[10px] font-bold uppercase tracking-widest border border-red-200 dark:border-red-800 transition-colors w-full text-center">Cancel</button>
                                                                <% } else if (report.status==='responding' ) { %>
                                                                    <% if (!report.user_confirmed_at) { %>
                                                                        <button onclick="markResolved(<%= report.id %>)"
                                                                            class="px-2 py-1 bg-emerald-500 hover:bg-emerald-600 text-white rounded text-[10px] font-bold uppercase tracking-widest transition-colors w-full text-center">Resolve</button>
                                                                        <% } else { %>
                                                                            <span
                                                                                class="text-[10px] font-medium text-gray-400 italic text-center block">Standby...</span>
                                                                            <% } %>
                                                                                <% } else { %>
                                                                                    <span
                                                                                        class="text-gray-300 dark:text-gray-600 text-center block w-full">-</span>
                                                                                    <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="8" class="px-6 py-12 text-center">
                                                                <div class="text-gray-300 dark:text-gray-600 mb-3"><i
                                                                        class="fa fa-clipboard-list text-4xl"></i></div>
                                                                <span
                                                                    class="text-sm font-medium text-gray-500 dark:text-gray-400">Archive
                                                                    is empty. No operations recorded.</span>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                // Use glassmorphism theme for SweetAlert globally in this view
                const GlassSwal = Swal.mixin({
                    customClass: {
                        popup: 'glass-swal',
                        confirmButton: 'rounded-lg px-4 py-2 font-bold uppercase tracking-widest text-xs',
                        cancelButton: 'rounded-lg px-4 py-2 font-bold uppercase tracking-widest text-xs'
                    },
                    background: document.documentElement.classList.contains('dark') ? 'rgba(17, 24, 39, 0.9)' : 'rgba(255, 255, 255, 0.9)',
                    color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                });

                // Real-time Poll for Reports
                let previousReportsJSON = '';

        // Initialize status
        <%
                    let initialStatus = 'none';
                let jsActive = reports.find(r => r.status === 'responding' || r.status === 'pending');
                if (jsActive) { initialStatus = jsActive.status; }
        %>
                    let currentPageStatus = "<%= initialStatus %>";

                // Logic relies on UI reload on status change for cleanly re-hydrating Alpine/Tailwind state.
                function pollReports() {
                    fetch('/api/my-reports-list')
                        .then(res => res.json())
                        .then(reports => {
                            const currentJSON = JSON.stringify(reports);
                            if (currentJSON === previousReportsJSON) return; // No change
                            previousReportsJSON = currentJSON;

                            // CHECK FOR STATUS CHANGE (Active Report Section)
                            const latestActive = reports.find(r => r.status === 'responding' || r.status === 'pending');
                            const newStatus = latestActive ? latestActive.status : 'none';

                            if (newStatus !== currentPageStatus) {
                                console.log("Status changed. Reloading...");
                                location.reload();
                                return;
                            }

                            // We only update the table dynamically here, active section is handled by reload/checkStatus
                        })
                        .catch(err => console.error(err));
                }

                setInterval(pollReports, 3000);

                function cancelReport(id) {
                    GlassSwal.fire({
                        title: '<span class="text-xl font-black uppercase tracking-tight text-red-500">Abort Operation?</span>',
                        html: '<span class="text-sm font-medium">Are you certain you wish to cancel this dispatch request?</span>',
                        icon: 'warning',
                        iconColor: '#ef4444',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#6b7280',
                        confirmButtonText: 'CONFIRM ABORT',
                        cancelButtonText: 'KEEP ACTIVE'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            fetch('/api/cancel_report', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ id: id })
                            }).then(res => res.json()).then(data => {
                                if (data.success) {
                                    GlassSwal.fire({
                                        icon: 'success',
                                        title: '<span class="font-black">ABORTED</span>',
                                        showConfirmButton: false,
                                        timer: 1500
                                    }).then(() => location.reload());
                                } else {
                                    GlassSwal.fire('Error', 'Failed to cancel.', 'error');
                                }
                            });
                        }
                    })
                }

                function markResolved(id) {
                    GlassSwal.fire({
                        title: '<span class="text-xl font-black uppercase tracking-tight text-emerald-500">Confirm Resolution</span>',
                        html: '<span class="text-sm font-medium text-gray-500 dark:text-gray-400">Provide final debriefing remarks for the operational log:</span>',
                        input: 'textarea',
                        inputPlaceholder: 'Type your feedback here...',
                        inputAttributes: { 'aria-label': 'Type your feedback here' },
                        icon: 'question',
                        iconColor: '#10b981',
                        showCancelButton: true,
                        confirmButtonText: 'SUBMIT DEBRIEF',
                        cancelButtonText: 'CANCEL',
                        confirmButtonColor: '#10b981',
                        cancelButtonColor: '#6b7280',
                        showLoaderOnConfirm: true,
                        customClass: Object.assign({}, GlassSwal.params.customClass, {
                            input: 'bg-white/50 dark:bg-gray-800/50 border border-gray-300 dark:border-gray-600 rounded-xl text-sm font-medium focus:ring-emerald-500 focus:border-emerald-500'
                        }),
                        preConfirm: (feedback) => {
                            if (!feedback) {
                                Swal.showValidationMessage('Feedback cannot be empty');
                                return false;
                            }
                            return fetch('/api/resolve', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ incidentId: id, remarks: feedback })
                            })
                                .then(response => {
                                    if (!response.ok) throw new Error(response.statusText)
                                    return response.json()
                                })
                                .catch(error => {
                                    Swal.showValidationMessage(`Request failed: ${error}`)
                                })
                        },
                        allowOutsideClick: () => !Swal.isLoading()
                    }).then((result) => {
                        if (result.isConfirmed && result.value.success) {
                            let msg = result.value.status === 'resolved'
                                ? 'Operation fully resolved and archived.'
                                : 'Awaiting responder counterpart confirmation.';
                            GlassSwal.fire({
                                icon: 'success',
                                title: '<span class="font-black">LOGGED</span>',
                                html: `<span class="text-sm font-medium text-gray-500">${msg}</span>`,
                                confirmButtonColor: '#10b981'
                            }).then(() => location.reload());
                        }
                    })
                }

                // MAP TRACKING LOGIC
                let trackMapEl = document.getElementById('trackMap');
                let mapInstance = null;
                let responderMarker = null;
                let routingControl = null;

                function initTrackMap(userLat, userLng, responderId) {
                    if (mapInstance) { mapInstance.off(); mapInstance.remove(); }

                    trackMapEl = document.getElementById('trackMap');
                    if (!trackMapEl) return;

                    mapInstance = L.map('trackMap', { zoomControl: false }).setView([userLat, userLng], 14);
                    L.control.zoom({ position: 'bottomright' }).addTo(mapInstance);

                    // Subtle darkish map tiles matching the theme better
                    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                        attribution: '&copy; OpenStreetMap | Carto'
                    }).addTo(mapInstance);

                    // User Marker - Pulse effect
                    const userIconHtml = `
                <div class="relative flex h-6 w-6">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-6 w-6 border-2 border-white bg-indigo-500 flex items-center justify-center">
                        <i class="fa fa-user" style="font-size: 10px; color: white;"></i>
                    </span>
                </div>
            `;
                    const uIcon = L.divIcon({ className: 'bg-transparent', html: userIconHtml, iconSize: [24, 24], iconAnchor: [12, 12] });
                    L.marker([userLat, userLng], { icon: uIcon }).addTo(mapInstance).bindPopup("<b class='font-bold text-xs uppercase'>Your Signal</b>", { className: 'glass-popup' });

                    trackResponderOnMap(mapInstance, responderId, userLat, userLng);
                }

                function trackResponderOnMap(map, rId, uLat, uLng) {
                    function pollLoc() {
                        fetch(`/api/responder-track/${rId}`)
                            .then(res => res.json())
                            .then(d => {
                                if (d.latitude && d.longitude) {
                                    if (!responderMarker) {
                                        const respIconHtml = `
                                    <div class="relative flex h-8 w-8">
                                        <span class="absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-20 animate-ping"></span>
                                        <span class="relative shadow-lg inline-flex rounded-full h-8 w-8 border-2 border-white bg-yellow-500 flex items-center justify-center pt-0.5">
                                            <i class="fa fa-ambulance shadow-sm" style="font-size: 14px; color: white;"></i>
                                        </span>
                                    </div>
                                `;
                                        const icon = L.divIcon({ className: 'bg-transparent', html: respIconHtml, iconSize: [32, 32], iconAnchor: [16, 16] });
                                        responderMarker = L.marker([d.latitude, d.longitude], { icon: icon, zIndexOffset: 1000 }).addTo(map).bindPopup("<b class='font-bold text-xs uppercase'>Operative inbound</b>", { className: 'glass-popup' });
                                    } else {
                                        responderMarker.setLatLng([d.latitude, d.longitude]);
                                    }

                                    if (routingControl) {
                                        routingControl.setWaypoints([L.latLng(d.latitude, d.longitude), L.latLng(uLat, uLng)]);
                                    } else {
                                        routingControl = L.Routing.control({
                                            waypoints: [L.latLng(d.latitude, d.longitude), L.latLng(uLat, uLng)],
                                            lineOptions: { styles: [{ color: '#f59e0b', opacity: 0.8, weight: 5, dashArray: '10, 10', className: 'animate-route' }] },
                                            show: false, addWaypoints: false, draggableWaypoints: false, fitSelectedRoutes: false,
                                            createMarker: function () { return null; }
                                        }).addTo(map);
                                    }
                                }
                            }).catch(e => console.warn("Tracking:", e));
                    }
                    pollLoc();
                    setInterval(pollLoc, 3000);
                }

                // Initialize map on load if container exists
                if (document.getElementById('trackMap')) {
                    const uLt = parseFloat(document.getElementById('userLat').value);
                    const uLn = parseFloat(document.getElementById('userLng').value);
                    const rId = document.getElementById('responderId').value;
                    initTrackMap(uLt, uLn, rId);
                }
            </script>
</body>

</html>