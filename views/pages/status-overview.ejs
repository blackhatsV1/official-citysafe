<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body class="app">
  <%- include('../partials/page-start'); %>

    <header class="app-header fixed-top">
      <%- include('../partials/admin-navbar'); %>
        <%- include('../partials/admin-sidebar'); %>
    </header>

    <div class="app-wrapper">
      <div class="app-content pt-3 p-md-3 p-lg-4">
        <div class="container-xl">
          <h1 class="app-page-title">Status Overview</h1>

          <div class="row g-4 mb-4">
            <!-- Responders Status Table -->
            <div class="col-12 col-xl-6">
              <div class="app-card app-card-orders-table shadow-sm mb-5 h-100">
                <div class="app-card-header p-3 border-bottom-0">
                  <h4 class="app-card-title">Responders Status</h4>
                </div>
                <div class="app-card-body p-3 pt-0">
                  <div class="table-responsive">
                    <table class="table app-table-hover mb-0 text-left">
                      <thead>
                        <tr>
                          <th class="cell">Responder</th>
                          <th class="cell">Station</th>
                          <th class="cell">Session</th>
                          <th class="cell">Duty Status</th>
                          <th class="cell">Contact</th>
                        </tr>
                      </thead>
                      <tbody id="responders-tbody">
                        <% responders.forEach(r=> { %>
                          <tr data-id="<%= r.id %>" data-role="responder">
                            <td class="cell">
                              <%= r.firstname %>
                                <%= r.lastname %>
                            </td>
                            <td class="cell">
                              <%= r.station_name || 'Unassigned' %>
                            </td>
                            <td class="cell">
                              <span class="badge <%= r.status !== 'offline' ? 'bg-success' : 'bg-secondary' %>">
                                <%= r.status !=='offline' ? 'logged in' : 'logged out' %>
                              </span>
                            </td>
                            <td class="cell">
                              <span class="badge <%= r.status === 'deployed' ? 'bg-warning' : 'bg-primary' %>">
                                <%= r.status==='deployed' ? 'deployed' : 'active' %>
                              </span>
                            </td>
                            <td class="cell">
                              <%= r.contact_number %>
                            </td>
                          </tr>
                          <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>

            <!-- Users Status Table -->
            <div class="col-12 col-xl-6">
              <div class="app-card app-card-orders-table shadow-sm mb-5 h-100">
                <div class="app-card-header p-3 border-bottom-0">
                  <h4 class="app-card-title">Users Status</h4>
                </div>
                <div class="app-card-body p-3 pt-0">
                  <div class="table-responsive">
                    <table class="table app-table-hover mb-0 text-left">
                      <thead>
                        <tr>
                          <th class="cell">User</th>
                          <th class="cell">Location</th>
                          <th class="cell">Status</th>
                          <th class="cell">Contact</th>
                        </tr>
                      </thead>
                      <tbody id="users-tbody">
                        <% users.forEach(u=> { %>
                          <tr data-id="<%= u.id %>" data-role="user">
                            <td class="cell">
                              <%= u.firstname %>
                                <%= u.lastname %>
                            </td>
                            <td class="cell">
                              <%= u.barangay %>, <%= u.city %>
                            </td>
                            <td class="cell">
                              <span class="badge <%= u.status !== 'offline' ? 'bg-success' : 'bg-secondary' %>">
                                <%= u.status !=='offline' ? 'logged in' : 'logged out' %>
                              </span>
                            </td>
                            <td class="cell">
                              <%= u.contact_number %>
                            </td>
                          </tr>
                          <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%- include('../partials/footer'); %>
    </div>

    <%- include('../partials/page-end'); %>
      <script src="/js/script.js"></script>
      <script>
        async function updateStatuses() {
          try {
            const response = await fetch('/api/status-overview');
            const data = await response.json();

            // Rebuild Responders Table
            const respTbody = document.getElementById('responders-tbody');
            let respHtml = '';
            data.responders.forEach(r => {
              const sessionClass = r.status !== 'offline' ? 'bg-success' : 'bg-secondary';
              const sessionText = r.status !== 'offline' ? 'logged in' : 'logged out';

              const dutyClass = r.status === 'deployed' ? 'bg-warning' : 'bg-primary';
              const dutyText = r.status === 'deployed' ? 'deployed' : 'active';

              respHtml += `
                        <tr data-id="${r.id}" data-role="responder">
                            <td class="cell">${r.firstname} ${r.lastname}</td>
                            <td class="cell">${r.station_name || 'Unassigned'}</td>
                            <td class="cell"><span class="badge ${sessionClass}">${sessionText}</span></td>
                            <td class="cell"><span class="badge ${dutyClass}">${dutyText}</span></td>
                            <td class="cell">${r.contact_number}</td>
                        </tr>
                    `;
            });
            if (respTbody) respTbody.innerHTML = respHtml;

            // Rebuild Users Table
            const userTbody = document.getElementById('users-tbody');
            let userHtml = '';
            data.users.forEach(u => {
              const statusClass = u.status !== 'offline' ? 'bg-success' : 'bg-secondary';
              const statusText = u.status !== 'offline' ? 'logged in' : 'logged out';

              userHtml += `
                        <tr data-id="${u.id}" data-role="user">
                            <td class="cell">${u.firstname} ${u.lastname}</td>
                            <td class="cell">${u.barangay}, ${u.city}</td>
                            <td class="cell"><span class="badge ${statusClass}">${statusText}</span></td>
                            <td class="cell">${u.contact_number}</td>
                        </tr>
                    `;
            });
            if (userTbody) userTbody.innerHTML = userHtml;

          } catch (error) {
            console.error('Error fetching statuses:', error);
          }
        }

        // Poll every 5 seconds
        setInterval(updateStatuses, 5000);
      </script>
</body>

</html>