<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
    <!-- openweather api key -->
    <script>
      const apiKey = "<%= apiKey %>";
    </script>
</head>

<body class="app">
  <%- include('../partials/page-start'); %>

    <header class="app-header fixed-top">
      <%- include('../partials/user-navbar'); %>
        <%- include('../partials/user-sidebar'); %>
    </header>

    <div class="app-wrapper">
      <div class="app-content pt-3 p-md-3 p-lg-4">
        <div class="container-xl">
          <div class="row g-4 mb-4">
            <div class="col-12">
              <div class="app-card app-card-settings shadow-sm p-4">
                <div class="app-card-body text-center">
                  <h1 class="mb-3 text-primary"><i class="bi bi-cloud-sun me-2"></i>Welcome to CitySafe!</h1>
                  <hr class="mb-4">
                  <p id="address" class="lead fw-bold text-muted">Loading Address...</p>
                  <p id="coords" class="small text-secondary"></p>
                  <div class="bg-light rounded p-3 mt-3 d-inline-block shadow-sm" id="weather-info">
                    Loading weather data...
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-4">
            <div class="col-12 col-lg-6">
              <div class="app-card app-card-basic shadow-sm h-100">
                <div class="app-card-header p-3 border-bottom-0">
                  <h4 class="app-card-title">Live Weather View</h4>
                </div>
                <div class="app-card-body p-3">
                  <div id="weather-map" class="rounded" style="height: 400px; width: 100%;"></div>
                </div>
              </div>
            </div>
            <div class="col-12 col-lg-6">
              <div class="app-card app-card-basic shadow-sm h-100">
                <div class="app-card-header p-3 border-bottom-0">
                  <h4 class="app-card-title">Live Location</h4>
                </div>
                <div class="app-card-body p-3 text-center">
                  <div id="map" class="rounded mb-3" style="height: 350px; width: 100%;"></div>
                  <%- include('../partials/selectloc-visitor'); %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%- include('../partials/footer'); %>
    </div>

    <%- include('../partials/page-end'); %>
      <script src="/js/script.js"></script>
</body>

</html>

