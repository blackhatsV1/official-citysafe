<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
    <!-- openweather api key -->
    <script>
      const apiKey = "<%= apiKey %>";
    </script>

</head>

<body>
  <%- include('../partials/page-start'); %>

    <header>
      <%- include('../partials/user-navbar', { currentPage: 'weather' }); %>
    </header>

    <div>
      <aside>
        <%- include('../partials/user-sidebar', { currentPage: 'weather' }); %>
      </aside>

      <main>
        <div>

          <div>
            <div>
              <i></i>
            </div>
            <h1>Meteorological
              Data</h1>
          </div>

          <div>
            <!-- Glow -->
            <div>
            </div>

            <div>
              <h2>
                <i></i> Localized Weather Scan
              </h2>
              <div>
                <div></div>
              </div>

              <div>
                <h5 id="address">Acquiring Location...
                </h5>
                <p id="coords"></p>

                <div
                  id="weather-info">
                  <i></i> Syncing atmospheric data...
                </div>
              </div>
            </div>
          </div>

          <div>

            <!-- Weather Map -->
            <div>
              <div>
                <h4>
                  <i></i> Radar Overlay
                </h4>
              </div>
              <div>
                <div id="weather-map"></div>
              </div>
            </div>

            <!-- Live Location -->
            <div>
              <div>
                <h4>
                  <i></i> Live Positional Tracking
                </h4>
              </div>
              <div>
                <div id="map">
                </div>
                <div>
                  <%- include('../partials/selectloc-visitor'); %>
                </div>
              </div>
            </div>

          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>
      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
      <script src="/js/script.js"></script>
      <%- include('../partials/page-end'); %>
</body>

</html>