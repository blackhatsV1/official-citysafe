<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
    <!-- openweather api key -->
    <script>
      const apiKey = "<%= apiKey %>";
    </script>

</head>

<body>
  <%- include('../partials/page-start'); %>

    <header>
      <%- include('../partials/user-navbar', { currentPage: 'weather' }); %>
    </header>

    <div class="cs-layout-container">
      <aside>
        <%- include('../partials/user-sidebar', { currentPage: 'weather' }); %>
      </aside>

      <main class="cs-main-content">
        <div class="cs-container">

          <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 3rem;">
            <div class="cs-badge"
              style="width: 64px; height: 64px; font-size: 1.5rem; background: var(--info-glow); color: var(--info); border: 2px solid var(--info);">
              <i class="fa-solid fa-cloud-sun-rain"></i>
            </div>
            <h1 class="cs-section-header" style="margin: 0;">
              METEOROLOGICAL <span
                style="background: linear-gradient(135deg, var(--info) 0%, var(--accent) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">DATA</span>
            </h1>
          </div>

          <!-- Main Weather Display -->
          <div class="cs-card" style="margin-bottom: 3rem; padding: 3rem; position: relative; overflow: hidden;">
            <div
              style="position: absolute; top: -100px; right: -100px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(14, 165, 233, 0.1) 0%, transparent 70%); border-radius: 50%; pointer-events: none;">
            </div>

            <div style="position: relative; z-index: 1; display: flex; flex-direction: column; gap: 2rem;">
              <div
                style="display: flex; align-items: center; gap: 1rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.5rem;">
                <div class="cs-badge" style="background: var(--primary-glow); color: var(--primary);"><i
                    class="fa-solid fa-satellite"></i></div>
                <h2 style="margin: 0; font-size: 1.5rem; font-weight: 800; color: var(--text-bright);">LOCALIZED WEATHER
                  SCAN</h2>
              </div>

              <div style="display: flex; flex-wrap: wrap; gap: 3rem; align-items: center;">
                <div id="weather-info"
                  style="flex: 1; min-width: 300px; font-size: 1.1rem; color: var(--text-dim); line-height: 1.6;">
                  <i class="fa-solid fa-spinner fa-spin"></i> Syncing atmospheric telemetry from satellite array...
                </div>

                <div class="cs-card"
                  style="background: rgba(0,0,0,0.2); border: 1px solid var(--border-glass); padding: 1.5rem; min-width: 250px;">
                  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                    <i class="fa-solid fa-location-dot" style="color: var(--danger);"></i>
                    <span style="font-weight: 700; color: var(--text-bright);">CURRENT POSITION</span>
                  </div>
                  <div id="address"
                    style="font-size: 0.9rem; color: var(--text-bright); margin-bottom: 0.5rem; font-weight: 600;">
                    Acquiring Location...</div>
                  <div id="coords"
                    style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--primary);">0.0000,
                    0.0000</div>
                </div>
              </div>
            </div>
          </div>

          <div class="cs-grid cs-grid-2">
            <!-- Weather Map -->
            <div class="cs-card" style="padding: 1.5rem;">
              <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-radar" style="color: var(--info);"></i>
                <h4 style="margin: 0; font-size: 1rem; font-weight: 700;">RADAR OVERLAY</h4>
              </div>
              <div class="cs-map-container" id="weather-map" style="height: 400px; border-radius: 1rem;"></div>
            </div>

            <!-- Live Location -->
            <div class="cs-card" style="padding: 1.5rem;">
              <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-crosshairs" style="color: var(--primary);"></i>
                <h4 style="margin: 0; font-size: 1rem; font-weight: 700;">POSITIONAL TRACKING</h4>
              </div>
              <div class="cs-map-container" id="map" style="height: 340px; border-radius: 1rem; margin-bottom: 1rem;">
              </div>
              <div
                style="background: rgba(255,255,250,0.02); border: 1px solid var(--border-glass); padding: 0.5rem; border-radius: 0.75rem;">
                <%- include('../partials/selectloc-visitor'); %>
              </div>
            </div>
          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>
      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
      <script src="/js/script.js"></script>
      <%- include('../partials/page-end'); %>
</body>

</html>