<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/user-navbar', { currentPage: 'sos' }); %>
        </header>

        <div>
            <aside>
                <%- include('../partials/user-sidebar', { currentPage: 'sos' }); %>
            </aside>

            <main>
                <div>

                    <h1>
                        <i></i> SOS DISPATCH
                    </h1>

                    <div>

                        <!-- Location Selection Area -->
                        <div>
                            <div>
                                <div>
                                    <i></i>
                                </div>
                                <h2>
                                    Operational Coordinates</h2>
                            </div>
                            <div>
                                <!-- The map partial -->
                                <%- include('../partials/selectloc'); %>
                            </div>
                        </div>

                        <!-- Dispatch Request Form -->
                        <div>
                            <!-- Alert Pulse Background -->
                            <div>
                            </div>

                            <div>
                                <div>
                                    <i></i>
                                </div>
                                <h2>
                                    Emergency Dispatch Request</h2>
                            </div>

                            <div>
                                <form action="/report" method="POST" id="sosForm" autocomplete="off">

                                    <p>
                                        Select the nature of the emergency. Dispatch operations will be initiated
                                        sequentially to your verified coordinates.
                                    </p>

                                    <input type="hidden" name="type_of_disaster" id="selected_disaster_type">

                                    <div>
                                        <% [ { type: 'Fire' , icon: 'fa-fire' , label: 'FIRE' , color: 'red' }, {
                                            type: 'Flood' , icon: 'fa-water' , label: 'FLOOD' , color: 'blue' }, {
                                            type: 'Earthquake' , icon: 'fa-globe-americas' , label: 'QUAKE' ,
                                            color: 'yellow' }, { type: 'Landslide' , icon: 'fa-mountain' ,
                                            label: 'LANDSLIDE' , color: 'stone' } ].forEach(emergency=> { %>
                                            <!-- Using Tailwind variables for colors mapping from original EJS data -->
                                            <% let borderHover="hover:border-red-400 dark:hover:border-red-500" ; let
                                                bgHover="hover:bg-red-50 dark:hover:bg-red-900/20" ; let
                                                iconBg="bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400" ;
                                                let textHover="group-hover:text-red-600 dark:group-hover:text-red-400" ;
                                                if(emergency.color==='blue' ) {
                                                borderHover="hover:border-blue-400 dark:hover:border-blue-500" ;
                                                bgHover="hover:bg-blue-50 dark:hover:bg-blue-900/20" ;
                                                iconBg="bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400"
                                                ; textHover="group-hover:text-blue-600 dark:group-hover:text-blue-400" ;
                                                } else if(emergency.color==='yellow' ) {
                                                borderHover="hover:border-yellow-400 dark:hover:border-yellow-500" ;
                                                bgHover="hover:bg-yellow-50 dark:hover:bg-yellow-900/20" ;
                                                iconBg="bg-yellow-100 dark:bg-yellow-900/40 text-yellow-600 dark:text-yellow-400"
                                                ;
                                                textHover="group-hover:text-yellow-600 dark:group-hover:text-yellow-400"
                                                ; } else if(emergency.color==='stone' ) {
                                                borderHover="hover:border-stone-400 dark:hover:border-stone-500" ;
                                                bgHover="hover:bg-stone-50 dark:hover:bg-stone-900/20" ;
                                                iconBg="bg-stone-100 dark:bg-stone-800/80 text-stone-700 dark:text-stone-300"
                                                ; textHover="group-hover:text-stone-700 dark:group-hover:text-stone-400"
                                                ; } %>
                                                <button type="button"
                                                    onclick="triggerSosReport('<%= emergency.type %>')">
                                                    <div>
                                                        <i></i>
                                                    </div>
                                                    <span>
                                                        <%= emergency.label %>
                                                    </span>
                                                </button>
                                                <% }) %>
                                    </div>

                                    <div>
                                        <label>Verified
                                            Dispatch Address</label>
                                        <div>
                                            <div>
                                                <i></i>
                                            </div>
                                            <textarea id="location" name="location" rows="3"
                                                placeholder="Acquiring satellite lock..." required readonly></textarea>
                                        </div>
                                        <input type="hidden" id="lat" name="lat">
                                        <input type="hidden" id="lon" name="lon">
                                    </div>

                                    <button type="submit" disabled></button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                function triggerSosReport(type) {
                    const input = document.getElementById('selected_disaster_type');
                    if (input) input.value = type;

                    const locField = document.getElementById('location');
                    if (!locField.value || locField.value.trim() === "" || locField.value.includes('Acquiring') || locField.value.includes('Waiting for location')) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Awaiting Location',
                            text: 'Satellite signal is still being processed. Please wait to ensure accurate dispatch.',
                            confirmButtonColor: '#4f46e5',
                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                        });
                        return;
                    }

                    // Type icon/color mapping for SweetAlert
                    let iconHtml = '<i></i>';
                    if (type === 'Fire') { iconHtml = '<i></i>'; }
                    if (type === 'Flood') { iconHtml = '<i></i>'; }
                    if (type === 'Earthquake') { iconHtml = '<i></i>'; }
                    if (type === 'Landslide') { iconHtml = '<i></i>'; }

                    Swal.fire({
                        title: `<span>INITIATE DISPATCH?</span>`,
                        html: `
                    <div>${iconHtml}</div>
                    <p>You are requesting emergency response for a <strong>${type.toUpperCase()}</strong> incident.</p>
                `,
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#6b7280',
                        confirmButtonText: '<span>CONFIRM & SEND</span>',
                        cancelButtonText: '<span>CANCEL</span>',
                        reverseButtons: true,
                        background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                        color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827',
                        customClass: { confirmButton: 'shadow-lg shadow-red-500/50' }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            Swal.fire({
                                title: 'Transmitting...',
                                text: 'Sending your distress protocol.',
                                allowOutsideClick: false,
                                showConfirmButton: false,
                                background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                                color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827',
                                didOpen: () => { Swal.showLoading() }
                            });
                            document.getElementById('sosForm').submit();
                        }
                    });
                }
            </script>
</body>

</html>