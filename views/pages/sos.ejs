<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/user-navbar', { currentPage: 'sos' }); %>
        </header>

        <div class="cs-layout-container">
            <aside>
                <%- include('../partials/user-sidebar', { currentPage: 'sos' }); %>
            </aside>

            <main class="cs-main-content">
                <div class="cs-container">

                    <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 3rem;">
                        <div class="cs-badge"
                            style="width: 64px; height: 64px; font-size: 1.5rem; background: var(--danger-glow); color: var(--danger); border: 2px solid var(--danger); animation: pulse 2s infinite;">
                            <i class="fa-solid fa-signal-stream"></i>
                        </div>
                        <h1 class="cs-section-header" style="margin: 0;">
                            SOS <span
                                style="background: linear-gradient(135deg, var(--danger) 0%, #ff6b6b 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">DISPATCH</span>
                        </h1>
                    </div>

                    <div class="cs-grid cs-grid-2">

                        <!-- Location Selection Area -->
                        <div class="cs-card" style="padding: 1.5rem;">
                            <div
                                style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem;">
                                <div class="cs-badge" style="background: var(--info-glow); color: var(--info);"><i
                                        class="fa-solid fa-map-location-dot"></i></div>
                                <h2 style="margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-bright);">
                                    OPERATIONAL COORDINATES</h2>
                            </div>
                            <div class="cs-map-container" style="height: 400px; border-radius: 1rem;">
                                <!-- The map partial -->
                                <%- include('../partials/selectloc'); %>
                            </div>
                        </div>

                        <!-- Dispatch Request Form -->
                        <div class="cs-card" style="padding: 2.5rem; position: relative; overflow: hidden;">
                            <!-- Alert Pulse Background -->
                            <div
                                style="position: absolute; top: -50px; left: -50px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(239, 68, 68, 0.05) 0%, transparent 70%); border-radius: 50%; pointer-events: none;">
                            </div>

                            <div
                                style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.5rem;">
                                <div class="cs-badge" style="background: var(--danger-glow); color: var(--danger);"><i
                                        class="fa-solid fa-burst"></i></div>
                                <h2 style="margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-bright);">
                                    EMERGENCY DISPATCH</h2>
                            </div>

                            <form action="/report" method="POST" id="sosForm" autocomplete="off"
                                style="display: flex; flex-direction: column; gap: 2.5rem;">
                                <p style="font-size: 0.95rem; color: var(--text-dim); line-height: 1.6; margin: 0;">
                                    Select the nature of the emergency. Dispatch operations will be initiated
                                    sequentially to your verified coordinates.
                                </p>

                                <input type="hidden" name="type_of_disaster" id="selected_disaster_type">

                                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
                                    <% [ { type: 'Fire' , icon: 'fa-fire' , label: 'FIRE' , color: 'var(--danger)' ,
                                        glow: 'var(--danger-glow)' }, { type: 'Flood' , icon: 'fa-droplet' ,
                                        label: 'FLOOD' , color: 'var(--info)' , glow: 'var(--info-glow)' }, {
                                        type: 'Earthquake' , icon: 'fa-house-crack' , label: 'QUAKE' ,
                                        color: 'var(--warning)' , glow: 'var(--warning-glow)' }, { type: 'Landslide' ,
                                        icon: 'fa-mountain' , label: 'LANDSLIDE' , color: 'var(--accent)' ,
                                        glow: 'var(--accent-glow)' } ].forEach(emergency=> { %>
                                        <button type="button" onclick="triggerSosReport('<%= emergency.type %>')"
                                            style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass); border-radius: 1rem; padding: 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); color: var(--text-bright); overflow: hidden; position: relative;"
                                            onmouseover="this.style.background='rgba(255,255,255,0.08)'; this.style.borderColor='<%= emergency.glow %>'; this.style.transform='translateY(-2px)'"
                                            onmouseout="this.style.background='rgba(255,255,255,0.03)'; this.style.borderColor='var(--border-glass)'; this.style.transform='translateY(0)'">
                                            <div class="cs-badge"
                                                style="width: 48px; height: 48px; font-size: 1.25rem; background: rgba(255,255,255,0.05); color: <%= emergency.color %>; border: 1px solid <%= emergency.glow %>;">
                                                <i class="fa-solid <%= emergency.icon %>"></i>
                                            </div>
                                            <span style="font-size: 0.8rem; font-weight: 800; letter-spacing: 0.1rem;">
                                                <%= emergency.label %>
                                            </span>
                                        </button>
                                        <% }) %>
                                </div>

                                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                                    <label
                                        style="font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase; letter-spacing: 0.05rem;">VERIFIED
                                        DISPATCH ADDRESS</label>
                                    <div style="position: relative;">
                                        <div
                                            style="position: absolute; left: 1rem; top: 1.25rem; color: var(--primary);">
                                            <i class="fa-solid fa-location-crosshairs fa-spin-pulse"></i>
                                        </div>
                                        <textarea id="location" name="location" rows="3"
                                            style="width: 100%; background: rgba(0,0,0,0.2); border: 1px solid var(--border-glass); border-radius: 0.75rem; padding: 1rem 1rem 1rem 3rem; color: var(--text-bright); font-size: 0.9rem; line-height: 1.5; resize: none; font-family: 'JetBrains Mono', monospace;"
                                            placeholder="Acquiring satellite lock..." required readonly></textarea>
                                    </div>
                                    <input type="hidden" id="lat" name="lat">
                                    <input type="hidden" id="lon" name="lon">
                                </div>

                                <button type="submit" id="submitBtn" style="display: none;"></button>
                            </form>
                        </div>
                    </div>
                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                function triggerSosReport(type) {
                    const input = document.getElementById('selected_disaster_type');
                    if (input) input.value = type;

                    const locField = document.getElementById('location');
                    if (!locField.value || locField.value.trim() === "" || locField.value.includes('Acquiring') || locField.value.includes('Waiting for location')) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Awaiting Location',
                            text: 'Satellite signal is still being processed. Please wait to ensure accurate dispatch.',
                            confirmButtonColor: '#4f46e5',
                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                        });
                        return;
                    }

                    // Type icon/color mapping for SweetAlert
                    let iconHtml = '<i class="fa-solid fa-triangle-exclamation"></i>';
                    if (type === 'Fire') { iconHtml = '<i class="fa-solid fa-fire"></i>'; }
                    if (type === 'Flood') { iconHtml = '<i class="fa-solid fa-droplet"></i>'; }
                    if (type === 'Earthquake') { iconHtml = '<i class="fa-solid fa-house-crack"></i>'; }
                    if (type === 'Landslide') { iconHtml = '<i class="fa-solid fa-mountain"></i>'; }

                    Swal.fire({
                        title: `<span>INITIATE DISPATCH?</span>`,
                        html: `
                    <div>${iconHtml}</div>
                    <p>You are requesting emergency response for a <strong>${type.toUpperCase()}</strong> incident.</p>
                `,
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#6b7280',
                        confirmButtonText: '<span>CONFIRM & SEND</span>',
                        cancelButtonText: '<span>CANCEL</span>',
                        reverseButtons: true,
                        background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                        color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827',
                        customClass: { confirmButton: 'shadow-lg shadow-red-500/50' }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            Swal.fire({
                                title: 'Transmitting...',
                                text: 'Sending your distress protocol.',
                                allowOutsideClick: false,
                                showConfirmButton: false,
                                background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                                color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827',
                                didOpen: () => { Swal.showLoading() }
                            });
                            document.getElementById('sosForm').submit();
                        }
                    });
                }
            </script>
</body>

</html>