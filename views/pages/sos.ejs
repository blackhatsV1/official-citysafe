<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <!-- removed non-map styling -->
</head>

<body class="app">
    <%- include('../partials/page-start'); %>

        <header class="app-header fixed-top">
            <%- include('../partials/user-navbar'); %>
                <%- include('../partials/user-sidebar'); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <h1 class="app-page-title text-danger"><i class="fa fa-triangle-exclamation me-2"></i>SOS Dispatch
                    </h1>

                    <div class="row g-4 mb-4">
                        <!-- Location Grid -->
                        <div class="col-sm-12 col-xl-6">
                            <div class="app-card app-card-settings shadow-sm h-100 border-top border-4 border-primary">
                                <div class="app-card-header p-3 border-bottom-0 d-flex align-items-center gap-2">
                                    <div class="bg-primary-soft p-2 rounded text-primary">
                                        <i class="fa fa-map-location-dot small"></i>
                                    </div>
                                    <h6 class="mb-0 fw-bold text-uppercase small">Operational Coordinates</h6>
                                </div>
                                <div class="app-card-body p-3 pt-0">
                                    <div class="p-0 flex-grow-1">
                                        <%- include('../partials/selectloc'); %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Dispatch Form -->
                        <div class="col-sm-12 col-xl-6">
                            <div class="app-card app-card-settings shadow-sm h-100 border-top border-4 border-danger">
                                <div class="app-card-header p-3 border-bottom-0 d-flex align-items-center gap-2">
                                    <div class="bg-danger-soft p-2 rounded text-danger">
                                        <i class="fa fa-bullhorn small"></i>
                                    </div>
                                    <h6 class="mb-0 fw-bold text-uppercase small">Emergency Dispatch Request</h6>
                                </div>
                                <div class="app-card-body p-4 pt-0">
                                    <form action="/report" method="POST" id="sosForm" autocomplete="off">
                                        <p class="text-muted small mb-4">Select the nature of the emergency. Dispatch
                                            will be initiated to your verified coordinates immediately.</p>

                                        <input type="hidden" name="type_of_disaster" id="selected_disaster_type">

                                        <div class="row g-3 mb-4">
                                            <% [ { type: 'Fire' , icon: 'fa-fire' , label: 'FIRE' }, { type: 'Flood' ,
                                                icon: 'fa-water' , label: 'FLOOD' }, { type: 'Earthquake' ,
                                                icon: 'fa-globe-americas' , label: 'EARTHQUAKE' }, { type: 'Landslide' ,
                                                icon: 'fa-mountain' , label: 'LANDSLIDE' } ].forEach(emergency=> { %>
                                                <div class="col-6">
                                                    <button type="button"
                                                        onclick="triggerSosReport('<%= emergency.type %>')"
                                                        class="btn app-btn-secondary w-100 h-100 p-4 disaster-btn text-center d-flex flex-column align-items-center gap-3 border shadow-sm transition-hover">
                                                        <div class="avatar-md bg-dark text-white rounded-circle d-flex align-items-center justify-content-center border"
                                                            style="width: 56px; height: 56px;">
                                                            <i class="fa <%= emergency.icon %> fs-3 text-danger"></i>
                                                        </div>
                                                        <span class="fw-bold small letter-spacing-1 text-dark">
                                                            <%= emergency.label %>
                                                        </span>
                                                    </button>
                                                </div>
                                                <% }) %>
                                        </div>

                                        <div class="mb-4">
                                            <label
                                                class="small fw-700 text-uppercase text-muted letter-spacing-1 mb-2 d-block">Verified
                                                Dispatch Address</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border px-3"><i
                                                        class="fa fa-location-arrow text-primary"></i></span>
                                                <textarea class="form-control bg-light" id="location" name="location"
                                                    rows="2" placeholder="Acquiring satellite lock..." required
                                                    readonly></textarea>
                                            </div>
                                            <input type="hidden" id="lat" name="lat">
                                            <input type="hidden" id="lon" name="lon">
                                        </div>

                                        <button type="submit" disabled class="d-none"></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('../partials/footer'); %>
        </div>

        <%- include('../partials/page-end'); %>
            <script>
                function triggerSosReport(type) {
                    const input = document.getElementById('selected_disaster_type');
                    if (input) input.value = type;

                    const loc = document.getElementById('location').value;
                    if (!loc || loc.trim() === "" || loc.includes('Acquiring')) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Awaiting Location',
                            text: 'Satellite signal is still being processed. Please wait to ensure accurate dispatch.',
                            confirmButtonColor: 'var(--bs-primary)'
                        });
                        return;
                    }

                    Swal.fire({
                        title: 'INITIATE DISPATCH?',
                        text: `You are requesting emergency response for a ${type.toUpperCase()} incident.`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#dc3545', // Danger color
                        cancelButtonColor: '#6c757d', // Secondary color
                        confirmButtonText: 'CONFIRM & SEND',
                        reverseButtons: true
                    }).then((result) => {
                        if (result.isConfirmed) {
                            document.getElementById('sosForm').submit();
                        }
                    });
                }
            </script>
</body>

</html>