<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <link rel="stylesheet"
            href="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.css" />
        <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.min.js"></script>

        <style>
            #missionMap {
                height: 450px;
                width: 100%;
            }
        </style>
</head>

<body class="app">
    <%- include('../partials/page-start'); %>
        <header class="app-header fixed-top">
            <%- include('../partials/responder-navbar'); %>
                <%- include('../partials/responder-sidebar'); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <div class="row g-3 mb-4 align-items-center justify-content-between">
                        <div class="col-auto">
                            <h1 class="app-page-title mb-0">Active Response</h1>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <!-- Mission Status Card -->
                        <div class="col-12">
                            <div class="app-card app-card-notification shadow-sm">
                                <div class="app-card-header p-3">
                                    <div class="row justify-content-between align-items-center">
                                        <div class="col-auto">
                                            <h4 class="app-card-title"><i
                                                    class="fa fa-ambulance me-2 text-warning"></i>Mission: <%=
                                                    mission.disaster_type.toUpperCase() %>
                                            </h4>
                                        </div>
                                        <div class="col-auto">
                                            <span class="badge bg-warning text-dark">STATUS: RESPONDING</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="app-card-body p-3">
                                    <div class="alert alert-info border-0 mb-3">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <div>
                                                <h6 class="mb-1">Operational Directive:</h6>
                                                <p class="mb-0 small">Go to the incident location. Once resolved, click
                                                    the button to finalize the response.</p>
                                            </div>
                                            <div id="resolve-btn-container">
                                                <% if (!mission.user_confirmed_at) { %>
                                                    <button class="btn btn-secondary btn-sm" disabled>
                                                        <i class="fa fa-hourglass-half me-2"></i>Waiting for User
                                                        Report...
                                                    </button>
                                                    <% } else { %>
                                                        <button onclick="resolveMission(<%= mission.incident_id %>)"
                                                            class="btn app-btn-primary">
                                                            <i class="fa fa-check-circle me-2"></i>MARK AS RESOLVED
                                                        </button>
                                                        <% } %>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row g-4">
                                        <div class="col-12 col-lg-4">
                                            <div class="p-3 bg-light rounded shadow-sm border h-100">
                                                <h6 class="border-bottom pb-2 mb-3">Unit Intelligence</h6>
                                                <div class="mb-3">
                                                    <small class="text-muted d-block">Reporter Name</small>
                                                    <span class="fw-bold">
                                                        <%= mission.firstname %>
                                                            <%= mission.lastname %>
                                                    </span>
                                                </div>
                                                <div class="mb-3">
                                                    <small class="text-muted d-block">Contact Number</small>
                                                    <span class="fw-bold">
                                                        <%= mission.contact_number %>
                                                    </span>
                                                </div>
                                                <div class="mb-3">
                                                    <small class="text-muted d-block">Address</small>
                                                    <span class="fw-bold small" id="incident-addr">Loading
                                                        address...</span>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block">Coordinates</small>
                                                    <code
                                                        class="small"><%= mission.incident_lat %>, <%= mission.incident_lng %></code>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12 col-lg-8">
                                            <div class="app-card app-card-map shadow-sm">
                                                <div id="missionMap" style="height: 400px; width: 100%;"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Nearby Disasters -->
                        <div class="col-12">
                            <div class="app-card app-card-orders shadow-sm">
                                <div class="app-card-header p-3">
                                    <h4 class="app-card-title">Nearby Incident Awareness</h4>
                                </div>
                                <div class="app-card-body">
                                    <div class="table-responsive">
                                        <table class="table app-table-hover mb-0 text-left">
                                            <thead>
                                                <tr>
                                                    <th class="cell">Date & Time</th>
                                                    <th class="cell">Type</th>
                                                    <th class="cell">Address</th>
                                                    <th class="cell">Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (reports.length> 0) { %>
                                                    <% reports.forEach(function(report) { %>
                                                        <tr>
                                                            <td class="cell small">
                                                                <%= new Date(report.reported_at).toLocaleString() %>
                                                            </td>
                                                            <td class="cell"><span class="badge bg-danger">
                                                                    <%= report.disaster_type %>
                                                                </span></td>
                                                            <td class="cell small addr-load"
                                                                data-lat="<%= report.latitude %>"
                                                                data-lon="<%= report.longitude %>">Loading geographical
                                                                data...</td>
                                                            <td class="cell"><span class="badge bg-info text-dark">
                                                                    <%= report.status %>
                                                                </span></td>
                                                        </tr>
                                                        <% }); %>
                                                            <% } else { %>
                                                                <tr>
                                                                    <td colspan="4" class="text-center py-4 text-muted">
                                                                        No other active reports in your immediate
                                                                        sector.</td>
                                                                </tr>
                                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <footer class="app-footer">
                <%- include('../partials/footer'); %>
            </footer>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            const incidentLat = <%= mission.incident_lat || 'null' %>;
            const incidentLng = <%= mission.incident_lng || 'null' %>;

            if (incidentLat !== null && incidentLng !== null) {
                const map = L.map('missionMap').setView([incidentLat, incidentLng], 13);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);

                L.marker([incidentLat, incidentLng]).addTo(map)
                    .bindPopup("<b>INCIDENT LOCATION</b><br><%= mission.disaster_type %>").openPopup();

                fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${incidentLat}&lon=${incidentLng}`)
                    .then(res => res.json())
                    .then(data => {
                        const addrEl = document.getElementById('incident-addr');
                        if (addrEl) addrEl.innerText = data.display_name || "Address not found";
                    });

                if (navigator.geolocation) {
                    navigator.geolocation.watchPosition(pos => {
                        const myLat = pos.coords.latitude;
                        const myLng = pos.coords.longitude;

                        fetch('/api/responder/location', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ lat: myLat, lng: myLng })
                        });

                        if (!window.routingControl) {
                            window.routingControl = L.Routing.control({
                                waypoints: [L.latLng(myLat, myLng), L.latLng(incidentLat, incidentLng)],
                                lineOptions: { styles: [{ color: '#15a362', opacity: 0.8, weight: 6 }] },
                                createMarker: function (i, wp) {
                                    if (i === 0) return L.marker(wp.latLng).bindPopup("<b>Your Unit</b>");
                                    return null;
                                },
                                addWaypoints: false,
                                draggableWaypoints: false,
                                fitSelectedRoutes: true,
                                show: false
                            }).addTo(map);
                        } else {
                            window.routingControl.setWaypoints([L.latLng(myLat, myLng), L.latLng(incidentLat, incidentLng)]);
                        }
                    }, err => console.error(err), { enableHighAccuracy: true });
                }
            }

            function resolveMission(id) {
                Swal.fire({
                    title: 'Resolve Incident?',
                    text: "Are you sure this incident is resolved? This will notify HQ and the citizen.",
                    icon: 'question',
                    input: 'textarea',
                    inputPlaceholder: 'Enter resolution remarks (e.g., situation stabilized, casualty handled)...',
                    showCancelButton: true,
                    confirmButtonColor: '#15a362',
                    confirmButtonText: 'Confirm Resolution'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const remarks = result.value || "Resolved by responding unit";
                        fetch('/api/resolve', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ incidentId: id, remarks: remarks })
                        })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    Swal.fire('Success', 'Response logged. Waiting for final verification.', 'success')
                                        .then(() => location.reload());
                                } else {
                                    Swal.fire('Error', 'Failed to update mission status', 'error');
                                }
                            });
                    }
                });
            }

            document.querySelectorAll('.addr-load').forEach(td => {
                const lat = td.getAttribute('data-lat');
                const lon = td.getAttribute('data-lon');
                if (lat && lon) {
                    fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`)
                        .then(res => res.json())
                        .then(data => {
                            td.innerText = data.display_name || "Unknown Address";
                        });
                }
            });

            setInterval(() => {
                fetch('/api/my-current-mission')
                    .then(res => res.json())
                    .then(mission => {
                        if (!mission || !mission.id) {
                            window.location.href = '/responder-history';
                            return;
                        }
                        const container = document.getElementById('resolve-btn-container');
                        if (container) {
                            const currentBtn = container.querySelector('button');
                            if (mission.user_confirmed_at && currentBtn.disabled) {
                                container.innerHTML = `<button onclick="resolveMission(${mission.incident_id})" class="btn app-btn-primary"><i class="fa fa-check-circle me-2"></i>MARK AS RESOLVED</button>`;
                            } else if (!mission.user_confirmed_at && !currentBtn.disabled) {
                                container.innerHTML = `<button class="btn btn-secondary btn-sm" disabled><i class="fa fa-hourglass-half me-2"></i>Waiting for User Report...</button>`;
                            }
                        }
                    })
                    .catch(err => console.error("Polling error:", err));
            }, 5000);
        </script>
</body>

</html>