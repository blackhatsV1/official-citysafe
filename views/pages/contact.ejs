<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="app">
    <%- include('../partials/page-start'); %>
        <header class="app-header fixed-top">
            <%- include('../partials/visitor-navbar'); %>
                <%- include('../partials/visitor-sidebar'); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <h1 class="app-page-title">Contact Us</h1>

                    <div class="row g-4 overflow-hidden">
                        <div class="col-12 col-lg-6">
                            <div class="app-card app-card-settings shadow-sm p-4">
                                <div class="app-card-header p-0 border-0 mb-3">
                                    <h4 class="app-card-title">Send Us a Message</h4>
                                </div>
                                <div class="app-card-body">
                                    <form action="/send-message" method="POST" onsubmit="return showLoading()">
                                        <div class="mb-3">
                                            <label for="floatingEmail" class="form-label">Email address</label>
                                            <input type="email" class="form-control" id="floatingEmail" name="email"
                                                placeholder="name@example.com" required>
                                            <div id="emailHelp" class="form-text">We'll never share your email with
                                                anyone else.</div>
                                        </div>
                                        <div class="mb-3">
                                            <label for="floatingName" class="form-label">Name</label>
                                            <input type="text" class="form-control" id="floatingName" name="name"
                                                placeholder="Your Name" required>
                                        </div>
                                        <div class="mb-3">
                                            <label for="floatingTextarea" class="form-label">Message</label>
                                            <textarea class="form-control" placeholder="Leave a comment here"
                                                id="floatingTextarea" name="message" style="height: 150px;"
                                                required></textarea>
                                        </div>
                                        <button type="submit" class="btn app-btn-primary w-100 py-3">SEND
                                            MESSAGE</button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="app-card app-card-notification shadow-sm mb-4 p-4">
                                <div class="app-card-header p-0 border-0 mb-3">
                                    <h4 class="app-card-title">Emergency Hotlines</h4>
                                </div>
                                <div class="app-card-body">
                                    <div class="d-flex flex-column gap-2">
                                        <div
                                            class="d-flex justify-content-between align-items-center p-2 bg-light rounded">
                                            <span>National Emergency Hotline</span>
                                            <span class="badge bg-danger">911</span>
                                        </div>
                                        <div
                                            class="d-flex justify-content-between align-items-center p-2 bg-light rounded">
                                            <span>Police (PNP)</span>
                                            <span class="badge bg-primary">117</span>
                                        </div>
                                        <div
                                            class="d-flex justify-content-between align-items-center p-2 bg-light rounded">
                                            <span>Fire (BFP)</span>
                                            <span class="badge bg-warning text-dark">(02) 8426-0219</span>
                                        </div>
                                        <div
                                            class="d-flex justify-content-between align-items-center p-2 bg-light rounded">
                                            <span>Red Cross</span>
                                            <span class="badge bg-info">143</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="app-card app-card-settings shadow-sm p-4">
                                <div class="app-card-header p-0 border-0 mb-3">
                                    <h4 class="app-card-title">Direct Contacts</h4>
                                </div>
                                <div class="app-card-body">
                                    <div class="list-group list-group-flush">
                                        <div
                                            class="list-group-item bg-transparent px-0 border-light d-flex justify-content-between">
                                            <span class="text-muted">Jayrold Tabalina</span>
                                            <span class="fw-bold">jayroldtabalina@gmail.com</span>
                                        </div>
                                        <div
                                            class="list-group-item bg-transparent px-0 border-light d-flex justify-content-between">
                                            <span class="text-muted">Yasmine Talaman</span>
                                            <span class="fw-bold">yama.talaman.ui@phinmaed.com</span>
                                        </div>
                                        <div
                                            class="list-group-item bg-transparent px-0 border-0 d-flex justify-content-between">
                                            <span class="text-muted">Mark Vincent Jabao</span>
                                            <span class="fw-bold">mark.jabao@gmail.com</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="app-footer">
                <%- include('../partials/footer'); %>
            </footer>
        </div>

        <script src="/js/script.js"></script>
        <script>
            function showLoading() {
                Swal.fire({
                    title: 'Sending Message',
                    html: '<div class="spinner-border text-primary" role="status"></div><p class="mt-2">Please wait...</p>',
                    allowOutsideClick: false,
                    showConfirmButton: false
                });
                return true;
            }

            document.addEventListener('DOMContentLoaded', function () {
                const urlParams = new URLSearchParams(window.location.search);
                const status = urlParams.get('status');

                if (status === 'success') {
                    Swal.fire({
                        icon: 'success',
                        title: 'Message Sent!',
                        text: 'We have received your message and will contact you shortly.',
                        confirmButtonColor: '#15a362'
                    }).then(() => {
                        window.history.replaceState({}, document.title, window.location.pathname);
                    });
                } else if (status === 'error') {
                    Swal.fire({
                        icon: 'error',
                        title: 'Sending Failed',
                        text: 'Something went wrong. Please try again later.'
                    }).then(() => {
                        window.history.replaceState({}, document.title, window.location.pathname);
                    });
                }
            });
        </script>
</body>

</html>