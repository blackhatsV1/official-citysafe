<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/visitor-navbar', { currentPage: 'contact' }); %>
        </header>

        <div>
            <aside>
                <%- include('../partials/visitor-sidebar', { currentPage: 'contact' }); %>
            </aside>

            <main>
                <div>

                    <div>
                        <h1>
                            Contact Us</h1>
                        <p>Reach out for inquiries, urgent concerns, or
                            systematic support.</p>
                    </div>

                    <div>
                        <!-- Contact Form -->
                        <div>
                            <div>
                            </div>
                            <div>
                                <div>
                                    <i></i>
                                </div>
                                <h4>Send a Message</h4>
                            </div>

                            <div>
                                <form action="/send-message" method="POST" onsubmit="return showLoading()">
                                    <div>
                                        <label for="floatingName">Full
                                            Name</label>
                                        <input type="text" id="floatingName" name="name" placeholder="John Doe" required>
                                    </div>
                                    <div>
                                        <label for="floatingEmail">Email
                                            Address</label>
                                        <input type="email" id="floatingEmail" name="email"
                                            placeholder="john@example.com" required>
                                        <div>
                                            <i></i> We'll never share your email.
                                        </div>
                                    </div>
                                    <div>
                                        <label for="floatingTextarea">Message
                                            Content</label>
                                        <textarea id="floatingTextarea" name="message"
                                            placeholder="How can we help you?" required rows="5"></textarea>
                                    </div>
                                    <button type="submit">
                                        <i></i> TRANSMIT MESSAGE
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- Side Info -->
                        <div>

                            <!-- Emergency Hotlines -->
                            <div>
                                <div>
                                </div>
                                <div>
                                    <i></i>
                                    <h4>Emergency
                                        Hotlines</h4>
                                </div>
                                <div>
                                    <div>
                                        <span>National
                                            Emergency</span>
                                        <span>911</span>
                                    </div>
                                    <div>
                                        <span>Police
                                            (PNP)</span>
                                        <span>117</span>
                                    </div>
                                    <div>
                                        <span>Fire
                                            (BFP)</span>
                                        <span>(02)
                                            8426-0219</span>
                                    </div>
                                    <div>
                                        <span>Red
                                            Cross</span>
                                        <span>143</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Direct Contacts -->
                            <div>
                                <div>
                                </div>
                                <div>
                                    <i></i>
                                    <h4>Direct Contacts
                                    </h4>
                                </div>
                                <div>
                                    <div>
                                        <span>Jayrold
                                            Tabalina</span>
                                        <a href="mailto:jayroldtabalina@gmail.com">jayroldtabalina@gmail.com</a>
                                    </div>
                                    <div>
                                        <span>Yasmine
                                            Talaman</span>
                                        <a href="mailto:yama.talaman.ui@phinmaed.com">yama.talaman.ui@phinmaed.com</a>
                                    </div>
                                    <div>
                                        <span>Mark
                                            Vincent Jabao</span>
                                        <a href="mailto:mark.jabao@gmail.com">mark.jabao@gmail.com</a>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>

            <!-- Add SweetAlert2 -->
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                // Use glassmorphism theme for SweetAlert
                const GlassSwal = Swal.mixin({
                    customClass: {
                        popup: 'glass-swal',
                        confirmButton: 'rounded-lg px-6 py-2.5 font-black uppercase tracking-widest text-xs shadow-md mx-2',
                    },
                    background: document.documentElement.classList.contains('dark') ? 'rgba(17, 24, 39, 0.9)' : 'rgba(255, 255, 255, 0.9)',
                    color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                });

                function showLoading() {
                    GlassSwal.fire({
                        title: '<span>Sending Data</span>',
                        html: '<div><i></i></div><p>Establishing secure connection...</p>',
                        allowOutsideClick: false,
                        showConfirmButton: false
                    });
                    return true;
                }

                document.addEventListener('DOMContentLoaded', function () {
                    const urlParams = new URLSearchParams(window.location.search);
                    const status = urlParams.get('status');

                    if (status === 'success') {
                        GlassSwal.fire({
                            icon: 'success',
                            title: '<span>TRANSMISSION SUCCESSFUL</span>',
                            html: '<span>We have received your message and will contact you shortly.</span>',
                            confirmButtonColor: '#10b981',
                            confirmButtonText: 'ACKNOWLEDGE'
                        }).then(() => {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        });
                    } else if (status === 'error') {
                        GlassSwal.fire({
                            icon: 'error',
                            title: '<span>TRANSMISSION FAILED</span>',
                            html: '<span>Network anomaly detected. Please try again.</span>',
                            confirmButtonColor: '#f43f5e',
                            confirmButtonText: 'RETRY'
                        }).then(() => {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        });
                    }
                });
            </script>
            
            <%- include('../partials/page-end'); %>
</body>

</html>