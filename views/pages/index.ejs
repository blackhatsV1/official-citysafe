<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="app">
    <%- include('../partials/page-start'); %>
        <header class="app-header fixed-top">
            <%- include('../partials/user-navbar'); %>
                <%- include('../partials/user-sidebar'); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <h1 class="app-page-title">Citizen Dashboard</h1>

                    <div class="row g-4 mb-4">
                        <div class="col-12 col-lg-7">
                            <div class="app-card app-card-map shadow-sm h-100">
                                <div
                                    class="app-card-header p-3 border-0 d-flex align-items-center justify-content-between">
                                    <h4 class="app-card-title">Local Operations Feed</h4>
                                    <span class="badge bg-success">LIVE</span>
                                </div>
                                <div class="app-card-body p-0">
                                    <%- include('../partials/selectloc'); %>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-5">
                            <div class="app-card app-card-settings shadow-sm h-100 p-4">
                                <div class="app-card-header p-0 border-0 mb-3">
                                    <h4 class="app-card-title text-danger"><i class="fa fa-bullhorn me-2"></i>Emergency
                                        SOS Dispatch</h4>
                                </div>
                                <div class="app-card-body">
                                    <p class="text-muted small mb-4">Request emergency assistance. Our dispatch center
                                        will receive your precise coordinates for immediate coordination.</p>

                                    <form action="/report" method="POST" id="dashboardSosForm">
                                        <input type="hidden" name="type_of_disaster"
                                            id="dashboard_selected_disaster_type">

                                        <div class="row g-3 mb-4">
                                            <div class="col-6">
                                                <button type="button" onclick="triggerDashboardSos('Fire')"
                                                    class="btn btn-outline-danger w-100 py-3">
                                                    <i class="fa fa-fire d-block mb-1"></i> FIRE
                                                </button>
                                            </div>
                                            <div class="col-6">
                                                <button type="button" onclick="triggerDashboardSos('Flood')"
                                                    class="btn btn-outline-primary w-100 py-3">
                                                    <i class="fa fa-water d-block mb-1"></i> FLOOD
                                                </button>
                                            </div>
                                            <div class="col-6">
                                                <button type="button" onclick="triggerDashboardSos('Earthquake')"
                                                    class="btn btn-outline-secondary w-100 py-3">
                                                    <i class="fa fa-globe-americas d-block mb-1"></i> EARTHQUAKE
                                                </button>
                                            </div>
                                            <div class="col-6">
                                                <button type="button" onclick="triggerDashboardSos('Landslide')"
                                                    class="btn btn-outline-warning w-100 py-3">
                                                    <i class="fa fa-mountain d-block mb-1"></i> LANDSLIDE
                                                </button>
                                            </div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label small fw-bold text-uppercase muted">Dispatch
                                                Location</label>
                                            <textarea class="form-control" id="location" name="location" rows="2"
                                                placeholder="Acquiring coordinates..." required readonly></textarea>
                                            <input type="hidden" id="lat" name="lat">
                                            <input type="hidden" id="lon" name="lon">
                                        </div>

                                        <button type="submit" class="btn btn-danger w-100 py-3 fw-bold">INITIATE
                                            EMERGENCY PROTOCOL</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="app-footer">
                <%- include('../partials/footer'); %>
            </footer>
        </div>

        <script>
            function triggerDashboardSos(type) {
                const input = document.getElementById('dashboard_selected_disaster_type');
                if (input) input.value = type;

                const locField = document.getElementById('location');
                if (!locField.value || locField.value.trim() === "" || locField.value.includes('Acquiring')) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Awaiting Location',
                        text: 'We are still resolving your GPS coordinates. Please wait a moment.',
                        confirmButtonColor: 'var(--accent)'
                    });
                    return;
                }

                Swal.fire({
                    title: 'CONFIRM SOS?',
                    text: `Request immediate assistance for ${type} incident at your location?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'CONFIRM & DISPATCH'
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('dashboardSosForm').submit();
                    }
                });
            }
        </script>
</body>

</html>