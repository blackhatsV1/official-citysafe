<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/user-navbar', { currentPage: 'index' }); %>
        </header>

        <div class="cs-layout-container">
            <aside>
                <%- include('../partials/user-sidebar', { currentPage: 'index' }); %>
            </aside>

            <main class="cs-main-content">
                <div class="cs-container">

                    <h1 class="cs-section-header">
                        <i class="fa-solid fa-home"></i> CITIZEN DASHBOARD
                    </h1>

                    <div class="cs-grid cs-grid-2">
                        <!-- Map Feed -->
                        <div class="cs-card">
                            <div class="cs-card-header">
                                <i class="fa-solid fa-satellite-dish"></i>
                                <h2 style="margin: 0; font-size: 1.25rem;">Local Operations Feed</h2>
                                <span class="cs-badge" style="margin-left: auto;">
                                    <span
                                        style="width: 6px; height: 6px; background: currentColor; border-radius: 50%; display: inline-block; margin-right: 0.25rem;"
                                        class="fa-fade"></span>
                                    LIVE
                                </span>
                            </div>
                            <div class="cs-card-body">
                                <div class="cs-map-container" style="height: 480px; position: relative;">
                                    <%- include('../partials/selectloc'); %>
                                </div>
                            </div>
                        </div>

                        <!-- SOS Dispatch -->
                        <div class="cs-card"
                            style="position: relative; overflow: hidden; border: 2px solid rgba(239, 68, 68, 0.2);">
                            <!-- Alert Pulse Background -->
                            <div
                                style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(239, 68, 68, 0.15) 0%, transparent 70%); pointer-events: none;">
                            </div>

                            <div class="cs-card-body" style="display: flex; flex-direction: column; height: 100%;">
                                <div style="margin-bottom: 2rem;">
                                    <h2
                                        style="color: var(--danger); font-size: 1.5rem; font-weight: 800; display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                                        <i class="fa-solid fa-triangle-exclamation fa-beat-fade"></i> Emergency SOS
                                        Dispatch
                                    </h2>
                                    <p style="color: var(--text-dim); font-size: 0.95rem;">
                                        Request emergency assistance. Our dispatch center will receive your precise
                                        coordinates for immediate coordination.
                                    </p>
                                </div>

                                <form action="/report" method="POST" id="dashboardSosForm"
                                    style="flex: 1; display: flex; flex-direction: column; gap: 1.5rem;">
                                    <input type="hidden" name="type_of_disaster" id="dashboard_selected_disaster_type">

                                    <!-- SOS Grid Buttons -->
                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                        <button type="button" onclick="triggerDashboardSos('Fire')" class="cs-card"
                                            style="padding: 1.25rem; text-align: center; background: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.2); cursor: pointer; transition: all 0.3s ease;">
                                            <div style="font-size: 1.5rem; color: #ef4444; margin-bottom: 0.5rem;">
                                                <i class="fa-solid fa-fire-flame-curved"></i>
                                            </div>
                                            <span style="font-weight: 700; color: #ef4444;">Fire</span>
                                        </button>

                                        <button type="button" onclick="triggerDashboardSos('Flood')" class="cs-card"
                                            style="padding: 1.25rem; text-align: center; background: rgba(59, 130, 246, 0.05); border: 1px solid rgba(59, 130, 246, 0.2); cursor: pointer; transition: all 0.3s ease;">
                                            <div style="font-size: 1.5rem; color: #3b82f6; margin-bottom: 0.5rem;">
                                                <i class="fa-solid fa-cloud-showers-heavy"></i>
                                            </div>
                                            <span style="font-weight: 700; color: #3b82f6;">Flood</span>
                                        </button>

                                        <button type="button" onclick="triggerDashboardSos('Earthquake')"
                                            class="cs-card"
                                            style="padding: 1.25rem; text-align: center; background: rgba(234, 179, 8, 0.05); border: 1px solid rgba(234, 179, 8, 0.2); cursor: pointer; transition: all 0.3s ease;">
                                            <div style="font-size: 1.5rem; color: #eab308; margin-bottom: 0.5rem;">
                                                <i class="fa-solid fa-house-crack"></i>
                                            </div>
                                            <span style="font-weight: 700; color: #eab308;">Quake</span>
                                        </button>

                                        <button type="button" onclick="triggerDashboardSos('Landslide')" class="cs-card"
                                            style="padding: 1.25rem; text-align: center; background: rgba(120, 113, 108, 0.05); border: 1px solid rgba(120, 113, 108, 0.2); cursor: pointer; transition: all 0.3s ease;">
                                            <div style="font-size: 1.5rem; color: #78716c; margin-bottom: 0.5rem;">
                                                <i class="fa-solid fa-hill-rockslide"></i>
                                            </div>
                                            <span style="font-weight: 700; color: #78716c;">Landslide</span>
                                        </button>
                                    </div>

                                    <!-- Location & Dispatch -->
                                    <div style="margin-top: auto;">
                                        <div class="cs-form-group">
                                            <label for="location" class="cs-label">Dispatch Coordinates</label>
                                            <div class="cs-input-wrapper">
                                                <i class="fa-solid fa-location-crosshairs cs-input-icon"></i>
                                                <textarea id="location" name="location" rows="2" class="cs-input"
                                                    placeholder="Acquiring GPS coordinates..." required readonly
                                                    style="resize: none;"></textarea>
                                            </div>
                                            <input type="hidden" id="lat" name="lat">
                                            <input type="hidden" id="lon" name="lon">
                                        </div>

                                        <button type="submit" class="cs-btn cs-btn-primary cs-auth-btn"
                                            style="background: var(--danger); border-color: var(--danger); margin-top: 1.5rem;">
                                            <i class="fa-solid fa-tower-broadcast" style="margin-right: 0.5rem;"></i>
                                            INITIATE PROTOCOL
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                function triggerDashboardSos(type) {
                    const input = document.getElementById('dashboard_selected_disaster_type');
                    if (input) input.value = type;

                    const locField = document.getElementById('location');
                    if (!locField.value || locField.value.trim() === "" || locField.value.includes('Acquiring') || locField.value.includes('Waiting for location')) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Awaiting Location',
                            text: 'We are still resolving your precise GPS coordinates. Please wait a moment for satellite lock.',
                            confirmButtonColor: '#6366f1',
                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                        });
                        return;
                    }

                    // Type icon/color mapping for SweetAlert
                    let iconColor = '#ef4444'; // default red
                    let iconHtml = '<i></i>';
                    if (type === 'Fire') { iconColor = '#ef4444'; iconHtml = '<i></i>'; }
                    if (type === 'Flood') { iconColor = '#3b82f6'; iconHtml = '<i></i>'; }
                    if (type === 'Earthquake') { iconColor = '#eab308'; iconHtml = '<i></i>'; }
                    if (type === 'Landslide') { iconColor = '#78716c'; iconHtml = '<i></i>'; }

                    Swal.fire({
                        title: `<span>CONFIRM SOS?</span>`,
                        html: `
                    <div>${iconHtml}</div>
                    <p>Request immediate responder assistance for a <strong>${type.toUpperCase()}</strong> incident at your current sector coordinates?</p>
                `,
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#64748b',
                        confirmButtonText: '<span>CONFIRM & DISPATCH</span>',
                        cancelButtonText: '<span>CANCEL</span>',
                        reverseButtons: true,
                        background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                        color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827',
                        customClass: {
                            confirmButton: 'shadow-lg shadow-red-500/50'
                        }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            Swal.fire({
                                title: 'Transmitting Signal...',
                                text: 'Dispatching your coordinates and incident details to Mission Control.',
                                allowOutsideClick: false,
                                background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                                color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827',
                                showConfirmButton: false,
                                didOpen: () => { Swal.showLoading() }
                            });
                            document.getElementById('dashboardSosForm').submit();
                        }
                    });
                }
            </script>
</body>

</html>