<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
    <script>
      const apiKey = "<%= apiKey %>";
      window.skipAutoLocation = true;
    </script>
    <script src="/js/script.js"></script>
</head>

<body
  class="bg-gradient-glass-light dark:bg-gradient-glass-dark text-gray-800 dark:text-gray-100 min-h-screen flex flex-col">
  <%- include('../partials/page-start'); %>

    <header class="sticky top-0 z-50">
      <%- include('../partials/visitor-navbar'); %>
    </header>

    <div class="flex flex-1 overflow-hidden relative">
      <aside class="z-40">
        <%- include('../partials/visitor-sidebar'); %>
      </aside>

      <main class="flex-1 px-4 py-8 sm:px-6 lg:px-8 overflow-y-auto w-full relative">
        <div class="max-w-7xl mx-auto space-y-8">

          <h1 class="text-3xl font-black text-gray-900 dark:text-gray-100 tracking-tight uppercase px-2 mb-2">URBAN
            SAFETY INTELLIGENCE HUB</h1>

          <!-- Hero Section -->
          <div class="glass-panel overflow-hidden relative">
            <!-- Decorative Gradient -->
            <div
              class="absolute inset-y-0 right-0 w-1/2 hidden lg:block bg-gradient-to-l from-indigo-500/10 to-transparent pointer-events-none">
            </div>

            <div class="p-8 lg:p-12 relative z-10">
              <div class="flex flex-col lg:flex-row items-center gap-10">
                <div class="flex-1 text-center lg:text-left space-y-6">
                  <h2
                    class="text-4xl lg:text-5xl font-black text-gray-900 dark:text-white leading-tight tracking-tight">
                    Welcome to <span
                      class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-500 to-purple-600">CitySafe</span>
                  </h2>
                  <p
                    class="text-lg lg:text-xl text-gray-600 dark:text-gray-300 font-medium max-w-2xl mx-auto lg:mx-0 leading-relaxed">
                    Access real-time environmental data, emergency alerts, and community response coordinates. Join the
                    network for full operational command.
                  </p>
                  <div class="pt-4 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                    <a href="/login"
                      class="btn-glass-primary px-8 py-3 text-lg flex items-center justify-center gap-2 shadow-lg shadow-indigo-500/25">
                      Log In <i class="fa fa-arrow-right"></i>
                    </a>
                    <a href="/register"
                      class="btn-glass px-8 py-3 text-lg flex items-center justify-center border border-gray-200 dark:border-gray-700 hover:border-indigo-300 dark:hover:border-indigo-600">
                      Create Account
                    </a>
                  </div>
                </div>

                <div class="hidden md:flex lg:w-1/3 justify-center pl-8 lg:pl-0">
                  <div
                    class="w-48 h-48 rounded-full bg-indigo-50 dark:bg-indigo-900/20 flex items-center justify-center shadow-inner relative">
                    <!-- Inner pulse -->
                    <div class="absolute inset-4 rounded-full border-4 border-indigo-500/20 animate-pulse"></div>
                    <i
                      class="fa fa-shield-alt text-7xl text-indigo-500 dark:text-indigo-400 opacity-90 drop-shadow-sm"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Three Column Info Grid -->
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Weather Map -->
            <div class="glass-panel flex flex-col overflow-hidden h-full">
              <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 bg-white/40 dark:bg-gray-900/40">
                <h3 class="text-sm font-bold uppercase tracking-wider text-gray-700 dark:text-gray-300">Live Weather
                  Radar</h3>
              </div>
              <div class="p-6 flex-1 flex flex-col gap-4">
                <div
                  class="flex-1 w-full bg-gray-100 dark:bg-gray-800 rounded-xl overflow-hidden shadow-inner border border-gray-200 dark:border-gray-700 min-h-[300px] relative z-0">
                  <div id="weather-map" class="absolute inset-0 z-0"></div>
                </div>
                <div class="flex items-center gap-2">
                  <span
                    class="px-2.5 py-1 bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400 rounded text-[10px] font-black uppercase tracking-widest flex items-center gap-1.5 w-max border border-green-200 dark:border-green-800/50">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                    Live Radar Active
                  </span>
                </div>
              </div>
            </div>

            <!-- Atmospheric Data -->
            <div class="glass-panel flex flex-col overflow-hidden h-full">
              <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 bg-white/40 dark:bg-gray-900/40">
                <h3 class="text-sm font-bold uppercase tracking-wider text-gray-700 dark:text-gray-300">Atmospheric Data
                </h3>
              </div>
              <div class="p-6 flex-1 flex flex-col gap-5">
                <div
                  class="bg-gray-50 dark:bg-gray-800/50 p-4 rounded-xl border border-gray-100 dark:border-gray-800 space-y-2">
                  <div class="flex items-start gap-2.5 text-indigo-600 dark:text-indigo-400">
                    <i class="fa fa-location-dot mt-0.5"></i>
                    <span id="address" class="text-sm font-bold truncate block w-full">Scanning coordinates...</span>
                  </div>
                  <div class="text-xs text-gray-500 dark:text-gray-400 font-mono pl-6" id="coords">Waiting for GPS
                    signal...</div>
                </div>

                <div id="weather-info"
                  class="flex-1 flex flex-col items-center justify-center p-8 border-2 border-dashed border-gray-200 dark:border-gray-700 rounded-xl bg-white/30 dark:bg-gray-900/30">
                  <div
                    class="animate-spin text-3xl text-indigo-500 mb-4 h-8 w-8 border-4 border-indigo-500 border-t-transparent rounded-full">
                  </div>
                  <p class="text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400 text-center">
                    Polling Atmospheric<br>Sensors</p>
                </div>
              </div>
            </div>

            <!-- Operations Map -->
            <div class="glass-panel flex flex-col overflow-hidden h-full">
              <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 bg-white/40 dark:bg-gray-900/40">
                <h3 class="text-sm font-bold uppercase tracking-wider text-gray-700 dark:text-gray-300">Live Operations
                  Map</h3>
              </div>
              <div class="p-6 flex-1 flex flex-col gap-4">
                <div
                  class="flex-1 w-full bg-gray-100 dark:bg-gray-800 rounded-xl overflow-hidden shadow-inner border border-gray-200 dark:border-gray-700 min-h-[300px] relative z-0">
                  <div id="map" class="absolute inset-0 z-0"></div>
                </div>

                <%- include('../partials/selectloc-visitor'); %>

                  <div
                    class="pt-2 text-center text-xs text-gray-500 dark:text-gray-400 font-medium border-t border-gray-100 dark:border-gray-800 border-dashed">
                    * Registration required for full incident reporting features.
                  </div>
              </div>
            </div>

          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>

      <script>
        window.addEventListener('load', () => {
          setTimeout(() => {
            window.dispatchEvent(new Event('resize'));
            if (typeof map !== 'undefined') map.invalidateSize();
            if (typeof weatherMap !== 'undefined') weatherMap.invalidateSize();
          }, 1000);
        });
      </script>
</body>

</html>