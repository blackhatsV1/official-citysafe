<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
    <script>
      const apiKey = "<%= apiKey %>";
      window.skipAutoLocation = true;
    </script>
    <script src="/js/script.js"></script>
</head>

<body>
  <%- include('../partials/page-start'); %>

    <header>
      <%- include('../partials/visitor-navbar'); %>
    </header>

    <div class="cs-layout-container">
      <aside>
        <%- include('../partials/visitor-sidebar'); %>
      </aside>

      <main class="cs-main-content">
        <div class="cs-container">

          <h1 class="cs-section-header">
            <i class="fa-solid fa-earth-asia"></i> URBAN SAFETY INTELLIGENCE HUB
          </h1>

          <!-- Hero Section -->
          <div class="cs-hero">
            <div class="cs-hero-content">
              <div
                style="display: flex; flex-direction: column; align-items: center; gap: 3rem; position: relative; z-index: 2;">
                <div style="flex: 1;">
                  <h2 style="font-size: 3rem; font-weight: 800; margin-bottom: 1.5rem; line-height: 1.1;">
                    Welcome to <span
                      style="background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">CitySafe</span>
                  </h2>
                  <p style="font-size: 1.1rem; color: var(--text-dim); margin-bottom: 2rem; line-height: 1.6;">
                    Access real-time environmental data, emergency alerts, and community response coordinates. Join the
                    network for full operational command.
                  </p>
                  <div style="display: flex; gap: 1rem;">
                    <a href="/login" class="cs-btn cs-btn-primary">
                      LOG IN <i class="fa-solid fa-right-to-bracket" style="margin-left: 0.5rem;"></i>
                    </a>
                    <a href="/register" class="cs-btn cs-btn-outline">
                      CREATE ACCOUNT
                    </a>
                  </div>
                </div>

                <div style="flex: 1; display: flex; justify-content: center;">
                  <div style="position: relative; width: 220px; height: 220px;">
                    <!-- Inner pulse -->
                    <div
                      style="position: absolute; inset: 0; background: var(--primary-glow); border-radius: 50%; opacity: 0.2; transform: scale(1.2); filter: blur(20px);"
                      class="fa-pulse"></div>
                    <div
                      style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: var(--card-glass); border: 1px solid var(--border-glass); border-radius: 50%; backdrop-filter: blur(10px); box-shadow: 0 0 40px var(--primary-glow);">
                      <i class="fa-solid fa-shield-halved fa-5x" style="color: var(--primary);"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Three Column Info Grid -->
          <div class="cs-grid cs-grid-3">

            <!-- Weather Map -->
            <div class="cs-card">
              <div class="cs-card-header">
                <i class="fa-solid fa-cloud-bolt"></i>
                <h3>Live Weather Radar</h3>
              </div>
              <div class="cs-card-body">
                <div class="cs-map-container" style="height: 250px; margin-bottom: 1rem;">
                  <div id="weather-map" style="height: 100%;"></div>
                </div>
                <div
                  style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: var(--success); font-weight: 600;">
                  <span
                    style="width: 8px; height: 8px; background: var(--success); border-radius: 50%; display: inline-block;"
                    class="fa-beat-fade"></span>
                  LIVE RADAR ACTIVE
                </div>
              </div>
            </div>

            <!-- Atmospheric Data -->
            <div class="cs-card">
              <div class="cs-card-header">
                <i class="fa-solid fa-wind"></i>
                <h3>Atmospheric Data</h3>
              </div>
              <div class="cs-card-body">
                <div class="cs-data-group" style="margin-bottom: 1.5rem;">
                  <div class="cs-data-item">
                    <i class="fa-solid fa-location-dot" style="color: var(--primary);"></i>
                    <span id="address" style="font-weight: 500;">Scanning coordinates...</span>
                  </div>
                  <div id="coords" style="font-size: 0.75rem; color: var(--text-dim); margin-left: 1.5rem;">Waiting for
                    GPS signal...</div>
                </div>

                <div id="weather-info" class="cs-card"
                  style="background: rgba(255,255,255,0.03); padding: 1rem; border-radius: 1rem;">
                  <div style="display: flex; align-items: center; gap: 1rem;">
                    <div style="font-size: 2rem; color: var(--accent);"><i class="fa-solid fa-satellite fa-spin"></i>
                    </div>
                    <p style="font-size: 0.85rem; color: var(--text-dim); margin: 0;">
                      Polling Atmospheric<br>Sensors...
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Operations Map -->
            <div class="cs-card">
              <div class="cs-card-header">
                <i class="fa-solid fa-map-location-dot"></i>
                <h3>Live Operations Map</h3>
              </div>
              <div class="cs-card-body">
                <div class="cs-map-container" style="height: 250px; margin-bottom: 1rem;">
                  <div id="map" style="height: 100%;"></div>
                </div>

                <%- include('../partials/selectloc-visitor'); %>

                  <div
                    style="margin-top: auto; padding-top: 1rem; font-size: 0.75rem; color: var(--text-dim); border-top: 1px solid var(--border-glass);">
                    <i class="fa-solid fa-circle-info" style="margin-right: 0.25rem;"></i> Registration required for
                    incident reporting.
                  </div>
              </div>
            </div>

          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>

      <script>
        window.addEventListener('load', () => {
          setTimeout(() => {
            window.dispatchEvent(new Event('resize'));
            if (typeof map !== 'undefined') map.invalidateSize();
            if (typeof weatherMap !== 'undefined') weatherMap.invalidateSize();
          }, 1000);
        });
      </script>
</body>

</html>