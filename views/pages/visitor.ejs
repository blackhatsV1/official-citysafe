<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
    <script>
      const apiKey = "<%= apiKey %>";
      window.skipAutoLocation = true;
    </script>
    <script src="/js/script.js"></script>
</head>

<body>
  <%- include('../partials/page-start'); %>

    <header>
      <%- include('../partials/visitor-navbar'); %>
    </header>

    <div>
      <aside>
        <%- include('../partials/visitor-sidebar'); %>
      </aside>

      <main>
        <div>

          <h1>URBAN
            SAFETY INTELLIGENCE HUB</h1>

          <!-- Hero Section -->
          <div>
            <!-- Decorative Gradient -->
            <div>
            </div>

            <div>
              <div>
                <div>
                  <h2>
                    Welcome to <span>CitySafe</span>
                  </h2>
                  <p>
                    Access real-time environmental data, emergency alerts, and community response coordinates. Join the
                    network for full operational command.
                  </p>
                  <div>
                    <a href="/login">
                      Log In <i></i>
                    </a>
                    <a href="/register">
                      Create Account
                    </a>
                  </div>
                </div>

                <div>
                  <div>
                    <!-- Inner pulse -->
                    <div></div>
                    <i></i>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Three Column Info Grid -->
          <div>

            <!-- Weather Map -->
            <div>
              <div>
                <h3>Live Weather
                  Radar</h3>
              </div>
              <div>
                <div>
                  <div id="weather-map"></div>
                </div>
                <div>
                  <span>
                    <span></span>
                    Live Radar Active
                  </span>
                </div>
              </div>
            </div>

            <!-- Atmospheric Data -->
            <div>
              <div>
                <h3>Atmospheric Data
                </h3>
              </div>
              <div>
                <div>
                  <div>
                    <i></i>
                    <span id="address">Scanning coordinates...</span>
                  </div>
                  <div id="coords">Waiting for GPS
                    signal...</div>
                </div>

                <div id="weather-info">
                  <div>
                  </div>
                  <p>
                    Polling Atmospheric<br>Sensors</p>
                </div>
              </div>
            </div>

            <!-- Operations Map -->
            <div>
              <div>
                <h3>Live Operations
                  Map</h3>
              </div>
              <div>
                <div>
                  <div id="map"></div>
                </div>

                <%- include('../partials/selectloc-visitor'); %>

                  <div>
                    * Registration required for full incident reporting features.
                  </div>
              </div>
            </div>

          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>

      <script>
        window.addEventListener('load', () => {
          setTimeout(() => {
            window.dispatchEvent(new Event('resize'));
            if (typeof map !== 'undefined') map.invalidateSize();
            if (typeof weatherMap !== 'undefined') weatherMap.invalidateSize();
          }, 1000);
        });
      </script>
</body>

</html>