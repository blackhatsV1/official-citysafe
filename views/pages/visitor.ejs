<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
    <script>
      const apiKey = "<%= apiKey %>";
      window.skipAutoLocation = true;
    </script>
    <script src="/js/script.js"></script>
</head>

<body class="app">
  <%- include('../partials/page-start'); %>
    <header class="app-header fixed-top">
      <%- include('../partials/visitor-navbar'); %>
        <%- include('../partials/visitor-sidebar'); %>
    </header>

    <div class="app-wrapper">
      <div class="app-content pt-3 p-md-3 p-lg-4">
        <div class="container-xl">
          <h1 class="app-page-title">Urban Safety Intelligence Hub</h1>

          <div class="app-card alert border-left-decoration shadow-sm mb-4" role="alert">
            <div class="inner">
              <div class="app-card-body p-3 p-lg-4">
                <h3 class="mb-3">Welcome to CitySafe</h3>
                <div class="row gx-5 gy-3">
                  <div class="col-12 col-lg-9">
                    <div>Access real-time environmental data, emergency alerts, and community response coordinates. Join
                      the network for full operational command.</div>
                  </div>
                  <div class="col-12 col-lg-3">
                    <div class="d-grid gap-2">
                      <a class="btn app-btn-primary" href="/login">Log In</a>
                      <a class="btn app-btn-secondary" href="/register">Register</a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-4 mb-4">
            <div class="col-12 col-lg-4">
              <div class="app-card app-card-chart h-100 shadow-sm">
                <div class="app-card-header p-3 border-0">
                  <h4 class="app-card-title">Live Weather Radar</h4>
                </div>
                <div class="app-card-body p-3 p-lg-4">
                  <div id="weather-map" style="height: 300px;" class="rounded"></div>
                  <div class="mt-3">
                    <span class="badge bg-success">Live Radar Active</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-4">
              <div class="app-card app-card-orders shadow-sm h-100">
                <div class="app-card-header p-3 border-0">
                  <h4 class="app-card-title">Atmospheric Data</h4>
                </div>
                <div class="app-card-body p-3 p-lg-4">
                  <div class="mb-3 p-3 bg-light rounded border">
                    <div class="d-flex align-items-center gap-2 mb-2 text-primary">
                      <i class="fa fa-location-dot"></i>
                      <span id="address" class="small fw-bold text-truncate d-block">Scanning...</span>
                    </div>
                    <span id="coords" class="text-muted small">Waiting for signal...</span>
                  </div>
                  <div id="weather-info" class="flex-grow-1">
                    <div class="text-center py-5 opacity-50">
                      <div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div>
                      <p class="small mb-0">Polling Atmospheric Sensors...</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-4">
              <div class="app-card app-card-chart h-100 shadow-sm">
                <div class="app-card-header p-3 border-0">
                  <h4 class="app-card-title">Live Operations Map</h4>
                </div>
                <div class="app-card-body p-3 p-lg-4">
                  <div id="map" style="height: 300px;" class="rounded"></div>
                  <%- include('../partials/selectloc-visitor'); %>
                    <div class="mt-3">
                      <small class="text-muted">* Register for full incident reporting features.</small>
                    </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <footer class="app-footer">
        <%- include('../partials/footer'); %>
      </footer>
    </div>

    <script>
      window.addEventListener('load', () => {
        setTimeout(() => {
          window.dispatchEvent(new Event('resize'));
          if (typeof map !== 'undefined') map.invalidateSize();
          if (typeof weatherMap !== 'undefined') weatherMap.invalidateSize();
        }, 1000);
      });
    </script>
</body>

</html>