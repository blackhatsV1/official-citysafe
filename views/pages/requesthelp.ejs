<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body class="app">
  <%- include('../partials/page-start'); %>

    <header class="app-header fixed-top">
      <%- include('../partials/user-navbar'); %>
        <%- include('../partials/user-sidebar'); %>
    </header>

    <div class="app-wrapper">
      <div class="app-content pt-3 p-md-3 p-lg-4">
        <div class="container-xl">
          <div class="row g-3 mb-4 align-items-center justify-content-between">
            <div class="col-auto">
              <h1 class="app-page-title mb-0">Help Center Dashboard</h1>
            </div>
          </div>

          <div class="row g-4 mb-4">
            <div class="col-12 col-lg-8 mx-auto">
              <div class="app-card app-card-settings shadow-sm p-4">
                <div class="app-card-header p-3 border-bottom-0">
                  <h4 class="app-card-title">Request Medical Assistance</h4>
                </div>
                <div class="app-card-body">

                  <form action="/api/med-request" method="POST">
                    <div class="mb-4">
                      <label for="address" class="form-label">Current Location Address</label>
                      <input type="text" class="form-control bg-light" id="address" name="address" readonly>
                    </div>

                    <div class="mb-4">
                      <label class="form-label">Select Location on Map</label>
                      <div id="map" class="rounded border mb-2" style="height: 300px; width: 100%;"></div>
                      <small class="text-muted d-block"><i class="fa fa-info-circle me-1"></i>Click on the map to select
                        your exact location for the request.</small>
                    </div>

                    <div class="row g-3">
                      <div class="col-md-6">
                        <label for="latitude" class="form-label">Latitude</label>
                        <input type="text" class="form-control bg-light" id="latitude" name="latitude" required
                          readonly>
                      </div>
                      <div class="col-md-6">
                        <label for="longitude" class="form-label">Longitude</label>
                        <input type="text" class="form-control bg-light" id="longitude" name="longitude" required
                          readonly>
                      </div>
                    </div>

                    <div class="mt-4 pt-3 border-top text-end">
                      <button type="submit" class="btn app-btn-primary theme-btn w-100 py-2">
                        <i class="fa fa-paper-plane me-2"></i>Submit Request
                      </button>
                    </div>
                  </form>

                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%- include('../partials/footer'); %>
    </div>

    <%- include('../partials/page-end'); %>

      <!-- External Scripts for Map -->
      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
      <script
        src="https://cdnjs.cloudflare.com/ajax/libs/leaflet-routing-machine/3.2.12/leaflet-routing-machine.min.js"></script>
      <script src="/js/script.js"></script>
      <script src="/js/sos.js"></script>
</body>

</html>