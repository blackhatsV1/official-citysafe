<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body
  class="bg-gradient-glass-light dark:bg-gradient-glass-dark text-gray-800 dark:text-gray-100 min-h-screen flex flex-col">
  <%- include('../partials/page-start'); %>

    <header class="sticky top-0 z-50">
      <%- include('../partials/visitor-navbar', { currentPage: 'about' }); %>
    </header>

    <div class="flex flex-1 overflow-hidden relative">
      <aside class="z-40">
        <%- include('../partials/visitor-sidebar', { currentPage: 'about' }); %>
      </aside>

      <main class="flex-1 px-4 py-8 sm:px-6 lg:px-8 overflow-y-auto w-full relative">
        <div class="max-w-7xl mx-auto space-y-6">

          <div class="flex items-center gap-3 px-2 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-400 flex items-center justify-center">
              <i class="fa fa-circle-info text-xl"></i>
            </div>
            <h1 class="text-3xl font-black text-gray-900 dark:text-gray-100 tracking-tight uppercase">About CitySafe
            </h1>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Mission Section -->
            <div class="lg:col-span-2 space-y-6">
              <div class="glass-panel overflow-hidden h-full flex flex-col border-t-4 border-indigo-500 relative">
                <!-- Background abstract shape -->
                <div
                  class="absolute -top-10 -right-10 w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none">
                </div>

                <div class="p-6 md:p-8 flex-1 relative z-10">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-3">
                    <i class="fa fa-bullseye text-indigo-500"></i> Our Mission
                  </h3>

                  <div class="space-y-6 text-gray-600 dark:text-gray-300 leading-relaxed">
                    <p class="text-sm md:text-base">
                      CitySafe is a web-based disaster response app that provides
                      real-time alerts, localized notifications, and reliable information
                      during emergencies. It helps citizens stay informed, empowers them
                      to send SOS requests for immediate assistance, and supports city officials and
                      responders in coordinating relief efforts efficiently.
                    </p>

                    <p class="text-sm md:text-base">
                      Developed as a <span
                        class="px-2 py-0.5 bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 rounded font-bold uppercase tracking-widest text-[10px] mx-1">Capstone
                        Research Project</span>, CitySafe aims to
                      strengthen disaster resilience in urban areas through a user-friendly and efficient system.
                    </p>
                  </div>

                  <div
                    class="mt-8 p-6 bg-gray-50/50 dark:bg-gray-800/50 rounded-2xl border border-gray-200 dark:border-gray-700 relative overflow-hidden group">
                    <div
                      class="absolute -right-4 -top-4 text-7xl text-gray-200 dark:text-gray-700 opacity-50 group-hover:scale-110 transition-transform">
                      <i class="fa fa-quote-right"></i>
                    </div>
                    <div class="relative z-10">
                      <p class="text-lg font-bold text-gray-800 dark:text-gray-200 mb-2 italic">
                        "CitySafe: Urban Disaster Response App"
                      </p>
                      <p class="text-[10px] uppercase tracking-widest font-black text-gray-500 dark:text-gray-400">
                        — Capstone Research Project
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Development Team Section -->
            <div class="lg:col-span-1 space-y-6">
              <div class="glass-panel overflow-hidden border-t-4 border-emerald-500 h-full">
                <div
                  class="px-6 py-4 border-b border-emerald-100 dark:border-emerald-900/30 bg-emerald-50/50 dark:bg-emerald-900/10 flex items-center justify-between">
                  <h4
                    class="text-sm font-bold uppercase tracking-wider text-gray-800 dark:text-gray-200 flex items-center gap-2">
                    <i class="fa fa-users-gear text-emerald-500"></i> Development Team
                  </h4>
                </div>
                <div class="p-4 space-y-3">

                  <div
                    class="flex items-center gap-4 p-3 rounded-xl bg-white/40 dark:bg-gray-800/40 border border-gray-200/50 dark:border-gray-700/50 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                    <div
                      class="w-12 h-12 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400 flex items-center justify-center font-black text-lg border border-blue-200 dark:border-blue-800 shrink-0 shadow-sm">
                      JT
                    </div>
                    <div>
                      <h6 class="text-sm font-bold text-gray-900 dark:text-gray-100">Jayrold Tabalina</h6>
                      <p
                        class="text-[10px] font-black uppercase tracking-widest text-emerald-600 dark:text-emerald-400">
                        Lead Programmer</p>
                    </div>
                  </div>

                  <div
                    class="flex items-center gap-4 p-3 rounded-xl bg-white/40 dark:bg-gray-800/40 border border-gray-200/50 dark:border-gray-700/50 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                    <div
                      class="w-12 h-12 rounded-full bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400 flex items-center justify-center font-black text-lg border border-purple-200 dark:border-purple-800 shrink-0 shadow-sm">
                      YT
                    </div>
                    <div>
                      <h6 class="text-sm font-bold text-gray-900 dark:text-gray-100">Yasmine M. Talaman</h6>
                      <p
                        class="text-[10px] font-black uppercase tracking-widest text-emerald-600 dark:text-emerald-400">
                        Documentation Lead</p>
                    </div>
                  </div>

                  <div
                    class="flex items-center gap-4 p-3 rounded-xl bg-white/40 dark:bg-gray-800/40 border border-gray-200/50 dark:border-gray-700/50 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                    <div
                      class="w-12 h-12 rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-600 dark:text-amber-400 flex items-center justify-center font-black text-lg border border-amber-200 dark:border-amber-800 shrink-0 shadow-sm">
                      MJ
                    </div>
                    <div>
                      <h6 class="text-sm font-bold text-gray-900 dark:text-gray-100">Mark Vincent Jabao</h6>
                      <p
                        class="text-[10px] font-black uppercase tracking-widest text-emerald-600 dark:text-emerald-400">
                        UI/UX Designer</p>
                    </div>
                  </div>

                </div>
              </div>
            </div>
          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>
      <%- include('../partials/page-end'); %>
</body>

</html>