<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body class="app">
  <%- include('../partials/page-start'); %>
    <header class="app-header fixed-top">
      <%- include('../partials/visitor-navbar'); %>
        <%- include('../partials/visitor-sidebar'); %>
    </header>

    <div class="app-wrapper">
      <div class="app-content pt-3 p-md-3 p-lg-4">
        <div class="container-xl">
          <h1 class="app-page-title">About CitySafe</h1>

          <div class="row g-4 mb-4">
            <div class="col-12 col-lg-8">
              <div class="app-card app-card-settings shadow-sm p-4">
                <div class="app-card-body">
                  <div class="mb-3">
                    <h3 class="app-page-title mb-3">Our Mission</h3>
                    <p style="line-height: 1.8;">
                      CitySafe is a web-based disaster response app that provides
                      real-time alerts, localized notifications, and reliable information
                      during emergencies. It helps citizens stay informed, empowers them
                      to send SOS requests for immediate assistance, and supports city officials and
                      responders in coordinating relief efforts efficiently.
                    </p>
                    <p>
                      Developed as a <em class="text-primary fw-bold">capstone research project</em>, CitySafe aims to
                      strengthen disaster resilience in urban areas through a user-friendly and efficient system.
                    </p>
                  </div>

                  <blockquote class="blockquote bg-light p-4 rounded border-left-decoration">
                    <p class="mb-2">“CitySafe: Urban Disaster Response App”</p>
                    <footer class="blockquote-footer">Capstone Research Project</footer>
                  </blockquote>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-4">
              <div class="app-card app-card-orders shadow-sm h-100">
                <div class="app-card-header p-3 border-0">
                  <h4 class="app-card-title">Development Team</h4>
                </div>
                <div class="app-card-body p-3">
                  <div class="list-group list-group-flush">
                    <div class="list-group-item border-0 py-3">
                      <div class="d-flex align-items-center gap-3">
                        <div
                          class="avatar bg-primary-soft rounded-circle d-flex align-items-center justify-content-center"
                          style="width: 40px; height: 40px;">
                          <span class="text-primary fw-bold">JT</span>
                        </div>
                        <div>
                          <h6 class="mb-0">Jayrold Tabalina</h6>
                          <small class="text-muted">Programmer</small>
                        </div>
                      </div>
                    </div>
                    <div class="list-group-item border-0 py-3">
                      <div class="d-flex align-items-center gap-3">
                        <div class="avatar bg-info-soft rounded-circle d-flex align-items-center justify-content-center"
                          style="width: 40px; height: 40px;">
                          <span class="text-info fw-bold">YT</span>
                        </div>
                        <div>
                          <h6 class="mb-0">Yasmine M. Talaman</h6>
                          <small class="text-muted">Documenter</small>
                        </div>
                      </div>
                    </div>
                    <div class="list-group-item border-0 py-3">
                      <div class="d-flex align-items-center gap-3">
                        <div
                          class="avatar bg-warning-soft rounded-circle d-flex align-items-center justify-content-center"
                          style="width: 40px; height: 40px;">
                          <span class="text-warning fw-bold">MJ</span>
                        </div>
                        <div>
                          <h6 class="mb-0">Mark Vincent Jabao</h6>
                          <small class="text-muted">UI/UX Designer</small>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <footer class="app-footer">
        <%- include('../partials/footer'); %>
      </footer>
    </div>

    <script src="/js/script.js"></script>
</body>

</html>