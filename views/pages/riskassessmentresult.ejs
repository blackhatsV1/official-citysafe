<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/user-navbar', { currentPage: 'riskassessment' }); %>
        </header>

        <div>
            <aside>
                <%- include('../partials/user-sidebar', { currentPage: 'riskassessment' }); %>
            </aside>

            <main>
                <div>

                    <div>
                        <div>
                            <div>
                                <i></i>
                            </div>
                            <h1>
                                Assessment History</h1>
                        </div>
                        <a href="/assess-risk">
                            <i></i> NEW ASSESSMENT
                        </a>
                    </div>

                    <div>
                        <div>
                            <h2>
                                Historical Records</h2>
                        </div>

                        <div>
                            <% if (assessments.length> 0) { %>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Date Assessed</th>
                                            <th>Calculated Score</th>
                                            <th>Threat Level</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% for (let i=0; i < assessments.length; i++) { %>
                                            <tr>
                                                <td>
                                                    <%= assessments[i].assessed_at %>
                                                </td>
                                                <td>
                                                    <span>
                                                        <%= assessments[i].risk_score %>%
                                                    </span>
                                                </td>
                                                <td>
                                                    <% if(assessments[i].risk_level==='High' ) { %>
                                                        <span>
                                                            <i></i>
                                                            <%= assessments[i].risk_level %>
                                                        </span>
                                                        <% } else if(assessments[i].risk_level==='Medium' ) { %>
                                                            <span>
                                                                <i></i>
                                                                <%= assessments[i].risk_level %>
                                                            </span>
                                                            <% } else { %>
                                                                <span>
                                                                    <i></i>
                                                                    <%= assessments[i].risk_level %>
                                                                </span>
                                                                <% } %>
                                                </td>
                                                <td>
                                                    <form action="/delete-result/<%= assessments[i].id %>" method="POST"
                                                        onsubmit="return confirmDelete(event, this);">
                                                        <button type="submit"
                                                            title="Delete Record">
                                                            <i></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% } %>
                                    </tbody>
                                </table>
                                <% } else { %>
                                    <div>
                                        <div>
                                            <i></i>
                                        </div>
                                        <h3>No Records
                                            Found</h3>
                                        <p>You haven't
                                            completed a risk assessment yet. Take one to understand your local
                                            vulnerabilities.</p>
                                        <a href="/assess-risk">
                                            START ASSESSMENT <i></i>
                                        </a>
                                    </div>
                                    <% } %>
                        </div>
                    </div>

                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>

            <!-- SweetAlert2 for nice confirms -->
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                const GlassSwal = Swal.mixin({
                    customClass: {
                        popup: 'glass-swal',
                        confirmButton: 'rounded-lg px-6 py-2.5 font-black uppercase tracking-widest text-xs shadow-md mx-2 bg-red-600 hover:bg-red-700 text-white border-0',
                        cancelButton: 'rounded-lg px-6 py-2.5 font-black uppercase tracking-widest text-xs shadow-sm mx-2 bg-gray-200 hover:bg-gray-300 text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-white border-0',
                    },
                    buttonsStyling: false,
                    background: document.documentElement.classList.contains('dark') ? 'rgba(17, 24, 39, 0.9)' : 'rgba(255, 255, 255, 0.9)',
                    color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                });

                function confirmDelete(e, form) {
                    e.preventDefault();
                    GlassSwal.fire({
                        title: 'Delete Record?',
                        text: "This assessment history will be permanently erased.",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: '<i></i> CONFIRM',
                        cancelButtonText: 'CANCEL',
                        reverseButtons: true
                    }).then((result) => {
                        if (result.isConfirmed) {
                            form.submit();
                        }
                    });
                    return false;
                }
            </script>
            
            <%- include('../partials/page-end'); %>
</body>

</html>