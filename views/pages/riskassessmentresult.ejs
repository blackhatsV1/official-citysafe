<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/user-navbar', { currentPage: 'riskassessment' }); %>
        </header>

        <div class="cs-layout-container">
            <aside>
                <%- include('../partials/user-sidebar', { currentPage: 'riskassessment' }); %>
            </aside>

            <main class="cs-main-content">
                <div class="cs-container">

                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem; flex-wrap: wrap; gap: 1.5rem;">
                        <div style="display: flex; align-items: center; gap: 1.5rem;">
                            <div class="cs-badge"
                                style="width: 64px; height: 64px; font-size: 1.5rem; background: var(--accent-glow); color: var(--accent); border: 2px solid var(--accent);">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                            </div>
                            <h1 class="cs-section-header" style="margin: 0;">
                                ASSESSMENT <span
                                    style="background: linear-gradient(135deg, var(--accent) 0%, var(--primary) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">HISTORY</span>
                            </h1>
                        </div>
                        <a href="/assess-risk" class="cs-btn-primary"
                            style="text-decoration: none; display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1.5rem;">
                            <i class="fa-solid fa-plus-circle"></i> NEW ASSESSMENT
                        </a>
                    </div>

                    <div class="cs-card" style="padding: 0; overflow: hidden; border: 1px solid var(--border-glass);">
                        <div
                            style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--border-glass); background: rgba(255,255,255,0.02); display: flex; align-items: center; gap: 1rem;">
                            <div class="cs-badge" style="background: var(--primary-glow); color: var(--primary);"><i
                                    class="fa-solid fa-database"></i></div>
                            <h2 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                HISTORICAL RECORDS</h2>
                        </div>

                        <div style="overflow-x: auto;">
                            <% if (assessments.length> 0) { %>
                                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                                    <thead>
                                        <tr style="background: rgba(0,0,0,0.3);">
                                            <th
                                                style="padding: 1.25rem 2rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                DATE ASSESSED</th>
                                            <th
                                                style="padding: 1.25rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                CALCULATED SCORE</th>
                                            <th
                                                style="padding: 1.25rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;">
                                                THREAT LEVEL</th>
                                            <th
                                                style="padding: 1.25rem 2rem; font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase; text-align: right;">
                                                ACTIONS</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% assessments.forEach(assessment=> { %>
                                            <tr style="border-bottom: 1px solid var(--border-glass); transition: background 0.2s ease;"
                                                onmouseover="this.style.background='rgba(255,255,255,0.02)'"
                                                onmouseout="this.style.background='transparent'">
                                                <td style="padding: 1.5rem 2rem;">
                                                    <div style="display: flex; align-items: center; gap: 1rem;">
                                                        <div class="cs-badge"
                                                            style="width: 32px; height: 32px; font-size: 0.75rem; background: rgba(255,255,255,0.05); color: var(--text-dim);">
                                                            <i class="fa-solid fa-calendar-day"></i></div>
                                                        <span
                                                            style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; color: var(--text-bright); font-weight: 600;">
                                                            <%= assessment.assessed_at %>
                                                        </span>
                                                    </div>
                                                </td>
                                                <td style="padding: 1.5rem 1.25rem;">
                                                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                                                        <div
                                                            style="flex-grow: 1; max-width: 100px; height: 6px; background: rgba(255,255,255,0.05); border-radius: 1rem; overflow: hidden;">
                                                            <div
                                                                style="height: 100%; width: <%= assessment.risk_score %>%; background: linear-gradient(90deg, var(--primary), var(--accent));">
                                                            </div>
                                                        </div>
                                                        <span
                                                            style="font-size: 1rem; font-weight: 900; color: var(--text-bright);">
                                                            <%= assessment.risk_score %>%
                                                        </span>
                                                    </div>
                                                </td>
                                                <td style="padding: 1.5rem 1.25rem;">
                                                    <% let levelColor='var(--text-dim)' ; let
                                                        levelBg='rgba(255,255,255,0.05)' ; let levelIcon='fa-shield' ;
                                                        if(assessment.risk_level==='High' ) { levelColor='var(--danger)'
                                                        ; levelBg='var(--danger-glow)' ; levelIcon='fa-biohazard' ; }
                                                        else if(assessment.risk_level==='Medium' ) {
                                                        levelColor='var(--warning)' ; levelBg='var(--warning-glow)' ;
                                                        levelIcon='fa-radiation' ; } else { levelColor='#10b981' ;
                                                        levelBg='rgba(16, 185, 129, 0.1)' ; levelIcon='fa-circle-check'
                                                        ; } %>
                                                        <span
                                                            style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; font-weight: 900; color: <%= levelColor %>; background: <%= levelBg %>; padding: 0.4rem 1rem; border-radius: 2rem; border: 1px solid <%= levelColor %>40;">
                                                            <i class="fa-solid <%= levelIcon %>"></i>
                                                            <%= assessment.risk_level.toUpperCase() %>
                                                        </span>
                                                </td>
                                                <td style="padding: 1.5rem 2rem; text-align: right;">
                                                    <form action="/delete-result/<%= assessment.id %>" method="POST"
                                                        onsubmit="return confirmDelete(event, this);">
                                                        <button type="submit"
                                                            style="background: none; border: 1px solid var(--border-glass); color: var(--text-dim); width: 32px; height: 32px; border-radius: 0.5rem; cursor: pointer; transition: all 0.2s ease;"
                                                            onmouseover="this.style.borderColor='var(--danger)'; this.style.color='var(--danger)'; this.style.background='rgba(239,68,68,0.05)'"
                                                            onmouseout="this.style.borderColor='var(--border-glass)'; this.style.color='var(--text-dim)'; this.style.background='none'"
                                                            title="Delete Record">
                                                            <i class="fa-solid fa-trash-can"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                                <% } else { %>
                                    <div style="padding: 6rem 2rem; text-align: center;">
                                        <div class="cs-badge"
                                            style="width: 80px; height: 80px; font-size: 2.5rem; margin: 0 auto 2rem; background: rgba(255,255,255,0.02); color: var(--text-dim); border-style: dashed;">
                                            <i class="fa-solid fa-microchip"></i>
                                        </div>
                                        <h3
                                            style="margin: 0; font-size: 1.5rem; font-weight: 800; color: var(--text-bright);">
                                            NO ANALYSIS DATA</h3>
                                        <p
                                            style="margin: 1rem 0 3rem; color: var(--text-dim); max-width: 400px; margin-left: auto; margin-right: auto; line-height: 1.6;">
                                            You haven't completed a tactical risk assessment yet. Execute a scan to
                                            understand your sector vulnerabilities.</p>
                                        <a href="/assess-risk" class="cs-btn-primary"
                                            style="text-decoration: none; padding: 1.25rem 2.5rem; font-size: 1rem; display: inline-flex; align-items: center; gap: 1rem;">
                                            <i class="fa-solid fa-play"></i> START ASSESSMENT
                                        </a>
                                    </div>
                                    <% } %>
                        </div>
                    </div>

                </div>
            </main>
        </div>
        </main>
        </div>

        <%- include('../partials/footer'); %>

            <!-- SweetAlert2 for nice confirms -->
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                const GlassSwal = Swal.mixin({
                    customClass: {
                        popup: 'glass-swal',
                        confirmButton: 'rounded-lg px-6 py-2.5 font-black uppercase tracking-widest text-xs shadow-md mx-2 bg-red-600 hover:bg-red-700 text-white border-0',
                        cancelButton: 'rounded-lg px-6 py-2.5 font-black uppercase tracking-widest text-xs shadow-sm mx-2 bg-gray-200 hover:bg-gray-300 text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-white border-0',
                    },
                    buttonsStyling: false,
                    background: document.documentElement.classList.contains('dark') ? 'rgba(17, 24, 39, 0.9)' : 'rgba(255, 255, 255, 0.9)',
                    color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                });

                function confirmDelete(e, form) {
                    e.preventDefault();
                    GlassSwal.fire({
                        title: 'Delete Record?',
                        text: "This assessment history will be permanently erased.",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: '<i></i> CONFIRM',
                        cancelButtonText: 'CANCEL',
                        reverseButtons: true
                    }).then((result) => {
                        if (result.isConfirmed) {
                            form.submit();
                        }
                    });
                    return false;
                }
            </script>

            <%- include('../partials/page-end'); %>
</body>

</html>