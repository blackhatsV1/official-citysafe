<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>
<!-- ========================================================================= -->

<body class="app">
    <%- include('../partials/page-start'); %>

        <header class="app-header fixed-top">
            <%- include('../partials/user-navbar'); %>
                <%- include('../partials/user-sidebar'); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <div class="row g-3 mb-4 align-items-center justify-content-between">
                        <div class="col-auto">
                            <h1 class="app-page-title mb-0">Assessment History</h1>
                        </div>
                        <div class="col-auto">
                            <div class="page-utilities">
                                <a class="btn app-btn-primary theme-btn" href="/assess-risk">
                                    <svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-plus me-1"
                                        fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                        <path fill-rule="evenodd"
                                            d="M8 3.5a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-.5.5H4a.5.5 0 0 1 0-1h3.5V4a.5.5 0 0 1 .5-.5z" />
                                        <path fill-rule="evenodd"
                                            d="M7.5 8a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 0 1H8.5V12a.5.5 0 0 1-1 0V8z" />
                                    </svg>
                                    Take New Assessment
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-12 col-lg-8 mx-auto">
                            <div class="app-card app-card-orders-table shadow-sm mb-5">
                                <div class="app-card-body">
                                    <div class="table-responsive">
                                        <% if (assessments.length> 0) { %>
                                            <table class="table app-table-hover mb-0 text-left">
                                                <thead>
                                                    <tr>
                                                        <th class="cell">Date Assessed</th>
                                                        <th class="cell">Risk Score</th>
                                                        <th class="cell">Risk Level</th>
                                                        <th class="cell">Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% for (let i=0; i < assessments.length; i++) { %>
                                                        <tr>
                                                            <td class="cell">
                                                                <%= assessments[i].assessed_at %>
                                                            </td>
                                                            <td class="cell"><span class="badge bg-secondary">
                                                                    <%= assessments[i].risk_score %>%
                                                                </span></td>
                                                            <td class="cell">
                                                                <% if(assessments[i].risk_level==='High' ) { %>
                                                                    <span class="badge bg-danger">
                                                                        <%= assessments[i].risk_level %>
                                                                    </span>
                                                                    <% } else if(assessments[i].risk_level==='Medium' )
                                                                        { %>
                                                                        <span class="badge bg-warning">
                                                                            <%= assessments[i].risk_level %>
                                                                        </span>
                                                                        <% } else { %>
                                                                            <span class="badge bg-success">
                                                                                <%= assessments[i].risk_level %>
                                                                            </span>
                                                                            <% } %>
                                                            </td>
                                                            <td class="cell">
                                                                <form action="/delete-result/<%= assessments[i].id %>"
                                                                    method="POST" class="d-inline">
                                                                    <button type="submit"
                                                                        onclick="return confirm('Delete this Assessment?')"
                                                                        class="btn-sm app-btn-secondary">Delete</button>
                                                                </form>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                                </tbody>
                                            </table>
                                            <% } else { %>
                                                <div class="text-center p-5">
                                                    <i class="fa fa-clipboard-list fs-1 text-muted mb-3"></i>
                                                    <p class="text-muted mb-0">No prior assessment results found.</p>
                                                </div>
                                                <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('../partials/footer'); %>
        </div>

        <%- include('../partials/page-end'); %>
            <script src="/js/script.js"></script>
</body>

</html>