<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body class="app">
  <%- include('../partials/page-start'); %>

    <header class="app-header fixed-top">
      <%- include('../partials/admin-navbar'); %>
        <%- include('../partials/admin-sidebar'); %>
    </header>

    <div class="app-wrapper">
      <div class="app-content pt-3 p-md-3 p-lg-4">
        <div class="container-xl">
          <div class="row g-4 mb-4">
            <div class="col-12 col-lg-8">
              <div class="app-card app-card-basic d-flex flex-column align-items-start shadow-sm h-100">
                <div class="app-card-header p-3 border-bottom-0">
                  <div class="row align-items-center gx-3">
                    <div class="col-auto">
                      <div class="app-icon-holder bg-primary text-white">
                        <i class="fa fa-info-circle"></i>
                      </div>
                    </div>
                    <div class="col-auto">
                      <h4 class="app-card-title">About CitySafe</h4>
                    </div>
                  </div>
                </div>
                <div class="app-card-body px-4 pb-4">
                  <figure class="text-center p-3 mb-0">
                    <blockquote class="blockquote">
                      <p>CitySafe is a web-based disaster response app that provides
                        real-time alerts, localized notifications, and reliable information
                        during emergencies. It helps citizens stay informed, empowers them
                        to send SOS requests for immediate assistance, and supports city officials and
                        responders in coordinating relief efforts efficiently.</p>
                      <p>
                        CitySafe was developed as a <em>capstone research project</em> entitled
                        “CitySafe: Urban Disaster Response App”, with the goal of creating a
                        user-friendly, efficient, and compassionate system that strengthens
                        disaster resilience in urban areas.
                      </p>
                    </blockquote>
                    <figcaption class="blockquote-footer mt-2">
                      Capstone Research Project <cite title="Source Title">“CitySafe: Urban Disaster Response
                        App”</cite>
                    </figcaption>
                  </figure>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-4">
              <div class="app-card app-card-settings shadow-sm p-4 h-100">
                <div class="app-card-body">
                  <h4 class="app-card-title mb-4">Team Members:</h4>

                  <div class="border rounded p-3 mb-3 text-center bg-light">
                    <figure class="mb-0">
                      <blockquote class="blockquote fs-6">
                        <p class="mb-1 fw-bold">Jayrold Tabalina</p>
                      </blockquote>
                      <figcaption class="blockquote-footer mb-0">
                        Programmer <cite title="Source Title">PHINMA-University of Iloilo</cite>
                      </figcaption>
                    </figure>
                  </div>

                  <div class="border rounded p-3 mb-3 text-center bg-light">
                    <figure class="mb-0">
                      <blockquote class="blockquote fs-6">
                        <p class="mb-1 fw-bold">Yasmine M. Talaman</p>
                      </blockquote>
                      <figcaption class="blockquote-footer mb-0">
                        Documenter <cite title="Source Title">PHINMA-University of Iloilo</cite>
                      </figcaption>
                    </figure>
                  </div>

                  <div class="border rounded p-3 text-center bg-light">
                    <figure class="mb-0">
                      <blockquote class="blockquote fs-6">
                        <p class="mb-1 fw-bold">Mark Vincent Jabao</p>
                      </blockquote>
                      <figcaption class="blockquote-footer mb-0">
                        UI/UX <cite title="Source Title">PHINMA-University of Iloilo</cite>
                      </figcaption>
                    </figure>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%- include('../partials/footer'); %>
    </div>

    <%- include('../partials/page-end'); %>
</body>

</html>