<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body
  class="bg-gradient-glass-light dark:bg-gradient-glass-dark text-gray-800 dark:text-gray-100 min-h-screen flex flex-col">
  <%- include('../partials/page-start'); %>

    <header class="sticky top-0 z-50">
      <%- include('../partials/admin-navbar', { currentPage: 'about' }); %>
    </header>

    <div class="flex flex-1 overflow-hidden relative">
      <aside class="z-40">
        <%- include('../partials/admin-sidebar', { currentPage: 'about' }); %>
      </aside>

      <main class="flex-1 px-4 py-8 sm:px-6 lg:px-8 overflow-y-auto w-full">
        <div class="max-w-6xl mx-auto">

          <h1 class="text-3xl font-black text-gray-900 dark:text-gray-100 tracking-tight mb-8 text-center uppercase">
            PROJECT OVERVIEW</h1>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Project Info -->
            <div class="col-span-1 lg:col-span-2 glass-panel overflow-hidden flex flex-col">
              <div
                class="px-8 py-6 border-b border-gray-100 dark:border-gray-800 bg-indigo-50/50 dark:bg-indigo-900/10 flex items-center gap-4">
                <div
                  class="w-12 h-12 rounded-xl bg-indigo-600 dark:bg-indigo-500 text-white flex items-center justify-center shadow-lg shadow-indigo-500/30">
                  <i class="fa fa-shield-alt text-2xl"></i>
                </div>
                <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100">About CitySafe</h2>
              </div>
              <div class="p-8 flex-1 bg-white/40 dark:bg-gray-900/40">
                <div class="prose prose-indigo dark:prose-invert max-w-none text-gray-600 dark:text-gray-300">
                  <p class="text-lg leading-relaxed mb-6 font-medium">
                    CitySafe is a web-based disaster response architecture that provides real-time alerts, localized
                    notifications, and reliable information during critical emergencies. It serves as a unified nexus
                    empowering citizens to stay informed, transmit SOS distress signals, and supports municipal
                    officials and responders in orchestrating rapid relief operations efficiently.
                  </p>
                  <div
                    class="p-6 bg-gray-50/80 dark:bg-gray-800/80 rounded-2xl border-l-4 border-indigo-500 shadow-sm relative overflow-hidden">
                    <!-- Decorative blur -->
                    <div class="absolute -right-8 -top-8 w-24 h-24 bg-indigo-500/10 rounded-full blur-2xl"></div>
                    <p class="relative z-10 italic text-gray-700 dark:text-gray-300">
                      CitySafe was developed as a capstone research initiative entitled <strong
                        class="text-indigo-600 dark:text-indigo-400">“CitySafe: Urban Disaster Response App”</strong>.
                      The primary objective is establishing a resilient, efficient, and compassionate digital
                      infrastructure that amplifies disaster readiness and recovery in modern urban environments.
                    </p>
                    <p
                      class="relative z-10 text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mt-4">
                      — System Architecture Research Initiative
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Team Members -->
            <div class="col-span-1 glass-panel flex flex-col">
              <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-800 bg-white/40 dark:bg-gray-900/40">
                <h2 class="text-sm font-bold uppercase tracking-wider text-gray-700 dark:text-gray-300">Development
                  Personnel</h2>
              </div>
              <div class="p-6 space-y-4">

                <!-- Member 1 -->
                <div
                  class="group relative bg-white/60 dark:bg-gray-800/60 p-5 rounded-2xl border border-gray-100 dark:border-gray-700/50 hover:border-indigo-300 dark:hover:border-indigo-700 transition-all hover:shadow-lg hover:-translate-y-1">
                  <h3 class="font-black text-gray-900 dark:text-gray-100 text-lg">Jayrold Tabalina</h3>
                  <div class="flex items-center gap-2 mt-2">
                    <span
                      class="px-2 py-0.5 bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300 rounded text-[10px] font-bold uppercase tracking-widest">Lead
                      Engineering</span>
                  </div>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-3 font-medium">PHINMA - University of Iloilo</p>
                </div>

                <!-- Member 2 -->
                <div
                  class="group relative bg-white/60 dark:bg-gray-800/60 p-5 rounded-2xl border border-gray-100 dark:border-gray-700/50 hover:border-blue-300 dark:hover:border-blue-700 transition-all hover:shadow-lg hover:-translate-y-1">
                  <h3 class="font-black text-gray-900 dark:text-gray-100 text-lg">Yasmine M. Talaman</h3>
                  <div class="flex items-center gap-2 mt-2">
                    <span
                      class="px-2 py-0.5 bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300 rounded text-[10px] font-bold uppercase tracking-widest">Documentation</span>
                  </div>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-3 font-medium">PHINMA - University of Iloilo</p>
                </div>

                <!-- Member 3 -->
                <div
                  class="group relative bg-white/60 dark:bg-gray-800/60 p-5 rounded-2xl border border-gray-100 dark:border-gray-700/50 hover:border-purple-300 dark:hover:border-purple-700 transition-all hover:shadow-lg hover:-translate-y-1">
                  <h3 class="font-black text-gray-900 dark:text-gray-100 text-lg">Mark Vincent Jabao</h3>
                  <div class="flex items-center gap-2 mt-2">
                    <span
                      class="px-2 py-0.5 bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-300 rounded text-[10px] font-bold uppercase tracking-widest">UX/UI
                      Architecture</span>
                  </div>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-3 font-medium">PHINMA - University of Iloilo</p>
                </div>

              </div>
            </div>
          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>
      <script src="/js/script.js"></script>
</body>

</html>