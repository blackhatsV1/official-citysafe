<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <title>Verify Account | CitySafe</title>
</head>

<body class="app app-login p-0">
    <%- include('../partials/page-start'); %>
        <div class="row g-0 app-auth-wrapper justify-content-center align-items-center w-100"
            style="min-height: 100vh;">
            <div class="col-12 col-md-7 col-lg-6 col-xl-4 auth-main-col text-center p-5">
                <div class="d-flex flex-column align-content-end">
                    <div class="app-auth-body mx-auto shadow-sm p-5 bg-white rounded border w-100">
                        <div class="app-auth-branding mb-4">
                            <a class="app-logo" href="/">
                                <h3 class="text-primary"><i class="fa fa-user-edit me-2"></i>CitySafe</h3>
                            </a>
                        </div>
                        <h2 class="auth-heading text-center mb-4">Verify</h2>
                        <div class="auth-intro mb-4 text-center text-muted">We sent a 6-digit code to your <%= method
                                || 'contact info' %>.</div>

                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="alert alert-danger" role="alert">
                                <%= error %>
                            </div>
                            <% } %>

                                <form action="/verify-code" method="POST" class="auth-form login-form text-start">
                                    <input type="hidden" name="email" value="<%= email %>">
                                    <div class="form-floating mb-3">
                                        <input type="text" class="form-control" name="code" id="floatingInput"
                                            placeholder="123456" required>
                                        <label for="floatingInput">Enter 6-Digit Code</label>
                                    </div>
                                    <div class="text-center">
                                        <button type="submit"
                                            class="btn app-btn-primary w-100 theme-btn mx-auto py-3 mb-4">Verify
                                            Account</button>
                                    </div>
                                </form>

                                <div class="auth-option text-center pt-3 text-muted">
                                    Didn't receive it? <a class="text-link"
                                        href="/resend-code?email=<%= email %>">Resend Code</a>
                                </div>
                    </div>
                </div>
            </div>
        </div>
        <%- include('../partials/page-end'); %>
            <script src="/js/script.js"></script>
            <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
</body>

</html>