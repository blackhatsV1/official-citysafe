<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <title>Verify Account | CitySafe</title>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <div>
            <!-- Auth Form Column (Centered for Verify) -->
            <div>
                <!-- Decorative blur background -->
                <div>
                    <div>
                    </div>
                </div>

                <div>
                    <!-- Branding -->
                    <div>
                        <a href="/">
                            <div>
                                <i></i>
                            </div>
                        </a>
                        <h2>Verification
                        </h2>
                        <p>
                            We sent a 6-digit transmission code to your <br>
                            <strong>
                                <%= method || 'contact info' %>
                            </strong>.
                        </p>
                    </div>

                    <% if (typeof error !=='undefined' && error) { %>
                        <div>
                            <i></i>
                            <%= error %>
                        </div>
                        <% } %>

                            <!-- Form -->
                            <form method="POST" action="/verify-code">
                                <input type="hidden" name="email" value="<%= email %>">

                                <div>
                                    <label for="code">Auth
                                        Code</label>
                                    <div>
                                        <input type="text" id="code" name="code"
                                            placeholder="••••••" maxlength="6" required autofocus>
                                    </div>
                                </div>

                                <button type="submit">
                                    <i></i> VERIFY IDENTITY
                                </button>
                            </form>

                            <!-- Footer text -->
                            <div>
                                <p>
                                    Didn't receive the transmission? <br>
                                    <a href="/resend-code?email=<%= email %>">
                                        <i></i> Resend Code
                                    </a>
                                </p>
                            </div>
                </div>
            </div>
        </div>

        <%- include('../partials/page-end'); %>
            <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
            <script src="/js/script.js"></script>
</body>

</html>