<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="app">
    <%- include('../partials/page-start'); %>

        <header class="app-header fixed-top">
            <%- include('../partials/user-navbar'); %>
                <%- include('../partials/user-sidebar'); %>
        </header>

        <div class="app-wrapper">
            <div class="app-content pt-3 p-md-3 p-lg-4">
                <div class="container-xl">
                    <h1 class="app-page-title">Help & Support</h1>

                    <div class="row g-4 mb-4">
                        <div class="col-12 col-lg-8">
                            <div class="app-card app-card-settings shadow-sm p-4 h-100">
                                <div class="app-card-body">
                                    <p class="text-muted mb-4">
                                        If you are experiencing any issues or have any questions, we are here to help!
                                        Below are some commonly asked questions and their answers.
                                    </p>

                                    <div class="accordion accordion-flush" id="faqAccordion">
                                        <div class="accordion-item border-bottom">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed fw-bold px-0 bg-transparent"
                                                    type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                                    How do I report an emergency?
                                                </button>
                                            </h2>
                                            <div id="faq1" class="accordion-collapse collapse"
                                                data-bs-parent="#faqAccordion">
                                                <div class="accordion-body px-0 text-muted">
                                                    Use the "One-Tap SOS Reporting" feature to quickly send a distress
                                                    signal to our team. We will respond as soon as possible to assist
                                                    you.
                                                </div>
                                            </div>
                                        </div>

                                        <div class="accordion-item border-bottom">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed fw-bold px-0 bg-transparent"
                                                    type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                                    How can I track my report status?
                                                </button>
                                            </h2>
                                            <div id="faq2" class="accordion-collapse collapse"
                                                data-bs-parent="#faqAccordion">
                                                <div class="accordion-body px-0 text-muted">
                                                    Go to "My Reports" to view the status of your reported incidents and
                                                    see if a responder has been assigned to your location.
                                                </div>
                                            </div>
                                        </div>

                                        <div class="accordion-item border-bottom">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed fw-bold px-0 bg-transparent"
                                                    type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                                    How do I find nearby safe zones?
                                                </button>
                                            </h2>
                                            <div id="faq3" class="accordion-collapse collapse"
                                                data-bs-parent="#faqAccordion">
                                                <div class="accordion-body px-0 text-muted">
                                                    Visit the "Nearby Stations" page to view a map of police stations,
                                                    fire stations, and hospitals near you for quick navigation.
                                                </div>
                                            </div>
                                        </div>

                                        <div class="accordion-item border-bottom">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed fw-bold px-0 bg-transparent"
                                                    type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                                    How do I check the weather?
                                                </button>
                                            </h2>
                                            <div id="faq4" class="accordion-collapse collapse"
                                                data-bs-parent="#faqAccordion">
                                                <div class="accordion-body px-0 text-muted">
                                                    The "Weather" page provides real-time updates on local weather
                                                    conditions to help you stay prepared for any potential hazards.
                                                </div>
                                            </div>
                                        </div>

                                        <div class="accordion-item border-0">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed fw-bold px-0 bg-transparent"
                                                    type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                                                    What is the Community Risk Assessment Tool?
                                                </button>
                                            </h2>
                                            <div id="faq5" class="accordion-collapse collapse"
                                                data-bs-parent="#faqAccordion">
                                                <div class="accordion-body px-0 text-muted">
                                                    This tool helps assess disaster risks in your area, providing
                                                    important data on natural disasters and preparedness.
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-4">
                            <div class="app-card app-card-settings shadow-sm p-4 mb-4">
                                <h4 class="app-card-title mb-3">Contact Us</h4>
                                <div class="app-card-body">
                                    <p class="text-muted small">Need further assistance?</p>
                                    <div class="list-group list-group-flush">
                                        <div
                                            class="list-group-item bg-transparent px-0 border-light d-flex flex-column">
                                            <small class="text-muted fw-bold">Email</small>
                                            <span class="text-primary">jayr.tabalina.ui@phinmaed.com</span>
                                        </div>
                                        <div
                                            class="list-group-item bg-transparent px-0 border-light d-flex flex-column">
                                            <small class="text-muted fw-bold">Phone</small>
                                            <span>(+63) 993 978 4619</span>
                                        </div>
                                        <div class="list-group-item bg-transparent px-0 border-0 d-flex flex-column">
                                            <small class="text-muted fw-bold">Social Media</small>
                                            <span class="text-info">@CitySafeOfficial</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="app-card app-card-notification shadow-sm p-4">
                                <h4 class="app-card-title mb-3">Emergency Hotlines</h4>
                                <div class="app-card-body">
                                    <div
                                        class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold">National Hotline</span>
                                        </div>
                                        <span class="badge bg-danger fs-6">911</span>
                                    </div>
                                    <div
                                        class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold">PNP (Police)</span>
                                            <small class="text-muted">(02) 8722-0650</small>
                                        </div>
                                        <span class="badge bg-primary fs-6">117</span>
                                    </div>
                                    <div
                                        class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold">BFP (Fire)</span>
                                        </div>
                                        <span class="badge bg-warning text-dark fs-6">(02) 8426</span>
                                    </div>
                                    <div
                                        class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold">Red Cross</span>
                                            <small class="text-muted">(02) 8790-2300</small>
                                        </div>
                                        <span class="badge bg-info text-white fs-6">143</span>
                                    </div>
                                    <div
                                        class="d-flex justify-content-between align-items-center border-bottom border-light py-2">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold">MMDA</span>
                                        </div>
                                        <span class="badge bg-success fs-6">136</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center py-2">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold">NDRRMC Opcen</span>
                                        </div>
                                        <span class="badge bg-secondary fs-6 text-dark">(02) 8911</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('../partials/footer'); %>
        </div>

        <%- include('../partials/page-end'); %>
</body>

</html>