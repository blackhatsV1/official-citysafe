<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        
        <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.min.js"></script>
        
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/responder-navbar', { currentPage: 'responder' }); %>
        </header>

        <div>
            <aside>
                <%- include('../partials/responder-sidebar', { currentPage: 'responder' }); %>
            </aside>

            <main>
                <div>

                    <div>
                        <h1>
                            <div>
                                <i></i>
                            </div>
                            Field Operations
                        </h1>
                        <div>
                            <div></div> LIVE SYSTEM ACTIVE
                        </div>
                    </div>

                    <div>

                        <!-- Map Component -->
                        <div>
                            <div>
                                <h4>
                                    <i></i> Operations Grid
                                </h4>
                            </div>
                            <div>
                                <div id="map">
                                </div>

                                <!-- GPS Status Overlay -->
                                <div>
                                    <div>
                                        <i></i>
                                        <span id="locationStatus">Initializing
                                            GPS...</span>
                                    </div>
                                    <div>
                                        <div></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Local Deployments Table -->
                        <div
                            id="nearby-reports">
                            <div>
                                <h4>
                                    <i></i> Local Deployments
                                </h4>
                                <div>
                                    2KM Radius Active
                                </div>
                            </div>
                            <div>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>
                                                Timestamp</th>
                                            <th>
                                                Reported By</th>
                                            <th>
                                                Classification</th>
                                            <th>
                                                Operational Address</th>
                                            <th>
                                                Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="reportsTableBody">
                                        <tr>
                                            <td colspan="5">
                                                <i></i>
                                                <p>Scanning
                                                    operational sectors for reported incidents...</p>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>

                </div>
            </main>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            // Use glassmorphism theme for SweetAlert
            const GlassSwal = Swal.mixin({
                customClass: {
                    popup: 'glass-swal',
                    confirmButton: 'rounded-lg px-4 py-2 font-bold uppercase tracking-widest text-xs shadow-md shadow-emerald-500/20',
                    cancelButton: 'rounded-lg px-4 py-2 font-bold uppercase tracking-widest text-xs'
                },
                background: document.documentElement.classList.contains('dark') ? 'rgba(17, 24, 39, 0.9)' : 'rgba(255, 255, 255, 0.9)',
                color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
            });

            const map = L.map('map', { zoomControl: false }).setView([10.7202, 122.5621], 13);
            L.control.zoom({ position: 'bottomright' }).addTo(map);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap | Carto'
            }).addTo(map);

            let userLocation = null;
            let userMarker = null;
            let userCircle = null;
            const currentMarkers = {};
            const addressCache = {};

            const icons = {
                'default': L.icon({
                    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
                    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
                    iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
                })
            };

            function addMarker(report) {
                if (currentMarkers[report.id]) return;

                const marker = L.marker([report.latitude, report.longitude], {
                    icon: icons['default']
                }).addTo(map);

                const date = new Date(report.reported_at).toLocaleString();
                const popupContent = `
                <div>
                    <div>
                        ${report.disaster_type}
                    </div>
                    <p>
                        <span>Status:</span> <span>${report.status.toUpperCase()}</span>
                    </p>
                    <p>
                        <span>Logged:</span> <span>${date}</span>
                    </p>
                    
                    <div id="addr-${report.id}">
                        <i></i> Resolving address...
                    </div>
                    
                    <button onclick="respondToReport(${report.id}, '${report.disaster_type}')">
                        DEPLOY NOW
                    </button>
                </div>
            `;
                marker.bindPopup(popupContent, { className: 'glass-popup' });

                marker.on('popupopen', () => {
                    const el = document.getElementById(`addr-${report.id}`);
                    if (!el || !el.innerText.includes('Resolving')) return;

                    if (addressCache[report.id]) {
                        el.innerText = addressCache[report.id];
                    } else {
                        fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${report.latitude}&lon=${report.longitude}`)
                            .then(r => r.json())
                            .then(d => {
                                const addr = d.display_name || "Unknown Coordinates";
                                addressCache[report.id] = addr;
                                if (el) el.innerText = addr;
                                const tableAddr = document.getElementById(`table-addr-${report.id}`);
                                if (tableAddr) tableAddr.innerText = addr;
                            });
                    }
                });
                currentMarkers[report.id] = marker;
            }

            function getDistanceFromLatLonInKm(lat1, lon1, lat2, lon2) {
                const R = 6371;
                const dLat = (lat2 - lat1) * Math.PI / 180;
                const dLon = (lon2 - lon1) * Math.PI / 180;
                const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLon / 2) * Math.sin(dLon / 2);
                return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            }

            window.respondToReport = function (id, type) {
                GlassSwal.fire({
                    title: '<span>Deploy Mission?</span>',
                    html: `<span>Confirm operational deployment to recorded <b>${type}</b> incident?</span>`,
                    icon: 'warning',
                    iconColor: '#10b981',
                    showCancelButton: true,
                    confirmButtonColor: '#10b981',
                    cancelButtonColor: '#6b7280',
                    confirmButtonText: 'CONFIRM DEPLOY'
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch('/api/respond', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ reportId: id })
                        })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    GlassSwal.fire({
                                        icon: 'success',
                                        title: '<span>ACCEPTED</span>',
                                        showConfirmButton: false,
                                        timer: 1500
                                    }).then(() => window.location.href = '/responding');
                                } else {
                                    GlassSwal.fire('Error', data.message || data.error, 'error');
                                }
                            });
                    }
                });
            };

            function pollResponder() {
                fetch('/api/responder-reports')
                    .then(res => res.json())
                    .then(newReports => {
                        const newIds = new Set(newReports.map(r => r.id));
                        newReports.forEach(r => addMarker(r));
                        Object.keys(currentMarkers).forEach(id => {
                            if (!newIds.has(parseInt(id))) {
                                map.removeLayer(currentMarkers[id]);
                                delete currentMarkers[id];
                            }
                        });
                        updateNearbyTable(newReports);
                    })
                    .catch(err => console.error("Polling error:", err));
            }

            function updateNearbyTable(reportsList) {
                if (!userLocation) return;
                const tbody = document.getElementById('reportsTableBody');
                let rows = '';
                let hasNearby = false;

                reportsList.forEach(report => {
                    if (!report.latitude || !report.longitude) return;
                    const dist = getDistanceFromLatLonInKm(userLocation.lat, userLocation.lon, report.latitude, report.longitude);

                    if (dist <= 2) {
                        hasNearby = true;
                        const dateStr = new Date(report.reported_at).toLocaleString();
                        const reporterName = (report.firstname && report.lastname) ? `${report.firstname} ${report.lastname}` : 'Anonymous Citizen';
                        const addr = addressCache[report.id] || "Pending Geocode...";

                        rows += `
                    <tr>
                        <td>${dateStr}</td>
                        <td>
                            <div>
                                <div>
                                    <i></i>
                                </div>
                                <span>${reporterName}</span>
                            </div>
                        </td>
                        <td>
                            <span>
                                ${report.disaster_type}
                            </span>
                        </td>
                        <td>
                            <span id="table-addr-${report.id}">
                                ${addr}
                            </span>
                        </td>
                        <td>
                            <button onclick="respondToReport(${report.id}, '${report.disaster_type}')">
                                DEPLOY
                            </button>
                        </td>
                    </tr>
                `;
                    }
                });

                if (!hasNearby) {
                    rows = '<tr><td colspan="5">No active incidents detected in your immediate sector.</td></tr>';
                }
                tbody.innerHTML = rows;
            }

            if (navigator.geolocation) {
                navigator.geolocation.watchPosition(pos => {
                    userLocation = { lat: pos.coords.latitude, lon: pos.coords.longitude };
                    document.getElementById('locationStatus').innerText = `LAT: ${userLocation.lat.toFixed(4)} | LNG: ${userLocation.lon.toFixed(4)}`;

                    const responderIcon = L.divIcon({
                        className: 'bg-transparent',
                        html: `
                        <div>
                            <span></span>
                            <span>
                                <i></i>
                            </span>
                        </div>
                    `,
                        iconSize: [32, 32], iconAnchor: [16, 16]
                    });

                    if (userMarker) {
                        userMarker.setLatLng([userLocation.lat, userLocation.lon]);
                        userCircle.setLatLng([userLocation.lat, userLocation.lon]);
                    } else {
                        userMarker = L.marker([userLocation.lat, userLocation.lon], { icon: responderIcon }).addTo(map).bindPopup("<b>Your Unit Position</b>", { className: 'glass-popup' }).openPopup();
                        userCircle = L.circle([userLocation.lat, userLocation.lon], {
                            color: '#3b82f6', weight: 1, fillColor: '#3b82f6', fillOpacity: 0.05, radius: 2000
                        }).addTo(map);
                    }

                    fetch('/api/responder/location', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ lat: userLocation.lat, lng: userLocation.lon })
                    });
                }, null, { enableHighAccuracy: true });
            }

            setInterval(pollResponder, 5000);
            pollResponder();
            window.addEventListener('load', () => setTimeout(() => map.invalidateSize(), 500));
        </script>
        <%- include('../partials/page-end'); %>
</body>

</html>