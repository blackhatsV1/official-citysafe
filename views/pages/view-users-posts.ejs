<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>
</head>

<body>
  <%- include('../partials/page-start'); %>

    <header>
      <%- include('../partials/admin-navbar', { currentPage: 'view-users-posts' }); %>
    </header>

    <div>
      <aside>
        <%- include('../partials/admin-sidebar', { currentPage: 'view-users-posts' }); %>
      </aside>

      <main>
        <div>

          <div>
            <h1>RECENT POSTS</h1>
            <div>
              <span>To see advanced metrics, explore
                the</span>
              <a href="/reports">
                <i></i> Analytics
              </a>
            </div>
          </div>

          <div>
            <% for (let i=0; i < users.length; i++) { %>
              <div>
                <div>
                  <div>
                    <i></i>
                  </div>
                  <div>
                    <h3>
                      <%= users[i].name %>
                    </h3>
                    <span>Posted: <%=
                        users[i].created_at %></span>
                  </div>
                </div>

                <div>
                  <div>
                    <div>
                      <span>Location</span>
                      <p>
                        <%= users[i].location %>
                      </p>
                    </div>
                    <div></div>
                    <div>
                      <span>Requesting
                        For</span>
                      <p>
                        <%= users[i].needs %>
                      </p>
                    </div>
                  </div>

                  <div>
                    <span>
                      <i></i> Local Helpers: <%= users[i].help_count %>
                    </span>

                    <div>
                      <!-- Note: Resolve button logic was href='#' in old design -->
                      <button type="button"
                        onclick="window.location.href='#'">
                        MARK AS RESOLVED
                      </button>

                      <div>
                        <button form="holdForm_<%= users[i].id %>" type="submit"
                          onclick="return confirm('Suspend this request?')">
                          <i></i> SUSPEND
                        </button>
                        <button form="deleteForm_<%= users[i].id %>" type="submit"
                          onclick="return confirm('Permanently remove this post?')">
                          <i></i> REMOVE
                        </button>
                      </div>
                    </div>

                    <form id="holdForm_<%= users[i].id %>" action="#" method="POST"></form>
                    <form id="deleteForm_<%= users[i].id %>" action="#" method="POST"></form>
                  </div>
                </div>
              </div>
              <% } %>

                <% if (users.length===0) { %>
                  <div>
                    <div>
                      <i></i>
                    </div>
                    <h3>No Recent Broadcasts</h3>
                    <p>There are currently no active requests for
                      assistance in the operations sector.</p>
                  </div>
                  <% } %>
          </div>

        </div>
      </main>
    </div>

    <%- include('../partials/footer'); %>
      <script src="/js/script.js"></script>
</body>

</html>