<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <script
            src="https://cdnjs.cloudflare.com/ajax/libs/OverlappingMarkerSpiderfier-Leaflet/0.2.6/oms.min.js"></script>

        <script src="https://unpkg.com/leaflet-routing-machine@latest/dist/leaflet-routing-machine.min.js"></script>
</head>

<body>
    <%- include('../partials/page-start'); %>

        <header>
            <%- include('../partials/admin-navbar', { currentPage: 'dashboard' }); %>
        </header>

        <div class="cs-layout-container">
            <aside>
                <%- include('../partials/admin-sidebar', { currentPage: 'dashboard' }); %>
            </aside>

            <main class="cs-main-content">
                <div class="cs-container">

                    <!-- Operations Command Header -->
                    <div
                        style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3.5rem; gap: 2rem; flex-wrap: wrap;">
                        <div style="flex: 1; min-width: 300px;">
                            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
                                <div class="cs-badge" style="background: var(--primary-glow); color: var(--primary);"><i
                                        class="fa-solid fa-tower-observation"></i></div>
                                <h1 class="cs-section-header" style="margin: 0;">OPERATIONS <span
                                        style="background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">COMMAND</span>
                                </h1>
                            </div>
                            <div style="display: flex; align-items: center; gap: 1rem;">
                                <span class="cs-badge"
                                    style="color: #10b981; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); font-size: 0.7rem; font-weight: 800;">
                                    <span
                                        style="width: 8px; height: 8px; background: #10b981; border-radius: 50%; display: inline-block; margin-right: 0.4rem; box-shadow: 0 0 8px #10b981;"
                                        class="fa-beat-fade"></span>
                                    SYSTEM NOMINAL
                                </span>
                                <span
                                    style="font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; font-weight: 800; letter-spacing: 0.1rem;">REGIONAL
                                    GRID CLUSTER: ALPHA-01</span>
                            </div>
                        </div>

                        <div style="display: flex; gap: 1.5rem;">
                            <!-- Stat Card: Operatives -->
                            <div class="cs-card"
                                style="padding: 1.25rem 2rem; min-width: 160px; position: relative; overflow: hidden; border-left: 4px solid var(--primary);">
                                <div
                                    style="position: absolute; top: -20px; right: -20px; font-size: 4rem; color: var(--primary); opacity: 0.05; transform: rotate(-15deg);">
                                    <i class="fa-solid fa-users-gear"></i>
                                </div>
                                <span
                                    style="display: block; font-size: 0.65rem; color: var(--text-dim); font-weight: 800; text-transform: uppercase; letter-spacing: 0.05rem; margin-bottom: 0.5rem;">TOTAL
                                    OPERATIVES</span>
                                <div id="total-users-count"
                                    style="font-size: 2.25rem; font-weight: 900; color: var(--text-bright); line-height: 1;">
                                    <%= totalUsers %>
                                </div>
                                <div
                                    style="margin-top: 0.5rem; height: 3px; background: rgba(255,255,255,0.05); border-radius: 1rem; overflow: hidden;">
                                    <div style="width: 70%; height: 100%; background: var(--primary);"></div>
                                </div>
                            </div>
                            <!-- Stat Card: Missions -->
                            <div class="cs-card"
                                style="padding: 1.25rem 2rem; min-width: 160px; position: relative; overflow: hidden; border-left: 4px solid var(--accent);">
                                <div
                                    style="position: absolute; top: -20px; right: -20px; font-size: 4rem; color: var(--accent); opacity: 0.05; transform: rotate(-15deg);">
                                    <i class="fa-solid fa-jet-fighter-up"></i>
                                </div>
                                <span
                                    style="display: block; font-size: 0.65rem; color: var(--text-dim); font-weight: 800; text-transform: uppercase; letter-spacing: 0.05rem; margin-bottom: 0.5rem;">ACTIVE
                                    MISSIONS</span>
                                <a href="/disaster-reports" id="total-requests-count"
                                    style="font-size: 2.25rem; font-weight: 900; color: var(--text-bright); line-height: 1; text-decoration: none; display: block;">
                                    <%= totalRequests %>
                                </a>
                                <div
                                    style="margin-top: 0.5rem; height: 3px; background: rgba(255,255,255,0.05); border-radius: 1rem; overflow: hidden;">
                                    <div style="width: 45%; height: 100%; background: var(--accent);"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Intelligence Grid -->
                    <div class="cs-grid cs-grid-2"
                        style="grid-template-columns: 2fr 1fr; margin-bottom: 3rem; gap: 2rem;">
                        <!-- Map Intelligence -->
                        <div class="cs-card"
                            style="padding: 0; overflow: hidden; border: 1px solid var(--border-glass);">
                            <div
                                style="padding: 1.25rem 2rem; border-bottom: 1px solid var(--border-glass); background: rgba(255,255,255,0.02); display: flex; align-items: center; gap: 1rem;">
                                <div class="cs-badge" style="background: var(--primary-glow); color: var(--primary);"><i
                                        class="fa-solid fa-earth-asia"></i></div>
                                <h2 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                    GEOSPATIAL INTELLIGENCE</h2>
                                <div style="margin-left: auto; display: flex; gap: 0.5rem;">
                                    <button onclick="refreshAdminMapData();" class="cs-badge"
                                        style="background: rgba(255,255,255,0.05); color: var(--text-dim); cursor: pointer; border: 1px solid var(--border-glass); font-size: 0.7rem; font-weight: 800; padding: 0.5rem 1rem;">
                                        <i class="fa-solid fa-arrows-rotate"></i> SYNC FEED
                                    </button>
                                </div>
                            </div>
                            <div style="padding: 1rem; background: rgba(0,0,0,0.2);">
                                <div class="cs-map-container"
                                    style="height: 520px; border-radius: 0.75rem; border: 1px solid var(--border-glass);">
                                    <div id="admin-map" style="height: 100%;"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Critical Threat Stream -->
                        <div class="cs-card"
                            style="padding: 0; display: flex; flex-direction: column; border: 1px solid rgba(239, 68, 68, 0.2);">
                            <div
                                style="padding: 1.25rem 2rem; border-bottom: 1px solid rgba(239, 68, 68, 0.2); background: rgba(239, 68, 68, 0.05); display: flex; align-items: center; gap: 1.5rem;">
                                <div class="cs-badge" style="background: var(--danger-glow); color: var(--danger);"><i
                                        class="fa-solid fa-radiation fa-spin"></i></div>
                                <h2 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--danger);">
                                    CRITICAL ALERTS</h2>
                                <a href="/assessment-results"
                                    style="margin-left: auto; color: var(--danger); font-size: 0.7rem; font-weight: 900; text-decoration: none; letter-spacing: 0.05rem;">FULL
                                    REPORT</a>
                            </div>

                            <div style="flex: 1; overflow-y: auto; max-height: 540px; padding: 1.5rem;"
                                class="cs-custom-scrollbar">
                                <% if (riskTables['High'] && riskTables['High'].length> 0) { %>
                                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                                        <% riskTables['High'].slice(0, 10).forEach(user=> { %>
                                            <div class="cs-card"
                                                style="background: rgba(239, 68, 68, 0.03); border: 1px solid rgba(239, 68, 68, 0.15); padding: 1.25rem; transition: all 0.2s ease; cursor: pointer;"
                                                onmouseover="this.style.background='rgba(239, 68, 68, 0.08)'; this.style.borderColor='rgba(239, 68, 68, 0.3)'"
                                                onmouseout="this.style.background='rgba(239, 68, 68, 0.03)'; this.style.borderColor='rgba(239, 68, 68, 0.15)'">
                                                <div
                                                    style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
                                                    <div style="display: flex; align-items: center; gap: 1rem;">
                                                        <div class="cs-badge"
                                                            style="width: 32px; height: 32px; background: var(--danger); color: white; border: none; font-size: 0.75rem;">
                                                            <i class="fa-solid fa-user-shield"></i>
                                                        </div>
                                                        <span
                                                            style="font-weight: 800; color: var(--text-bright); font-size: 0.95rem;">
                                                            <%= user.username %>
                                                        </span>
                                                    </div>
                                                    <span class="cs-badge"
                                                        style="background: var(--danger-glow); color: var(--danger); font-size: 0.65rem; font-weight: 900; border-color: var(--danger);">VULNERABLE</span>
                                                </div>
                                                <div style="display: flex; align-items: center; gap: 1rem;">
                                                    <div
                                                        style="flex: 1; height: 4px; background: rgba(0,0,0,0.3); border-radius: 4px; overflow: hidden;">
                                                        <div
                                                            style="width: <%= user.risk_score %>%; height: 100%; background: var(--danger); box-shadow: 0 0 10px var(--danger);">
                                                        </div>
                                                    </div>
                                                    <span
                                                        style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; font-weight: 800; color: var(--danger); min-width: 40px;">
                                                        <%= user.risk_score %>%
                                                    </span>
                                                </div>
                                            </div>
                                            <% }) %>
                                    </div>
                                    <% } else { %>
                                        <div
                                            style="height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 2rem; text-align: center; opacity: 0.5;">
                                            <div class="cs-badge"
                                                style="width: 80px; height: 80px; font-size: 2.5rem; background: rgba(255,255,255,0.02); color: var(--text-dim); border-style: dashed; margin-bottom: 2rem;">
                                                <i class="fa-solid fa-shield-virus"></i>
                                            </div>
                                            <h3
                                                style="margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-bright);">
                                                NO THREATS DETECTED</h3>
                                            <p style="margin-top: 0.5rem; font-size: 0.9rem;">Sector intelligence
                                                indicates zero high-risk individuals at this timestamp.</p>
                                        </div>
                                        <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Analytics Grid -->
                    <div class="cs-grid cs-grid-2" style="margin-bottom: 2rem; gap: 2rem;">
                        <!-- Trend Analysis -->
                        <div class="cs-card"
                            style="padding: 0; overflow: hidden; border: 1px solid var(--border-glass);">
                            <div
                                style="padding: 1.25rem 2rem; border-bottom: 1px solid var(--border-glass); background: rgba(255,255,255,0.02); display: flex; align-items: center; gap: 1rem;">
                                <div class="cs-badge" style="background: var(--primary-glow); color: var(--primary);"><i
                                        class="fa-solid fa-microchip"></i></div>
                                <h2 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                    MISSION TELEMETRY</h2>
                            </div>
                            <div style="padding: 2rem;">
                                <div style="height: 320px; position: relative;">
                                    <canvas id="userChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- Stratification -->
                        <div class="cs-card"
                            style="padding: 0; overflow: hidden; border: 1px solid var(--border-glass);">
                            <div
                                style="padding: 1.25rem 2rem; border-bottom: 1px solid var(--border-glass); background: rgba(255,255,255,0.02); display: flex; align-items: center; gap: 1rem;">
                                <div class="cs-badge" style="background: var(--accent-glow); color: var(--accent);"><i
                                        class="fa-solid fa-signature"></i></div>
                                <h2 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-bright);">
                                    RISK STRATIFICATION</h2>
                            </div>
                            <div style="padding: 2rem;">
                                <div style="display: flex; align-items: center; gap: 3rem; height: 320px;">
                                    <div style="flex: 1; height: 100%; position: relative;">
                                        <canvas id="riskLevelChart"></canvas>
                                    </div>
                                    <div style="display: flex; flex-direction: column; gap: 1.25rem; min-width: 160px;">
                                        <div
                                            style="padding: 1rem; background: rgba(0,0,0,0.2); border-radius: 0.75rem; border: 1px solid rgba(239, 68, 68, 0.15); display: flex; align-items: center; gap: 1rem;">
                                            <span
                                                style="width: 10px; height: 10px; border-radius: 50%; background: var(--danger); box-shadow: 0 0 8px var(--danger);"></span>
                                            <div>
                                                <div
                                                    style="font-size: 0.55rem; font-weight: 900; color: var(--danger); text-transform: uppercase;">
                                                    CRITICAL</div>
                                                <div
                                                    style="font-size: 0.85rem; font-weight: 700; color: var(--text-bright);">
                                                    <%= riskTables['High'] ? riskTables['High'].length : 0 %> NODES
                                                </div>
                                            </div>
                                        </div>
                                        <div
                                            style="padding: 1rem; background: rgba(0,0,0,0.2); border-radius: 0.75rem; border: 1px solid rgba(245, 158, 11, 0.15); display: flex; align-items: center; gap: 1rem;">
                                            <span
                                                style="width: 10px; height: 10px; border-radius: 50%; background: var(--warning); box-shadow: 0 0 8px var(--warning);"></span>
                                            <div>
                                                <div
                                                    style="font-size: 0.55rem; font-weight: 900; color: var(--warning); text-transform: uppercase;">
                                                    ELEVATED</div>
                                                <div
                                                    style="font-size: 0.85rem; font-weight: 700; color: var(--text-bright);">
                                                    <%= riskTables['Medium'] ? riskTables['Medium'].length : 0 %> NODES
                                                </div>
                                            </div>
                                        </div>
                                        <div
                                            style="padding: 1rem; background: rgba(0,0,0,0.2); border-radius: 0.75rem; border: 1px solid rgba(16, 185, 129, 0.15); display: flex; align-items: center; gap: 1rem;">
                                            <span
                                                style="width: 10px; height: 10px; border-radius: 50%; background: #10b981; box-shadow: 0 0 8px #10b981;"></span>
                                            <div>
                                                <div
                                                    style="font-size: 0.55rem; font-weight: 900; color: #10b981; text-transform: uppercase;">
                                                    SECURE</div>
                                                <div
                                                    style="font-size: 0.85rem; font-weight: 700; color: var(--text-bright);">
                                                    <%= riskTables['Low'] ? riskTables['Low'].length : 0 %> NODES
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- System Performance -->
                    <div class="cs-grid cs-grid-3" style="gap: 2rem;">
                        <% [ { id: 'checklistChart' , icon: 'fa-clipboard-check' , title: 'COMPLIANCE' ,
                            color: 'var(--primary)' }, { id: 'trendChart' , icon: 'fa-arrow-trend-up' ,
                            title: 'VELOCITY' , color: 'var(--accent)' }, { id: 'hazardsChart' , icon: 'fa-biohazard' ,
                            title: 'HAZARDS' , color: 'var(--danger)' } ].forEach(widget=> { %>
                            <div class="cs-card"
                                style="padding: 0; overflow: hidden; border: 1px solid var(--border-glass);">
                                <div
                                    style="padding: 1rem 1.5rem; border-bottom: 1px solid var(--border-glass); background: rgba(255,255,255,0.02); display: flex; align-items: center; gap: 0.75rem;">
                                    <i class="fa-solid <%= widget.icon %>"
                                        style="color: <%= widget.color %>; font-size: 0.9rem;"></i>
                                    <h2
                                        style="margin: 0; font-size: 0.8rem; font-weight: 800; color: var(--text-bright); letter-spacing: 0.05rem;">
                                        <%= widget.title %>
                                    </h2>
                                </div>
                                <div style="padding: 1.5rem;">
                                    <div style="height: 160px; position: relative;">
                                        <canvas id="<%= widget.id %>"></canvas>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>

                </div>
            </main>
        </div>
        </main>
        </div>

        <%- include('../partials/footer'); %>

            <!-- Scripts -->
            <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
            <script src="/js/script.js"></script>

            <script>
                (function ($) {
                    "use strict";

                    const getComputedStyleVar = (name) => getComputedStyle(document.documentElement).getPropertyValue(name).trim();

                    Chart.defaults.color = getComputedStyleVar('--text-dim') || "#94a3b8";
                    Chart.defaults.borderColor = "rgba(255,255,255,0.05)";
                    Chart.defaults.font.family = "'Inter', sans-serif";
                    Chart.defaults.font.weight = '600';

                    // Listen for theme changes to update chart colors dynamically if needed...

                    // --- Incident Trends ---
                    new Chart($("#userChart").get(0).getContext("2d"), {
                        type: "bar",
                        data: {
                            labels: <% - JSON.stringify(chartData.map(d => d.day)) %>,
                            datasets: [{
                                label: "Incoming Reports",
                                data: <% - JSON.stringify(chartData.map(d => d.total)) %>,
                                backgroundColor: "#6366f1",
                                borderRadius: 6
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: { y: { beginAtZero: true, grid: { borderDash: [5, 5] } }, x: { grid: { display: false } } }
                        }
                    });

                    // --- Risk Stratification ---
                    new Chart($("#riskLevelChart").get(0).getContext("2d"), {
                        type: "doughnut",
                        data: {
                            labels: <% - JSON.stringify(riskLevelData.map(d => d.risk_level)) %>,
                            datasets: [{
                                data: <% - JSON.stringify(riskLevelData.map(d => d.total)) %>,
                                backgroundColor: document.documentElement.classList.contains('dark') ? ["#f8fafc", "#94a3b8", "#475569", "#1e293b"] : ["#111827", "#4b5563", "#9ca3af", "#e5e7eb"],
                                borderWidth: 0
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: false, cutout: '75%', plugins: { legend: { display: false } } }
                    });

                    // --- Other Charts ---
                    new Chart($("#checklistChart").get(0).getContext("2d"), {
                        type: "bar",
                        data: {
                            labels: ["River", "Fault", "Kit", "Plan"],
                            datasets: [{
                                data: [<%= checklistData.near_river %>, <%= checklistData.near_fault %>, <%= checklistData.has_emergency_kit %>, <%= checklistData.has_evacuation_plan %>],
                                backgroundColor: "#3b82f6",
                                borderRadius: 4
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } } } }
                    });

                    new Chart($("#trendChart").get(0).getContext("2d"), {
                        type: "line",
                        data: {
                            labels: <% - JSON.stringify(trendData.map(d => d.date)) %>,
                            datasets: [{
                                label: "Risk Velocity",
                                data: <% - JSON.stringify(trendData.map(d => d.avg_score)) %>,
                                borderColor: "#8b5cf6",
                                tension: 0.4,
                                fill: true,
                                backgroundColor: "rgba(139, 92, 246, 0.1)"
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false } } }
                    });

                    new Chart($("#hazardsChart").get(0).getContext("2d"), {
                        type: "bar",
                        data: {
                            labels: ["River", "Fault"],
                            datasets: [{
                                data: [<%= hazardsData.near_river %>, <%= hazardsData.near_fault %>],
                                backgroundColor: ["#3b82f6", "#ef4444"],
                                borderRadius: 4
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } } } }
                    });

                })(jQuery);

                // --- Map Logic ---
                let adminMap, adminMarkersLayer, oms;
                let responders = [];
                let incidents = [];

                function initAdminMap() {
                    // Check for dark mode to set basic tile layer if desired, or stick to standard standard for map
                    const isDark = document.documentElement.classList.contains('dark');
                    const tileLayerStr = isDark ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png' : 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png';

                    adminMap = L.map('admin-map').setView([10.7202, 122.5621], 13);
                    L.tileLayer(tileLayerStr).addTo(adminMap);

                    if (typeof OverlappingMarkerSpiderfier !== 'undefined') {
                        oms = new OverlappingMarkerSpiderfier(adminMap, { keepSpiderfied: true, nearbyDistance: 20 });
                    }
                    adminMarkersLayer = L.layerGroup().addTo(adminMap);
                    refreshAdminMapData();
                    setInterval(refreshAdminMapData, 5000);
                }

                async function refreshAdminMapData() {
                    try {
                        const [rR, rI, rS] = await Promise.all([fetch('/api/responders'), fetch('/api/incidents'), fetch('/api/admin/stats')]);
                        responders = await rR.json();
                        incidents = await rI.json();
                        const stats = await rS.json();
                        if (stats) {
                            $('#total-users-count').text(stats.totalUsers);
                            $('#total-requests-count').text(stats.totalRequests);
                        }
                        plotAdminMap();
                    } catch (e) { console.error(e); }
                }

                function plotAdminMap() {
                    adminMarkersLayer.clearLayers();
                    if (oms) oms.clearMarkers();

                    responders.forEach(r => {
                        if (r.latitude && r.longitude && r.status !== 'offline') {
                            const color = r.status === 'active' ? '#10b981' : (r.status === 'deployed' ? '#f59e0b' : '#64748b');
                            const icon = L.divIcon({
                                className: 'responder-dot',
                                html: `<div></div>`,
                                iconSize: [16, 16]
                            });
                            L.marker([r.latitude, r.longitude], { icon }).addTo(adminMarkersLayer)
                                .bindPopup(`<div><strong>${r.firstname} ${r.lastname}</strong><span>${r.status.toUpperCase()}</span></div>`);
                        }
                    });

                    incidents.forEach(incident => {
                        if ((incident.status === 'pending' || incident.status === 'responding') && incident.latitude && incident.longitude) {
                            const color = incident.disaster_type === 'Fire' ? '#ef4444' : (incident.disaster_type === 'Flood' ? '#3b82f6' : '#f97316');
                            const icon = L.divIcon({
                                className: 'incident-icon',
                                html: `<div><i></i></div>`,
                                iconSize: [32, 32]
                            });
                            const marker = L.marker([incident.latitude, incident.longitude], { icon }).addTo(adminMarkersLayer);
                            marker.bindPopup(`<div><strong>${incident.disaster_type} Incident</strong><div>Reported: ${new Date(incident.reported_at).toLocaleString()}</div><button onclick="openDeployModal('${incident.id}', '${incident.disaster_type}', ${incident.latitude}, ${incident.longitude})">DEPLOY UNITS</button></div>`);
                            if (oms) oms.addMarker(marker);
                        }
                    });
                }

                window.openDeployModal = async function (reportId, type, lat, lng) {
                    if (typeof window.openSharedDeployModal === 'function') {
                        await window.openSharedDeployModal({ reportId, lat, lng, type, dateStr: new Date().toLocaleString() });
                    }
                };

                if ($('#admin-map').length) initAdminMap();

                // Ensure map resizes correctly when tab/sidebar changes
                window.addEventListener('resize', () => {
                    if (adminMap) {
                        setTimeout(() => adminMap.invalidateSize(), 300);
                    }
                });
            </script>
</body>

</html>