<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="app app-signup p-0">
    <div class="row g-0 auth-wrapper">
        <div class="col-12 col-md-7 col-lg-6 auth-main-col p-5">
            <div class="d-flex flex-column align-content-end h-100">
                <div class="app-auth-body mx-auto">
                    <div class="app-auth-branding mb-4">
                        <a class="app-logo" href="/visitor"><i class="fa fa-shield-alt text-primary fs-2 me-2"></i><span
                                class="logo-text">CITYSAFE</span></a>
                    </div>
                    <h2 class="auth-heading text-center mb-2">Create Citizen Account</h2>
                    <div class="auth-intro mb-4 text-center">Join the network to receive early warning alerts and manage
                        safety reports.</div>

                    <div class="auth-form-container text-start">
                        <form class="auth-form signup-form" method="POST" action="/register">
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="sr-only" for="signup-first">Firstname</label>
                                    <input id="signup-first" name="firstname" type="text" class="form-control"
                                        placeholder="Firstname" required="required">
                                </div>
                                <div class="col-md-6">
                                    <label class="sr-only" for="signup-last">Lastname</label>
                                    <input id="signup-last" name="lastname" type="text" class="form-control"
                                        placeholder="Lastname" required="required">
                                </div>
                            </div>
                            <div class="email mb-3">
                                <label class="sr-only" for="signup-email">Email Address</label>
                                <input id="signup-email" name="email" type="email" class="form-control"
                                    placeholder="Email Address" required="required">
                            </div>
                            <div class="contact mb-3">
                                <label class="sr-only" for="signup-contact">Contact Number</label>
                                <input id="signup-contact" name="contact_number" type="text" class="form-control"
                                    placeholder="Contact Number" required="required">
                            </div>
                            <div class="password mb-3 position-relative">
                                <label class="sr-only" for="signup-password">Password</label>
                                <input id="signup-password" name="password" type="password" class="form-control"
                                    placeholder="Password" required="required">
                                <i class="fa fa-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 text-muted opacity-50"
                                    id="toggleSignupPass" style="cursor: pointer; z-index: 10;"></i>
                            </div><!--//form-group-->
                            <div class="password mb-4 position-relative">
                                <label class="sr-only" for="confirm-password">Confirm Password</label>
                                <input id="confirm-password" name="confirm_password" type="password"
                                    class="form-control" placeholder="Confirm Password" required="required">
                                <i class="fa fa-eye-slash position-absolute top-50 end-0 translate-middle-y me-3 text-muted opacity-50"
                                    id="toggleConfirmPass" style="cursor: pointer; z-index: 10;"></i>
                            </div><!--//form-group-->

                            <div id="passError" class="alert alert-danger mb-4 small py-2" style="display:none;">
                                <i class="fa fa-exclamation-triangle me-2"></i> Passwords do not match!
                            </div>

                            <div class="text-center">
                                <button type="submit" class="btn app-btn-primary w-100 theme-btn mx-auto"
                                    onclick="return validateSignup()">CREATE ACCOUNT</button>
                            </div>
                        </form>

                        <div class="auth-option text-center pt-5">Already have an account? <a class="app-link"
                                href="/login">Sign In</a></div>
                    </div><!--//auth-form-container-->

                </div><!--//auth-body-->

                <footer class="app-auth-footer">
                    <div class="container text-center py-3">
                        <small class="copyright">Designed with <span class="sr-only">love</span><i class="fas fa-heart"
                                style="color: #fb866a;"></i> by <a class="app-link" href="#" target="_blank">CitySafe
                                Team</a></small>
                    </div>
                </footer><!--//app-auth-footer-->
            </div><!--//flex-column-->
        </div><!--//auth-main-col-->
        <div class="col-12 col-md-5 col-lg-6 auth-background-col">
            <div class="auth-background-mask"></div>
            <div class="auth-background-overlay p-3 p-lg-5">
                <div class="d-flex flex-column align-content-end h-100">
                    <div class="copy-content p-3 p-lg-5 text-white">
                        <h2 class="display-5 fw-bold mb-3">Join CitySafe Today</h2>
                        <div class="auth-intro">Protecting your community starts with information. Get verified access
                            to real-time safety data.</div>
                    </div>
                    <div class="auth-footer-notes text-white-50 p-3 p-lg-5">
                        Reliable. Resilient. Responsive.
                    </div>
                </div>
            </div><!--//auth-background-overlay-->
        </div><!--//auth-background-col-->
    </div><!--//row-->

    <!-- OTP Modal -->
    <div class="modal fade" id="otpModal" tabindex="-1" aria-labelledby="otpModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="otpModalLabel">Verify Your Email</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <div class="bg-light rounded p-3 mb-4 border">
                        <i class="fa fa-envelope-open-text text-primary fs-2 mb-2"></i>
                        <p class="mb-0 small text-muted">We sent a verification code to</p>
                        <strong id="otpEmailDisplay" class="text-primary"></strong>
                    </div>
                    <div class="my-4">
                        <input type="text" id="otpInput" class="form-control form-control-lg text-center fw-800"
                            maxlength="4" placeholder="0 0 0 0"
                            style="font-size: 2rem; letter-spacing: 0.5rem !important;">
                    </div>
                    <div id="otpError" class="text-danger mb-2 small" style="display:none;">Invalid verification code
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn app-btn-primary px-5 py-2 fw-bold" onclick="verifyOtp()">Verify
                        Identity</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Core Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>

    <script>
        function setupToggle(toggleId, inputId) {
            const toggle = document.querySelector(toggleId);
            const input = document.querySelector(inputId);
            if (!toggle || !input) return;
            toggle.addEventListener("click", function () {
                const isPassword = input.getAttribute("type") === "password";
                input.setAttribute("type", isPassword ? "text" : "password");
                this.classList.toggle("fa-eye");
                this.classList.toggle("fa-eye-slash");
            });
        }

        setupToggle("#toggleSignupPass", "#signup-password");
        setupToggle("#toggleConfirmPass", "#confirm-password");

        function validateSignup() {
            const form = document.querySelector('form');
            if (!form.checkValidity()) {
                form.reportValidity();
                return false;
            }

            const p1 = document.getElementById("signup-password").value;
            const p2 = document.getElementById("confirm-password").value;
            const err = document.getElementById("passError");

            if (p1 !== p2) {
                err.style.display = "block";
                return false;
            }
            err.style.display = "none";

            const formData = {
                firstname: document.querySelector('input[name="firstname"]').value,
                lastname: document.querySelector('input[name="lastname"]').value,
                email: document.querySelector('input[name="email"]').value,
                contact_number: document.querySelector('input[name="contact_number"]').value,
                password: p1
            };

            fetch('/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('otpEmailDisplay').innerText = data.email;
                        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                            const otpModal = new bootstrap.Modal(document.getElementById('otpModal'));
                            otpModal.show();
                        }
                    } else {
                        alert(data.message || 'Registration failed');
                    }
                })
                .catch(err => {
                    alert('Error connecting to server');
                    console.error(err);
                });

            return false;
        }

        function verifyOtp() {
            const code = document.getElementById('otpInput').value;
            const email = document.getElementById('otpEmailDisplay').innerText;
            const errorDiv = document.getElementById('otpError');

            if (code.length !== 4) {
                errorDiv.innerText = "Please enter 4 digits";
                errorDiv.style.display = 'block';
                return;
            }

            fetch('/verify-code-json', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, code })
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        window.location.href = data.redirect;
                    } else {
                        errorDiv.innerText = data.message || "Invalid Code";
                        errorDiv.style.display = 'block';
                    }
                })
                .catch(err => console.error(err));
        }
    </script>
    <%- include('../partials/page-end'); %>
</body>

</html>