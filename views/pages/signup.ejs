<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>

</head>

<body>
    <div class="cs-auth-wrapper">
        <!-- Auth Form Column -->
        <div class="cs-auth-form-column">
            <div class="cs-auth-card" style="width: 100%; max-width: 500px; padding: 2.5rem;">
                <!-- Branding -->
                <div style="margin-bottom: 2rem; text-align: center;">
                    <a href="/visitor" class="cs-navbar-brand justify-center" style="font-size: 1.5rem;">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>CITYSAFE</span>
                    </a>
                </div>

                <!-- Intro -->
                <div style="margin-bottom: 2rem;">
                    <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text-bright);">
                        Create Identity</h2>
                    <p style="color: var(--text-dim); font-size: 0.95rem;">Join the network to receive early warning
                        alerts and manage localized safety operations.</p>
                </div>

                <!-- Form -->
                <form method="POST" action="/register" style="display: flex; flex-direction: column; gap: 1.15rem;">

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="cs-form-group">
                            <label for="signup-first" class="cs-label">First Name</label>
                            <input id="signup-first" name="firstname" type="text" class="cs-input" placeholder="John"
                                required>
                        </div>
                        <div class="cs-form-group">
                            <label for="signup-last" class="cs-label">Last Name</label>
                            <input id="signup-last" name="lastname" type="text" class="cs-input" placeholder="Doe"
                                required>
                        </div>
                    </div>

                    <div class="cs-form-group">
                        <label for="signup-email" class="cs-label">Email Terminal</label>
                        <div class="cs-input-wrapper">
                            <i class="fa-solid fa-at cs-input-icon"></i>
                            <input id="signup-email" name="email" type="email" class="cs-input"
                                placeholder="john.doe@example.com" required>
                        </div>
                    </div>

                    <div class="cs-form-group">
                        <label for="signup-contact" class="cs-label">Comms Frequency</label>
                        <div class="cs-input-wrapper">
                            <i class="fa-solid fa-satellite-dish cs-input-icon"></i>
                            <input id="signup-contact" name="contact_number" type="text" class="cs-input"
                                placeholder="+63 912 345 6789" required>
                        </div>
                    </div>

                    <div class="cs-form-group">
                        <label for="signup-password" class="cs-label">Security Passcode</label>
                        <div class="cs-input-wrapper">
                            <i class="fa-solid fa-lock cs-input-icon"></i>
                            <input id="signup-password" name="password" type="password" class="cs-input"
                                placeholder="••••••••" required>
                            <button type="button" class="toggle-pass" data-target="signup-password"
                                style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-dim); cursor: pointer; transition: color 0.2s;">
                                <i class="fa-solid fa-eye-slash"></i>
                            </button>
                        </div>
                    </div>

                    <div class="cs-form-group">
                        <label for="confirm-password" class="cs-label">Confirm Passcode</label>
                        <div class="cs-input-wrapper">
                            <i class="fa-solid fa-shield-halved cs-input-icon"></i>
                            <input id="confirm-password" name="confirm_password" type="password" class="cs-input"
                                placeholder="••••••••" required>
                            <button type="button" class="toggle-pass" data-target="confirm-password"
                                style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-dim); cursor: pointer; transition: color 0.2s;">
                                <i class="fa-solid fa-eye-slash"></i>
                            </button>
                        </div>
                    </div>

                    <div id="passError" class="hidden"
                        style="color: var(--danger); font-size: 0.8rem; display: flex; align-items: center; gap: 0.5rem; margin-top: -0.5rem;">
                        <i class="fa-solid fa-circle-exclamation"></i> Security passcodes do not align.
                    </div>

                    <button type="button" class="cs-btn cs-btn-primary cs-auth-btn" onclick="validateSignup()">
                        INITIALIZE CLEARANCE <i class="fa-solid fa-fingerprint" style="margin-left: 0.5rem;"></i>
                    </button>
                </form>

                <!-- Footer text -->
                <div style="margin-top: 1.5rem; text-align: center;">
                    <p style="color: var(--text-dim); font-size: 0.9rem;">
                        Already possess operational clearance? <br><a href="/login" class="cs-text-link">Execute Login
                            Sequence</a>
                    </p>
                </div>

                <div
                    style="margin-top: 2rem; text-align: center; font-size: 0.75rem; color: var(--text-dim); opacity: 0.6;">
                    <p>
                        Designed with <i class="fa-solid fa-heart" style="color: var(--danger);"></i> by CitySafe
                        Project
                    </p>
                </div>
            </div>
        </div>

        <!-- Visual Hero Column -->
        <div class="cs-auth-hero-column">
            <!-- Grid pattern overlay -->
            <div
                style="position: absolute; inset: 0; background-image: radial-gradient(var(--border-glass) 1px, transparent 1px); background-size: 30px 30px; opacity: 0.3;">
            </div>

            <!-- Content -->
            <div class="cs-auth-hero-content">
                <div>
                    <div
                        style="margin-bottom: 2rem; display: inline-flex; padding: 1rem; border-radius: 1.25rem; background: var(--primary-glow); color: white; box-shadow: 0 0 30px var(--primary-glow);">
                        <i class="fa-solid fa-tower-broadcast fa-2x"></i>
                    </div>
                    <h2
                        style="font-size: 3.5rem; line-height: 1.1; margin-bottom: 1.5rem; font-weight: 800; color: white;">
                        Join CitySafe<br><span
                            style="background: linear-gradient(135deg, var(--secondary) 0%, var(--accent) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Node
                            Array</span></h2>
                    <p
                        style="font-size: 1.1rem; line-height: 1.6; color: rgba(255,255,255,0.8); margin-bottom: 2rem; max-width: 500px;">
                        Protecting your sector starts with information. Get verified operational access to real-time
                        safety telemetry.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden element to store email for OTP -->
    <div id="otpEmailDisplay"></div>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Password toggles
        document.querySelectorAll('.toggle-pass').forEach(btn => {
            btn.addEventListener('click', function () {
                const targetId = this.getAttribute('data-target');
                const passInput = document.getElementById(targetId);
                const icon = this.querySelector('i');

                if (passInput.type === "password") {
                    passInput.type = "text";
                    icon.classList.remove("fa-eye-slash");
                    icon.classList.add("fa-eye", "text-indigo-500", "dark:text-indigo-400");
                } else {
                    passInput.type = "password";
                    icon.classList.add("fa-eye-slash");
                    icon.classList.remove("fa-eye", "text-indigo-500", "dark:text-indigo-400");
                }
            });
        });

        // Validation & OTP flow using SweetAlert2
        function validateSignup() {
            const form = document.querySelector('form');
            if (!form.checkValidity()) {
                form.reportValidity();
                return false;
            }

            const p1 = document.getElementById("signup-password").value;
            const p2 = document.getElementById("confirm-password").value;
            const err = document.getElementById("passError");

            if (p1 !== p2) {
                err.classList.remove('hidden');
                return false;
            }
            err.classList.add('hidden');

            const formData = {
                firstname: document.getElementById('signup-first').value,
                lastname: document.getElementById('signup-last').value,
                email: document.getElementById('signup-email').value,
                contact_number: document.getElementById('signup-contact').value,
                password: p1
            };

            Swal.fire({
                title: 'Transmitting Clearance Request',
                text: 'Please wait while we establish your operational node...',
                allowOutsideClick: false,
                showConfirmButton: false,
                background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827',
                didOpen: () => { Swal.showLoading() }
            });

            fetch('/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            })
                .then(res => res.json())
                .then(data => {
                    Swal.close();
                    if (data.success) {
                        document.getElementById('otpEmailDisplay').innerText = data.email;
                        showOtpModal(data.email);
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Clearance Denied',
                            text: data.message || 'Registration sequence failed.',
                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                        });
                    }
                })
                .catch(err => {
                    Swal.close();
                    Swal.fire({
                        icon: 'error',
                        title: 'Comms Failure',
                        text: 'Unable to connect to the command center.',
                        background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                        color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                    });
                    console.error(err);
                });

            return false;
        }

        function showOtpModal(email) {
            Swal.fire({
                title: '<span>Verify Clearance</span>',
                html: `
                    <div>
                        Authentication packet dispatched to:<br>
                        <strong>${email}</strong>
                    </div>
                    <input type="text" id="otpInput" maxlength="4" placeholder="0000" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
                    <div id="otpError">Invalid authorization code</div>
                `,
                showCancelButton: true,
                confirmButtonText: '<span>Authorize</span>',
                cancelButtonText: '<span>Abort</span>',
                confirmButtonColor: '#4f46e5',
                cancelButtonColor: '#6b7280',
                customClass: {
                    popup: 'glass-swal',
                    confirmButton: 'rounded-lg shadow-lg shadow-indigo-500/40',
                    cancelButton: 'rounded-lg'
                },
                preConfirm: () => {
                    const code = document.getElementById('otpInput').value;
                    if (code.length !== 4) {
                        Swal.showValidationMessage('Requires 4-digit code');
                        return false;
                    }
                    return code;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    verifyOtp(result.value);
                }
            });
        }

        function verifyOtp(code) {
            const email = document.getElementById('otpEmailDisplay').innerText;

            Swal.fire({
                title: 'Verifying Signal',
                allowOutsideClick: false,
                showConfirmButton: false,
                background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827',
                didOpen: () => { Swal.showLoading() }
            });

            fetch('/verify-code-json', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, code })
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Clearance Granted',
                            showConfirmButton: false,
                            timer: 1500,
                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                        }).then(() => {
                            window.location.href = data.redirect;
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Clearance Denied',
                            text: data.message || "Invalid Authorization Code.",
                            confirmButtonText: 'Retry',
                            confirmButtonColor: '#4f46e5',
                            background: document.documentElement.classList.contains('dark') ? '#1f2937' : '#ffffff',
                            color: document.documentElement.classList.contains('dark') ? '#f3f4f6' : '#111827'
                        }).then(() => {
                            showOtpModal(email);
                        });
                    }
                })
                .catch(err => {
                    console.error(err);
                    Swal.close();
                });
        }
    </script>
</body>

</html>