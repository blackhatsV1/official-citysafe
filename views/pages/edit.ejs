<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body
    class="bg-gradient-glass-light dark:bg-gradient-glass-dark text-gray-800 dark:text-gray-100 min-h-screen flex flex-col">
    <%- include('../partials/page-start'); %>

        <header class="sticky top-0 z-50">
            <%- include('../partials/admin-navbar', { currentPage: 'userslist' }); %>
        </header>

        <div class="flex flex-1 overflow-hidden relative">
            <aside class="z-40">
                <%- include('../partials/admin-sidebar', { currentPage: 'userslist' }); %>
            </aside>

            <main class="flex-1 px-4 py-8 sm:px-6 lg:px-8 overflow-y-auto w-full relative">
                <div class="max-w-5xl mx-auto space-y-6">

                    <div class="flex items-center gap-3 px-2 mb-2">
                        <div
                            class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-400 flex items-center justify-center shadow-inner">
                            <i class="fa fa-user-pen text-xl"></i>
                        </div>
                        <h1 class="text-3xl font-black text-gray-900 dark:text-gray-100 tracking-tight uppercase">Modify
                            User Profile</h1>
                    </div>

                    <div class="glass-panel overflow-hidden border-t-4 border-indigo-500 shadow-lg relative">
                        <!-- Glow effect -->
                        <div
                            class="absolute -top-10 -right-10 w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none">
                        </div>

                        <div
                            class="px-6 py-4 border-b border-indigo-100 dark:border-indigo-900/30 bg-indigo-50/50 dark:bg-indigo-900/10 flex items-center justify-between z-20 relative">
                            <h4
                                class="text-sm font-bold uppercase tracking-wider text-gray-800 dark:text-gray-200 flex items-center gap-2">
                                <i class="fa fa-address-card text-indigo-500"></i> Account Data
                            </h4>
                            <div
                                class="px-2 py-1 bg-white/50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">
                                User ID: <%= user.id %>
                            </div>
                        </div>

                        <div class="p-6 md:p-8 relative z-10">
                            <form action="/update/<%= user.id %>" method="POST" class="space-y-8">

                                <!-- Personal Info Section -->
                                <div class="space-y-6">
                                    <h5
                                        class="text-xs font-black uppercase tracking-widest text-indigo-600 dark:text-indigo-400 border-b border-gray-200 dark:border-gray-700/50 pb-2 mb-4 flex items-center gap-2">
                                        <i class="fa fa-circle-user"></i> Personal Identification
                                    </h5>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div class="space-y-2">
                                            <label for="firstname"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">First
                                                Name</label>
                                            <input type="text" id="firstname" name="firstname"
                                                value="<%= user.firstname %>" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="lastname"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Last
                                                Name</label>
                                            <input type="text" id="lastname" name="lastname"
                                                value="<%= user.lastname %>" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="email"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Email
                                                Address</label>
                                            <input type="email" id="email" name="email" value="<%= user.email %>"
                                                required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="contact_number"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Contact
                                                Number</label>
                                            <input type="number" id="contact_number" name="contact_number"
                                                value="<%= user.contact_number %>" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                    </div>
                                </div>

                                <!-- Address Info Section -->
                                <div class="space-y-6">
                                    <h5
                                        class="text-xs font-black uppercase tracking-widest text-indigo-600 dark:text-indigo-400 border-b border-gray-200 dark:border-gray-700/50 pb-2 mb-4 flex items-center gap-2">
                                        <i class="fa fa-map-location-dot"></i> Geographical Data
                                    </h5>
                                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                        <div class="space-y-2 lg:col-span-2">
                                            <label for="street_address"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Street
                                                Address</label>
                                            <input type="text" id="street_address" name="street_address"
                                                value="<%= user.street_address %>" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="barangay"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Barangay</label>
                                            <input type="text" id="barangay" name="barangay"
                                                value="<%= user.barangay %>" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="city"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">City
                                                / Municipality</label>
                                            <input type="text" id="city" name="city" value="<%= user.city %>" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="province"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Province</label>
                                            <input type="text" id="province" name="province"
                                                value="<%= user.province %>" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="postal_code"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Postal
                                                Code</label>
                                            <input type="text" id="postal_code" name="postal_code"
                                                value="<%= user.postal_code %>" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="country"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Country</label>
                                            <input type="text" id="country" name="country" value="<%= user.country %>"
                                                required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="landmark"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Landmark</label>
                                            <input type="text" id="landmark" name="landmark"
                                                value="<%= user.landmark %>" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2">
                                            <label for="address_type"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Address
                                                Type</label>
                                            <input type="text" id="address_type" name="address_type"
                                                value="<%= user.address_type %>" placeholder="e.g. Home, Office"
                                                required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white">
                                        </div>
                                        <div class="space-y-2 md:col-span-2 lg:col-span-3">
                                            <label for="additional_instructions"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Additional
                                                Guidance / Instructions</label>
                                            <textarea id="additional_instructions" name="additional_instructions"
                                                rows="2" required
                                                class="w-full px-4 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white"><%= user.additional_instructions %></textarea>
                                        </div>
                                    </div>
                                </div>

                                <!-- Security Section -->
                                <div class="space-y-4">
                                    <h5
                                        class="text-xs font-black uppercase tracking-widest text-indigo-600 dark:text-indigo-400 border-b border-gray-200 dark:border-gray-700/50 pb-2 mb-4 flex items-center gap-2">
                                        <i class="fa fa-shield-halved"></i> Permissions & Authentication
                                    </h5>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div class="space-y-2">
                                            <label for="role"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">User
                                                Role Priority</label>
                                            <div class="relative group">
                                                <div
                                                    class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400 group-focus-within:text-indigo-500 transition-colors">
                                                    <i class="fa fa-id-badge"></i>
                                                </div>
                                                <select id="role" name="role" required
                                                    class="w-full pl-10 pr-10 py-2.5 bg-white/40 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white appearance-none cursor-pointer">
                                                    <option value="user" <%=user.role==='user' ? 'selected' : '' %>
                                                        class="bg-white dark:bg-gray-800 text-gray-900
                                                        dark:text-gray-100">User</option>
                                                    <option value="admin" <%=user.role==='admin' ? 'selected' : '' %>
                                                        class="bg-white dark:bg-gray-800 text-gray-900
                                                        dark:text-gray-100">Administrator</option>
                                                </select>
                                                <div
                                                    class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-gray-400">
                                                    <i class="fa fa-chevron-down text-xs"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="space-y-2">
                                            <label for="password"
                                                class="block text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 ml-1">Override
                                                Password (Optional)</label>
                                            <div class="relative group">
                                                <div
                                                    class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400 group-focus-within:text-indigo-500 transition-colors">
                                                    <i class="fa fa-key"></i>
                                                </div>
                                                <input type="password" id="password" name="password"
                                                    placeholder="Leave empty to retain current password"
                                                    autocomplete="new-password"
                                                    class="w-full pl-10 pr-12 py-2.5 bg-indigo-50/30 dark:bg-indigo-900/10 border border-indigo-100 dark:border-indigo-800/30 rounded-xl focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all text-sm font-bold text-gray-900 dark:text-white placeholder-gray-400">

                                                <button type="button" id="togglePassword"
                                                    class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-indigo-500 focus:outline-none transition-colors">
                                                    <i class="fa fa-eye-slash w-5 text-center"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Actions -->
                                <div
                                    class="pt-6 mt-6 border-t border-gray-200 dark:border-gray-700/50 flex flex-col-reverse sm:flex-row gap-4 justify-between items-center relative z-20">
                                    <a href="/userslist"
                                        class="w-full sm:w-auto px-6 py-2.5 rounded-xl border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-bold uppercase tracking-widest text-xs hover:bg-gray-100 dark:hover:bg-gray-800 transition-all flex items-center justify-center gap-2 shadow-sm">
                                        <i class="fa fa-xmark"></i> Cancel Edit
                                    </a>
                                    <button type="submit"
                                        class="w-full sm:w-auto px-8 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-black uppercase tracking-widest text-xs transition-all shadow-md hover:shadow-indigo-500/25 flex items-center justify-center gap-2 transform hover:-translate-y-0.5">
                                        <i class="fa fa-floppy-disk"></i> COMMIT CHANGES
                                    </button>
                                </div>

                            </form>
                        </div>
                    </div>

                </div>
            </main>
        </div>

        <%- include('../partials/footer'); %>

            <script>
                const togglePassword = document.querySelector("#togglePassword");
                const passwordInput = document.querySelector("#password");
                const icon = togglePassword.querySelector("i");

                togglePassword.addEventListener("click", function () {
                    const isPassword = passwordInput.getAttribute("type") === "password";
                    passwordInput.setAttribute("type", isPassword ? "text" : "password");

                    if (isPassword) {
                        icon.classList.remove("fa-eye-slash");
                        icon.classList.add("fa-eye");
                        icon.classList.add("text-indigo-500");
                    } else {
                        icon.classList.remove("fa-eye");
                        icon.classList.add("fa-eye-slash");
                        icon.classList.remove("text-indigo-500");
                    }
                });
            </script>
            <%- include('../partials/page-end'); %>
</body>

</html>