<!-- Glassmorphic Visitor Sidebar -->
<div id="mobile-sidebar"
    class="fixed inset-y-0 left-0 w-64 glass-panel z-40 transform -translate-x-full transition-transform duration-300 xl:translate-x-0 xl:static xl:block flex flex-col h-full overflow-y-auto">
    <!-- Close Button for Mobile -->
    <div class="flex justify-end p-4 xl:hidden">
        <button onclick="document.getElementById('mobile-sidebar').classList.add('-translate-x-full')"
            class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
            <i class="fa fa-times text-xl"></i>
        </button>
    </div>

    <div class="p-6 text-center border-b border-gray-200 dark:border-gray-800">
        <a href="/visitor" class="flex items-center justify-center gap-2 text-indigo-600 dark:text-indigo-400">
            <i class="fa fa-shield-alt text-3xl"></i>
            <span class="font-bold text-2xl tracking-wider text-gray-900 dark:text-gray-100">CITYSAFE</span>
        </a>
    </div>

    <div
        class="p-4 border-b border-gray-200 dark:border-gray-800 mx-4 my-2 rounded-xl bg-gray-50/50 dark:bg-gray-800/50 backdrop-blur-sm">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
                <i class="fa fa-user-secret text-gray-500 dark:text-gray-400"></i>
            </div>
            <div>
                <h6 class="font-bold text-sm text-gray-900 dark:text-gray-100 m-0">GUEST ACCESS</h6>
                <span
                    class="px-2 py-0.5 mt-1 rounded text-xs font-semibold bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300 inline-block">PUBLIC</span>
            </div>
        </div>
    </div>

    <nav class="flex-1 px-4 py-4 space-y-2">
        <a href="/visitor"
            class="flex items-center gap-3 px-4 py-3 rounded-lg <%= (typeof page !== 'undefined' && page === 'visitor') ? 'bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 font-semibold' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800' %> transition-colors">
            <i class="fa fa-home w-5 text-center"></i>
            <span>Portal Home</span>
        </a>
        <a href="/services"
            class="flex items-center gap-3 px-4 py-3 rounded-lg <%= (typeof page !== 'undefined' && page === 'services') ? 'bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 font-semibold' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800' %> transition-colors">
            <i class="fa fa-th-list w-5 text-center"></i>
            <span>Services</span>
        </a>
        <a href="/about"
            class="flex items-center gap-3 px-4 py-3 rounded-lg <%= (typeof page !== 'undefined' && page === 'about') ? 'bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 font-semibold' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800' %> transition-colors">
            <i class="fa fa-info-circle w-5 text-center"></i>
            <span>About Us</span>
        </a>
        <a href="/contact"
            class="flex items-center gap-3 px-4 py-3 rounded-lg <%= (typeof page !== 'undefined' && page === 'contact') ? 'bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 font-semibold' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800' %> transition-colors">
            <i class="fa fa-envelope w-5 text-center"></i>
            <span>Contact</span>
        </a>
    </nav>

    <div class="p-4 mt-auto border-t border-gray-200 dark:border-gray-800">
        <div class="flex flex-col gap-3">
            <a href="/login" class="btn-glass-primary w-full text-center">Sign In</a>
            <a href="/register" class="btn-glass w-full text-center">Register</a>
        </div>
    </div>
</div>

<!-- Overlay for mobile when sidebar is open -->
<div id="sidebar-overlay"
    onclick="document.getElementById('mobile-sidebar').classList.add('-translate-x-full'); this.classList.add('hidden')"
    class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-30 hidden xl:hidden transition-opacity"></div>