<div id="app-sidepanel" class="app-sidepanel shadow-sm">
    <div id="sidepanel-drop" class="sidepanel-drop border-0"></div>
    <div class="sidepanel-inner d-flex flex-column">
        <a href="#" id="sidepanel-close" class="sidepanel-close d-xl-none">&times;</a>
        <div class="app-branding text-center">
            <a class="app-logo" href="/visitor">
                <i class="fa fa-shield-alt text-primary fs-4 me-2"></i>
                <span class="logo-text">CITYSAFE</span>
            </a>
        </div>

        <div class="app-sidepanel-user px-3 py-2 border-bottom mb-3">
            <div class="d-flex align-items-center gap-2">
                <div class="app-icon-holder small shadow-sm bg-light">
                    <i class="fa fa-user-secret text-secondary"></i>
                </div>
                <div class="overflow-hidden">
                    <h6 class="mb-0 text-truncate small fw-bold text-dark">GUEST ACCESS</h6>
                    <span class="badge bg-secondary" style="font-size: 0.6rem;">PUBLIC</span>
                </div>
            </div>
        </div>

        <nav id="app-nav-main" class="app-nav app-nav-main flex-grow-1">
            <ul class="app-menu list-unstyled accordion" id="menu-accordion">
                <li class="nav-item">
                    <a class="nav-link <%= (typeof page !== 'undefined' && page === 'visitor') ? 'active' : '' %>"
                        href="/visitor">
                        <span class="nav-icon"><i class="fa fa-home"></i></span>
                        <span class="nav-link-text">Portal Home</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= (typeof page !== 'undefined' && page === 'services') ? 'active' : '' %>"
                        href="/services">
                        <span class="nav-icon"><i class="fa fa-th-list"></i></span>
                        <span class="nav-link-text">Services</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= (typeof page !== 'undefined' && page === 'about') ? 'active' : '' %>"
                        href="/about">
                        <span class="nav-icon"><i class="fa fa-info-circle"></i></span>
                        <span class="nav-link-text">About us</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= (typeof page !== 'undefined' && page === 'contact') ? 'active' : '' %>"
                        href="/contact">
                        <span class="nav-icon"><i class="fa fa-envelope"></i></span>
                        <span class="nav-link-text">Contact</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="app-sidepanel-footer mt-auto p-3">
            <div class="d-grid gap-2">
                <a href="/login" class="btn app-btn-primary">Sign In</a>
                <a href="/register" class="btn app-btn-secondary">Register</a>
            </div>
        </div>
    </div>
</div>