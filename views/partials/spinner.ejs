<div id="spinner">
    <div>
        <div role="status" aria-hidden="true"></div>
        <div>Loading CitySafe Hub...</div>
    </div>
</div>

<script>
    // Remove spinner shortly after load or after a failsafe timeout
    window.addEventListener('load', () => {
        const spinner = document.getElementById('spinner');
        if (spinner) { spinner.classList.add('fade'); setTimeout(() => spinner.remove(), 300); }
    });
    setTimeout(() => {
        const spinner = document.getElementById('spinner');
        if (spinner) { spinner.remove(); console.warn('System: Spinner forced hidden by failsafe.'); }
    }, 3000);
</script>