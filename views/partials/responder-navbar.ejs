<!-- Glassmorphic Responder Navbar -->
<nav class="cs-navbar">
    <div class="cs-navbar-container">
        <div class="cs-navbar-utils" style="width: 100%; justify-content: space-between;">

            <!-- Mobile Sidebar Toggle & Logo -->
            <div style="display: flex; align-items: center; gap: 1rem;">
                <button id="sidepanel-toggler" class="cs-nav-btn lg:hidden">
                    <i class="fa-solid fa-bars-staggered"></i>
                </button>
                <a href="/responder" class="cs-navbar-brand">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>CITYSAFE</span>
                </a>
            </div>

            <!-- Utilities -->
            <div style="display: flex; align-items: center; gap: 1rem;">

                <!-- Theme Toggle -->
                <button class="cs-nav-btn"
                    onclick="document.documentElement.classList.toggle('dark'); localStorage.theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light'">
                    <i class="fa-solid fa-moon dark:hidden"></i>
                    <i class="fa-solid fa-sun hidden dark:block"></i>
                </button>

                <!-- Notifications Dropdown (Alpine) -->
                <div x-data="{ open: false }" style="position: relative;">
                    <button @click="open = !open" @click.outside="open = false" class="cs-nav-btn">
                        <i class="fa-solid fa-truck-fast"></i>
                        <span class="cs-badge">3</span>
                    </button>

                    <div x-show="open" x-transition class="cs-card"
                        style="position: absolute; top: calc(100% + 10px); right: 0; min-width: 260px; z-index: 100;">
                        <div
                            style="font-weight: 600; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 0.5rem; color: var(--primary); display: flex; align-items: center; gap: 0.5rem;">
                            <i class="fa-solid fa-tower-broadcast"></i> Responder Alerts
                        </div>
                        <div style="padding: 0.5rem 0;">
                            <div style="font-size: 0.85rem; font-weight: 500;">New emergency incident reported.</div>
                            <div style="font-size: 0.7rem; color: var(--text-dim); margin-top: 0.25rem;">2 mins ago
                            </div>
                        </div>
                        <div style="height: 1px; background: var(--border-glass); margin: 0.5rem 0;"></div>
                        <a href="/responder" class="cs-sidebar-link"
                            style="justify-content: center; font-size: 0.8rem;">View Dashboard</a>
                    </div>
                </div>

                <!-- Responder User Dropdown (Alpine) -->
                <div x-data="{ open: false }" style="position: relative;">
                    <button @click="open = !open" @click.outside="open = false" class="cs-btn cs-btn-ghost"
                        style="padding: 0.25rem 0.75rem;">
                        <div class="cs-user-avatar"
                            style="width: 32px; height: 32px; font-size: 0.9rem; background: var(--secondary); color: white;">
                            <i class="fa-solid fa-user-shield"></i>
                        </div>
                        <span style="margin: 0 0.5rem;">
                            <%= username %>
                        </span>
                        <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
                    </button>

                    <div x-show="open" x-transition class="cs-card"
                        style="position: absolute; top: calc(100% + 10px); right: 0; min-width: 220px; z-index: 100; padding: 0.75rem;">
                        <div
                            style="margin-bottom: 0.75rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border-glass);">
                            <div style="font-weight: 600; font-size: 0.95rem;">
                                <%= username %>
                            </div>
                            <div
                                style="font-size: 0.75rem; color: var(--secondary); font-weight: 600; text-transform: uppercase;">
                                Emergency Responder</div>
                        </div>
                        <a href="/aboutresponder" class="cs-sidebar-link"><i class="fa-solid fa-building-shield"></i>
                            System Info</a>
                        <div style="height: 1px; background: var(--border-glass); margin: 0.5rem 0;"></div>
                        <a href="/logout" class="cs-sidebar-link" style="color: var(--danger);"><i
                                class="fa-solid fa-power-off"></i> Log Out</a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</nav>