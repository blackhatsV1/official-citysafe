<!-- Glassmorphic Admin Navbar -->
<nav class="glass-nav relative">
    <div class="max-w-full mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">

            <!-- Mobile Sidebar Toggle & Logo -->
            <div class="flex items-center gap-3">
                <button id="sidepanel-toggler"
                    class="xl:hidden p-2 rounded-md text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 transition-colors focus:outline-none">
                    <i class="fa fa-bars text-xl"></i>
                </button>
                <a href="/adminpage"
                    class="xl:hidden flex items-center gap-2 text-indigo-600 dark:text-indigo-400 hover:opacity-80 transition-opacity">
                    <i class="fa fa-shield-alt text-2xl"></i>
                    <span class="font-bold text-xl tracking-wider text-gray-900 dark:text-gray-100">CITYSAFE</span>
                </a>
            </div>

            <!-- Utilities -->
            <div class="flex items-center gap-4">

                <!-- Theme Toggle -->
                <button
                    onclick="document.documentElement.classList.toggle('dark'); localStorage.theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light'"
                    class="p-2 rounded-full text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 transition-colors">
                    <i class="fa-solid fa-moon dark:hidden"></i>
                    <i class="fa-solid fa-sun hidden dark:block"></i>
                </button>

                <!-- Notifications Dropdown (Alpine) -->
                <div x-data="{ open: false }" class="relative">
                    <button @click="open = !open" @click.outside="open = false"
                        class="relative p-2 rounded-full text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 transition-colors focus:outline-none">
                        <i class="fa-solid fa-bell text-lg"></i>
                        <span
                            class="absolute top-0 right-0 inline-flex items-center justify-center w-4 h-4 text-xs font-bold leading-none text-white bg-red-500 rounded-full transform translate-x-1/4 -translate-y-1/4">!</span>
                    </button>

                    <div x-show="open" style="display: none;"
                        class="absolute right-0 mt-2 w-72 glass-panel shadow-xl z-50 overflow-hidden text-sm">
                        <div
                            class="px-4 py-3 border-b border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/50">
                            <h5 class="font-semibold text-gray-800 dark:text-gray-200 m-0">System Alerts</h5>
                        </div>
                        <div class="p-4 border-b border-gray-100 dark:border-gray-800">
                            <div class="font-medium text-gray-800 dark:text-gray-200">System Nominal - All sectors
                                clear.</div>
                            <div class="text-xs text-gray-500 mt-1">Just now</div>
                        </div>
                        <a href="/disaster-reports"
                            class="block px-4 py-3 text-center text-indigo-600 dark:text-indigo-400 hover:bg-gray-50 dark:hover:bg-gray-800 font-medium transition-colors">View
                            All Reports</a>
                    </div>
                </div>

                <!-- Admin User Dropdown (Alpine) -->
                <div x-data="{ open: false }" class="relative">
                    <button @click="open = !open" @click.outside="open = false"
                        class="flex items-center gap-2 p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors focus:outline-none">
                        <div
                            class="w-8 h-8 rounded-full bg-gray-900 border border-gray-700 dark:bg-gray-800 flex items-center justify-center text-white">
                            <i class="fa fa-user-shield"></i>
                        </div>
                    </button>

                    <div x-show="open" style="display: none;"
                        class="absolute right-0 mt-2 w-56 glass-panel py-1 shadow-xl z-50">
                        <div class="px-4 py-3 border-b border-gray-100 dark:border-gray-800 text-sm">
                            <span class="block font-semibold text-gray-900 dark:text-white">
                                <%= username %>
                            </span>
                            <span class="block text-gray-500 dark:text-gray-400 text-xs mt-0.5">Administrator</span>
                        </div>
                        <a href="/aboutadmin text-primary"
                            class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 border-b border-gray-100 dark:border-gray-800 transition-colors"><i
                                class="fa fa-info-circle w-5"></i> System Info</a>
                        <a href="/logout"
                            class="block px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"><i
                                class="fa fa-sign-out-alt w-5"></i> Log Out</a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</nav>