<head>
  <meta charset="utf-8">
  <title>CitySafe | Professional Disaster Response</title>
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <meta content="disaster, weather, location, alerts, donation" name="keywords">
  <meta content="CitySafe - Urban Disaster Response & Management" name="description">

  <!-- Favicon & PWA -->
  <link rel="icon" type="image/png" href="/images/shield.png">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/images/shield.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="CitySafe">

  <!-- Map Assets -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <!-- Interactive Alpine.js (Lightweight for toggles) -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.0/dist/cdn.min.js"></script>

  <!-- Theme Init Script -->
  <script>
    // On page load or when changing themes, best to add inline in `head` to avoid FOUC
    if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark')
    } else {
      document.documentElement.classList.remove('dark')
    }
  </script>
</head>