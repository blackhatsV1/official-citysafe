<!-- Glassmorphic User Sidebar -->
<div id="mobile-sidebar" class="cs-sidebar">
  <!-- Close Button for Mobile -->
  <div class="cs-sidebar-header lg:hidden">
    <button class="cs-nav-btn"
      onclick="document.getElementById('mobile-sidebar').classList.add('-translate-x-full'); document.getElementById('sidebar-overlay').classList.add('hidden')">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <div class="cs-sidebar-header">
    <a href="/" class="cs-navbar-brand">
      <i class="fa-solid fa-shield-halved"></i>
      <span>CITYSAFE</span>
    </a>
  </div>

  <div class="cs-sidebar-user">
    <div class="cs-user-avatar">
      <i class="fa-solid fa-user-shield"></i>
    </div>
    <div class="cs-user-info">
      <h6>
        <%= username %>
      </h6>
      <span>CITIZEN UNIT</span>
    </div>
  </div>

  <nav class="cs-sidebar-nav">
    <a href="/"
      class="cs-sidebar-link <%= (typeof currentPage !== 'undefined' && currentPage === 'index') ? 'active' : '' %>">
      <i class="fa-solid fa-tower-observation"></i>
      <span>Control Center</span>
    </a>
    <a href="/send-sos"
      class="cs-sidebar-link <%= (typeof currentPage !== 'undefined' && currentPage === 'send-sos') ? 'active' : '' %>">
      <i class="fa-solid fa-kit-medical"></i>
      <span>Emergency SOS</span>
    </a>
    <a href="/my-reports"
      class="cs-sidebar-link <%= (typeof currentPage !== 'undefined' && currentPage === 'reports') ? 'active' : '' %>">
      <i class="fa-solid fa-clipboard-list"></i>
      <span>Incident Logs</span>
    </a>
    <a href="/nearby-stations"
      class="cs-sidebar-link <%= (typeof currentPage !== 'undefined' && currentPage === 'stations') ? 'active' : '' %>">
      <i class="fa-solid fa-map-location-dot"></i>
      <span>Stations & Maps</span>
    </a>
    <a href="/assess-risk"
      class="cs-sidebar-link <%= (typeof currentPage !== 'undefined' && currentPage === 'risk') ? 'active' : '' %>">
      <i class="fa-solid fa-shield-virus"></i>
      <span>Risk Audit</span>
    </a>
  </nav>

  <div style="margin-top: auto; padding: 1rem;">
    <a href="/editaccount" class="cs-sidebar-link">
      <i class="fa-solid fa-gears"></i>
      <span>Account Settings</span>
    </a>
    <a href="/logout" class="cs-sidebar-link" style="color: var(--danger);">
      <i class="fa-solid fa-power-off"></i>
      <span>Sign Out</span>
    </a>
  </div>
</div>

<!-- Overlay for mobile when sidebar is open -->
<div id="sidebar-overlay" class="cs-sidebar-overlay"
  onclick="document.getElementById('mobile-sidebar').classList.add('-translate-x-full'); this.classList.remove('show')">
</div>