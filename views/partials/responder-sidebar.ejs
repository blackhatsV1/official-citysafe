<!-- Glassmorphic Responder Sidebar -->
<div id="mobile-sidebar">
    <!-- Close Button for Mobile -->
    <div>
        <button
            onclick="document.getElementById('mobile-sidebar').classList.add('-translate-x-full'); document.getElementById('sidebar-overlay').classList.add('hidden')">
            <i></i>
        </button>
    </div>

    <div>
        <a href="/responder">
            <i></i>
            <span>CITYSAFE</span>
        </a>
    </div>

    <div>
        <div>
            <div>
                <i></i>
            </div>
            <div>
                <h6>
                    <%= typeof username !=='undefined' ? username : 'Responder' %>
                </h6>
                <span>FIELD
                    UNIT</span>
            </div>
        </div>
    </div>

    <nav>
        <a href="/responder">
            <i></i>
            <span>Mission Control</span>
        </a>
        <a href="/responder#nearby-reports">
            <i></i>
            <span>Nearby Ops</span>
        </a>
        <a href="/responder-history">
            <i></i>
            <span>History</span>
        </a>
        <a href="/aboutresponder">
            <i></i>
            <span>Station Info</span>
        </a>
    </nav>

    <div>
        <a href="/logout">
            <i></i>
            <span>Sign Off</span>
        </a>
    </div>
</div>

<!-- Overlay for mobile when sidebar is open -->
<div id="sidebar-overlay"
    onclick="document.getElementById('mobile-sidebar').classList.add('-translate-x-full'); this.classList.add('hidden')"></div>